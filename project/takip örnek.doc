<?xml version="1.0" encoding="utf-8"?><?mso-application progid="Word.Document"?><w:wordDocument xml:space="preserve" xmlns:w="http://schemas.microsoft.com/office/word/2003/wordml"><w:lists /><w:styles><w:style w:type="paragraph" w:styleId="P0" w:default="on"><w:name w:val="Normal" /><w:pPr /><w:rPr /></w:style><w:style w:type="character" w:styleId="C0" w:default="on"><w:name w:val="Default Paragraph Font" /><w:semiHidden w:val="on" /><w:rPr /></w:style><w:style w:type="character" w:styleId="C1"><w:name w:val="Line Number" /><w:basedOn w:val="C0" /><w:semiHidden w:val="on" /><w:rPr /></w:style><w:style w:type="character" w:styleId="C2"><w:name w:val="Hyperlink" /><w:rPr><w:color w:val="0000FF" /><w:u w:val="single" /></w:rPr></w:style><w:style w:type="table" w:styleId="T0" w:default="on"><w:name w:val="Normal Table" /><w:tblPr><w:tblCellMar><w:top w:w="0" w:type="dxa" /><w:left w:w="108" w:type="dxa" /><w:bottom w:w="0" w:type="dxa" /><w:right w:w="108" w:type="dxa" /></w:tblCellMar></w:tblPr></w:style><w:style w:type="table" w:styleId="T1"><w:name w:val="Table Simple 1" /><w:basedOn w:val="T0" /><w:tblPr><w:tblBorders><w:bottom w:val="single" w:sz="4" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:insideH w:val="single" w:sz="4" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:insideV w:val="single" w:sz="4" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:left w:val="single" w:sz="4" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:right w:val="single" w:sz="4" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:top w:val="single" w:sz="4" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /></w:tblBorders><w:tblCellMar><w:left w:w="108" w:type="dxa" /><w:right w:w="108" w:type="dxa" /></w:tblCellMar></w:tblPr></w:style></w:styles><w:docPr><w:autoHyphenation w:val="off" /><w:defaultTabStop w:val="720" /><w:evenAndOddHeaders w:val="off" /></w:docPr><w:body><wx:sect xmlns:wx="http://schemas.microsoft.com/office/word/2003/auxHint"><w:tbl><w:tblPr><w:tblW w:w="5000" w:type="pct" /><w:tblInd w:w="0" w:type="dxa" /><w:tblBorders><w:bottom w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:insideH w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:insideV w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:left w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:right w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:top w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /></w:tblBorders><w:tblCellMar><w:top w:w="75" w:type="dxa" /><w:left w:w="75" w:type="dxa" /><w:bottom w:w="75" w:type="dxa" /><w:right w:w="75" w:type="dxa" /></w:tblCellMar><w:tblCellSpacing w:w="0" w:type="dxa" /></w:tblPr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>TAKİP TALEBİ</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>Örnek No:1</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>1-Alacaklının ve varsa kanuni temsilcisinin vekilinin adı, soyadı, vergi kimlik numarası, T.C. kimlik numarası, alacaklı veya vekili adına ödemenin yapılacağı banka adıyla hesap bilgileri ve yerleşim yerindeki adresi, alacaklı yabancı ülkede oturuyorsa Türkiye’de göstereceği yerleşim yerindeki adresi:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t xml:space="preserve">SEFA ÖRME KUMAŞÇILIK SANAYİ TİCARET LİMİTED ŞİRKETİ </w:t></w:r><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>( Vergi Dairesi:ESENYURT Vergi Numarası:7580430291 )</w:t><w:br w:type="text-wrapping" /><w:t>CUMHURİYET MAH. VOLKAN 1 SK. A BLOK NO: 1C İÇ KAPI NO: 1 BÜYÜKÇEKMECE / İSTANBUL</w:t><w:br w:type="text-wrapping" /><w:br w:type="text-wrapping" /></w:r><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>Av.FATMA ULUCA TELLİ</w:t></w:r><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t xml:space="preserve">, </w:t></w:r><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>Av.ULAŞ HÜSEYİN TELLİ</w:t></w:r><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t xml:space="preserve">, </w:t><w:br w:type="text-wrapping" /><w:t>MECİDİYEKÖY YOLU CD. KARSUYU SOKAK NO:2 TRUMP TOWERS KULE 1 KAT:4 D:401 ŞİŞLİ / İSTANBUL</w:t><w:br w:type="text-wrapping" /><w:t>Telefon:0212 230 89 10 - Faks:0212 247 52 04</w:t><w:br w:type="text-wrapping" /></w:r><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>Banka Hesabı:TÜRKİYE VAKIFLAR BANKASI ÇAĞLAYAN ŞUBESİ İBAN: TR170001500158007300656815</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>2-Borçlunun ve varsa kanuni temsilcisinin adı, soyadı ve yerleşim yerindeki adresi, alacaklı tarafından biliniyorsa vergi kimlik numarası:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t xml:space="preserve">1-AS GRAND DIŞ TİCARET LİMİTED ŞİRKETİ (Vergi Dairesi: LİMAN VERGİ DAİRESİ Vergi No: 7300400762) </w:t></w:r><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:br w:type="text-wrapping" /><w:t>CAMİ ŞERİF MAH. 5232 SK. BUĞDAYCI APT SİTESİ NO: 14 İÇ KAPI NO: 38 AKDENİZ / MERSİN</w:t><w:br w:type="text-wrapping" /><w:br w:type="text-wrapping" /></w:r><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t xml:space="preserve">2-SEYİDOĞLU KUMAŞÇILIK TİCARET LİMİTED ŞİRKETİ (Vergi Dairesi: LİMAN VERGİ DAİRESİ Vergi No: 7671411157) </w:t></w:r><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:br w:type="text-wrapping" /><w:t>MEVLANA MAH. GAZİ OSMAN PAŞA CAD. NO: 61 İÇ KAPI NO: 1 TOROSLAR / MERSİN</w:t><w:br w:type="text-wrapping" /></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>3-Takip terekeye karşı açılmışsa mirasçıların, adı, soyadı ve yerleşim yerindeki adresleri:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>4-Alacağın veya istenen teminatın Türk parasıyla tutarı ve faizli alacaklarda faizin miktarı ile işlemeye başladığı gün; alacak veya teminat yabancı para ise alacağın hangi tarihteki kur üzerinden talep edildiği ve faizi:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:tbl><w:tblPr><w:tblW w:w="5000" w:type="pct" /><w:tblInd w:w="0" w:type="dxa" /><w:tblBorders><w:bottom w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:insideH w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:insideV w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:left w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:right w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /><w:top w:val="none" w:sz="0" w:space="0" w:shadow="off" w:frame="off" w:color="000000" /></w:tblBorders><w:tblCellMar><w:top w:w="15" w:type="dxa" /><w:left w:w="15" w:type="dxa" /><w:bottom w:w="15" w:type="dxa" /><w:right w:w="15" w:type="dxa" /></w:tblCellMar><w:tblCellSpacing w:w="15" w:type="dxa" /></w:tblPr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1500" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>832.920,00</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="75" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>TL Çek alacağı (30.09.2025)</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1500" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>99.351,38</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="75" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>TL İşlemiş Faiz (TİCARİ)</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1500" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>83.292,00</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="75" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>TL Karşılıksız Çek Tazminati alacağı (30.09.2025)</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1500" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>2.498,76</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="75" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>TL Komisyon alacağı (30.09.2025)</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1500" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>+--------------</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="75" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1500" w:type="pct" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:jc w:val="right" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>1.018.062,14 TL</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="75" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>1.018.062,14 TL tutarındaki alacağın icra gideri, vek.ücr. ve takip tarihinden itibaren asıl alacağa işleyecek (YILLIK %39,75 (TİCARİ) değişen oranlarda) faizi ile tahsili talebidir. (Fazlaya dair ve faiz oranlarındaki artıştan doğan talep hakkımız saklıdır) TBK. 100.mad. gereğince kısmi ödemeler öncelikle işlemiş faiz, masraf ve fer'ilere mahsup edilecektir.</w:t><w:br w:type="text-wrapping" /></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>5-Taşınır rehni veya ipotekle temin edilmiş olan bir alacak talebinde rehnedilenin ne olduğu rehnedilen üçüncü şahıslar tarafından verilmiş veya mülkiyeti üçüncü şahsa geçmiş ise adı ve soyadı, rehnedilen şey üzerinde, sonra gelen rehin hakkı varsa bu hakka sahip olan kişinin adı, soyadı, yerleşim yerindeki adresi:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>6-Takip, ilâma veya ilâm hükmündeki belgeye müstenit ise ilâm veya belgeyi veren makamın adı, ilâm veya belgenin tarihi, numarası ve özeti:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>7-Adî veya hasılat kiralarına ait takip talebi:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>8-Tevdi edilen senet (Poliçe, emre muharrer senet, çek) in tarih ve numarası, özeti, senede dayalı değilse borcun sebebi:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>832.920,00 TL ÇEK (Keşide Tarihi:30.09.2025 Seri No:8024066 Banka ve Şube:Türkiye Garanti Bankası 0718 Mersin Çarşı Şubesi)</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>9-Alacaklının takip yollarından hangisini seçtiği:</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>HACİZ</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:gridSpan w:val="2" /><w:tcW w:w="0" w:type="auto" /><w:vAlign w:val="center" /></w:tcPr><w:p><w:pPr><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>Yukarıda yazdığım hakkımın alınmasını talep ederim.</w:t></w:r></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:b w:val="on" /><w:color w:val="000000" /></w:rPr><w:t>(İİK m.8, 58)</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="left" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc></w:tr><w:tr><w:trPr><w:gridAfter w:val="0" /><w:gridBefore w:val="0" /></w:trPr><w:tc><w:tcPr><w:tcW w:w="1550" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="both" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="3450" w:type="pct" /></w:tcPr><w:p><w:pPr><w:jc w:val="center" /><w:ind w:left="0" w:right="0" /><w:rPr><w:color w:val="000000" /></w:rPr></w:pPr><w:r><w:rPr><w:color w:val="000000" /></w:rPr><w:t>07.01.2026</w:t><w:br w:type="text-wrapping" /><w:t xml:space="preserve">Av.FATMA ULUCA TELLİ Av.ULAŞ HÜSEYİN TELLİ </w:t><w:br w:type="text-wrapping" /><w:t>Alacaklı veya Vekilinin İmzası</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p><w:pPr><w:spacing w:before="0" w:after="0" /><w:ind w:left="0" w:right="0" /></w:pPr></w:p><w:sectPr><w:type w:val="next-page" /><w:pgSz w:w="11907" w:h="16839" w:code="9" /><w:pgMar w:left="720" w:right="384" w:top="576" w:bottom="384" /></w:sectPr></wx:sect></w:body></w:wordDocument>