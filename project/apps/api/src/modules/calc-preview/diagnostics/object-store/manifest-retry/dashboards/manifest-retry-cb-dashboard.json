{
  "annotations": {
    "list": []
  },
  "description": "Phase 10.1.7/10.1.13 - Manifest Retry Circuit Breaker & Queue Metrics",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "manifest_retry_circuit_breaker_state",
          "legendFormat": "{{state}}",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "OFF", "color": "dark-gray" } } },
            { "type": "value", "options": { "1": { "text": "ON", "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "open" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "half_open" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "CB Open Duration (seconds)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "manifest_retry_circuit_breaker_open_seconds",
          "legendFormat": "Open Duration",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 60 },
              { "color": "red", "value": 120 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "CB Trips by Reason (5m rate)",
      "type": "piechart",
      "gridPos": { "h": 4, "w": 6, "x": 10, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(manifest_retry_circuit_breaker_trips_total[5m])) by (trip_reason)",
          "legendFormat": "{{trip_reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Queue Size by Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "manifest_retry_queue_size",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "CB Transitions Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(manifest_retry_circuit_breaker_transitions_total[5m])) by (from, to, reason)",
          "legendFormat": "{{from}} → {{to}} ({{reason}})",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "title": "Retry Success Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(manifest_retry_job_done_total{reason=\"ok\"}[5m])) / sum(rate(manifest_retry_job_done_total[5m]))",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "DLQ Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 4 },
      "targets": [
        {
          "expr": "sum(rate(manifest_retry_job_dlq_total[5m])) / sum(rate(manifest_retry_job_done_total[5m]))",
          "legendFormat": "DLQ Ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.1 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Jobs by Outcome (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(manifest_retry_job_done_total[5m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 8,
      "title": "DLQ by Error Code (5m rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "sum(rate(manifest_retry_job_dlq_total[5m])) by (error_code)",
          "legendFormat": "{{error_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 10,
      "title": "DLQ Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "manifest_dlq_size",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 11,
      "title": "DLQ Oldest Age",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 6, "y": 20 },
      "targets": [
        {
          "expr": "manifest_dlq_oldest_age_seconds",
          "legendFormat": "Oldest Age",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3600 },
              { "color": "red", "value": 86400 }
            ]
          }
        }
      }
    },
    {
      "id": 12,
      "title": "Job Duration p50/p95/p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 20 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(manifest_retry_job_duration_seconds_bucket{outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p50 (success)",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(manifest_retry_job_duration_seconds_bucket{outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p95 (success)",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(manifest_retry_job_duration_seconds_bucket{outcome=\"success\"}[5m])) by (le))",
          "legendFormat": "p99 (success)",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 13,
      "title": "Queue Size Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "manifest_retry_queue_size",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 14,
      "title": "Job Duration by Outcome",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(manifest_retry_job_duration_seconds_bucket[5m])) by (outcome, le))",
          "legendFormat": "p95 {{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["manifest-retry", "circuit-breaker", "phase-10", "dlq", "queue"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Manifest Retry - Circuit Breaker & Queue",
  "uid": "manifest-retry-cb",
  "version": 2
