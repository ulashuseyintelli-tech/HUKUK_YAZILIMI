{
  "id": "003",
  "name": "high-fee-ratio-warning",
  "description": "Düşük anapara - yüksek masraf oranı uyarısı beklenir",
  "tags": ["fee", "warning", "policy"],
  
  "request": {
    "tenantId": "t_demo",
    "payload": {
      "principalAmount": 1000,
      "currency": "TRY",
      "interestType": "LEGAL_3095",
      "startDate": "2025-01-01",
      "endDate": "2025-03-01",
      "caseType": "ILAMSIZ",
      "debtorCount": 1
    }
  },
  
  "expect": {
    "status": "OK",
    "tolerances": {
      "moneyAbs": 0.01,
      "moneyRel": 0.000001
    },
    "must": {
      "success": true,
      "status": "FULL",
      "policy.softWarnings": "object"
    },
    "forbid": {
      "status": ["UNAVAILABLE"]
    },
    "traceAssertions": {
      "noPII": true,
      "maxDurationMs": 1500,
      "breakerNeverOpen": ["interest_engine", "fee_engine"],
      "noFallback": true
    }
  }
}
