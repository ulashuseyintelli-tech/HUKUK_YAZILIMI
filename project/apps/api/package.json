{
  "name": "@hukuk/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/apps/api/src/main.js",
    "start:prod": "node dist/apps/api/src/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:phase9c": "jest --testPathPattern=\"bundle-manifest|bundle-seal\" --verbose",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "npx --yes tsx prisma/seed.ts",
    "db:bootstrap": "pnpm db:push && pnpm db:seed",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "seed:rates": "ts-node scripts/seed-interest-rates.ts",
    "seed:tm47d-happy-path": "npx --yes tsx src/scripts/tm47d-happy-path-seed.ts",
    "backfill:due-claimitem": "npx --yes tsx scripts/backfill-due-to-claimitem.ts",
    "clean": "rm -rf dist .turbo node_modules"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.974.0",
    "@hukuk/types": "workspace:*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.0",
    "@prisma/client": "^5.8.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^7.0.4",
    "@types/pdfmake": "^0.2.12",
    "adm-zip": "^0.5.16",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "ioredis": "^5.3.2",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "lru-cache": "^11.2.6",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "nodemailer": "^7.0.11",
    "openai": "^6.10.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "1.1.1",
    "pdf-poppler": "^0.2.3",
    "pdfkit": "^0.17.2",
    "pdfmake": "^0.2.20",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "tesseract.js": "^6.0.1",
    "xmlbuilder2": "^4.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.3.0",
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.11.0",
    "@types/passport-jwt": "^4.0.0",
    "@types/supertest": "^6.0.3",
    "fast-check": "^4.4.0",
    "ioredis-mock": "^8.9.0",
    "jest": "^29.7.0",
    "prisma": "^5.8.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3",
    "xlsx": "^0.18.5"
  }
}
