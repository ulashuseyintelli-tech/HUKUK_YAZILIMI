{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "entryFile": "apps/api/src/main",
  "compilerOptions": {
    "tsConfigPath": "tsconfig.dev.json",
    "deleteOutDir": true,
    "assets": [
      {
        "include": "config/**/*.yaml",
        "outDir": "dist"
      }
    ],
    "watchAssets": true
  }
}
