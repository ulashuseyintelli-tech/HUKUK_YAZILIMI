// ==================== OFİS PERSONELİ (AVUKAT HARİÇ) ====================

// Personel Türleri
enum StaffType {
  STAJYER_AVUKAT    // Stajyer Avukat
  OFIS_KATIBI       // Ofis Katibi
  ADLI_KATIP        // Adli Katip (adliye koordinasyonu)
  SEKRETER          // Sekreter
  MUHASEBE          // Muhasebe
  ARSIV             // Arşiv Sorumlusu
  DIGER             // Diğer
}

// Ofis Personeli (Avukat hariç tüm çalışanlar)
model StaffMember {
  id          String     @id @default(cuid())
  tenantId    String
  officeId    String?
  
  // Kişisel Bilgiler
  firstName   String
  lastName    String
  tckn        String?    // TC Kimlik No
  email       String?
  phone       String?
  
  // Personel Türü
  staffType   StaffType
  
  // Genel Yetkiler (büro genelinde varsayılan)
  canCreateCase        Boolean @default(false)  // Dosya oluşturabilir
  canEditCase          Boolean @default(false)  // Dosya düzenleyebilir
  canGenerateDocuments Boolean @default(false)  // Belge taslağı hazırlayabilir
  canApproveDocuments  Boolean @default(false)  // Belge onaylayabilir
  canSeeFinance        Boolean @default(false)  // Muhasebe modülünü görebilir
  canApproveFinance    Boolean @default(false)  // Muhasebe işlemi onaylayabilir
  canSendNotifications Boolean @default(false)  // Tebligat gönderebilir
  
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  caseAssignments CaseStaff[]

  @@index([tenantId])
  @@index([officeId])
  @@index([staffType])
  @@index([isActive])
}

// Dosya Bazlı Personel Ataması
model CaseStaff {
  id            String      @id @default(cuid())
  caseId        String
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  
  // Bu dosyadaki rol
  roleOnCase    String      // STAJYER, KONTROL, YAZI_ISLERI, MUHASEBE, TEBLIGAT, ARSIV
  
  // Bu dosyadaki yetkiler (personelin genel yetkilerini override edebilir)
  canEdit       Boolean     @default(false)  // Dosya içeriğini düzenleyebilir
  canApprove    Boolean     @default(false)  // İşlem onaylayabilir
  canView       Boolean     @default(true)   // Sadece görüntüleyebilir
  
  // Bildirimler
  receiveNotifications Boolean @default(true)
  
  // Atama bilgileri
  assignedAt    DateTime    @default(now())
  assignedById  String?     // Kim atadı
  notes         String?     // Özel notlar
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([caseId, staffMemberId])
  @@index([caseId])
  @@index([staffMemberId])
  @@index([roleOnCase])
}

// ==================== MÜVEKKİL İLETİŞİM SİSTEMİ ====================

// Müvekkil Bildirimleri (E-posta, SMS, WhatsApp logu)
model ClientNotification {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseId        String?  // İlgili dosya (opsiyonel)
  
  // İletişim Kanalı
  channel       String   // EMAIL, SMS, WHATSAPP
  
  // Bildirim Türü
  type          String   // MASRAF_ISTEK, GENEL_BILGILENDIRME, RAPOR, HATIRLATMA, DIGER
  
  // İçerik
  subject       String?  // E-posta konusu
  body          String   @db.Text // Mesaj içeriği
  
  // Durum
  status        String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt        DateTime?
  deliveredAt   DateTime?
  errorMessage  String?
  
  // Gönderen
  sentById      String
  
  // Meta
  metadata      Json?    // Ek bilgiler (template id, vs.)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([caseId])
  @@index([channel])
  @@index([type])
  @@index([status])
}

// Portal Bildirimleri (Müvekkil portalında gösterilecek bildirimler)
model PortalNotification {
  id            String   @id @default(cuid())
  clientId      String
  caseId        String?  // İlgili dosya (opsiyonel)
  
  // Bildirim Türü
  type          String   // TAHSILAT, ISLEM, BELGE, DURUM_DEGISIKLIGI, GENEL
  
  // İçerik
  title         String
  message       String
  
  // Durum
  isRead        Boolean  @default(false)
  readAt        DateTime?
  
  // Link (opsiyonel - tıklandığında yönlendirilecek sayfa)
  linkUrl       String?
  
  createdAt     DateTime @default(now())

  @@index([clientId])
  @@index([caseId])
  @@index([isRead])
  @@index([createdAt])
}

// Portal Belgeleri (Müvekkilin portaldan yüklediği belgeler)
model PortalDocument {
  id            String   @id @default(cuid())
  clientId      String
  caseId        String?  // İlgili dosya (opsiyonel)
  tenantId      String
  
  // Belge Bilgileri
  type          String   // VEKALET, KIMLIK, SOZLESME, DIGER
  title         String
  description   String?
  
  // Dosya Bilgileri
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  
  // Durum
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt    DateTime?
  reviewedBy    String?  // User ID
  reviewNote    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId])
  @@index([caseId])
  @@index([tenantId])
  @@index([status])
}

// Portal Mesajları (Müvekkil-Büro arası mesajlaşma)
model PortalMessage {
  id            String   @id @default(cuid())
  clientId      String
  tenantId      String
  caseId        String?  // İlgili dosya (opsiyonel)
  
  // Mesaj İçeriği
  content       String
  
  // Gönderen
  senderType    String   // CLIENT veya OFFICE
  senderId      String   // ClientPortalUser ID veya User ID
  senderName    String
  
  // Okunma Durumu
  isRead        Boolean  @default(false)
  readAt        DateTime?
  
  createdAt     DateTime @default(now())

  @@index([clientId])
  @@index([tenantId])
  @@index([caseId])
  @@index([createdAt])
}

// Masraf Talepleri
model ExpenseRequest {
  id            String   @id @default(cuid())
  tenantId      String
  caseId        String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Masraf Kalemleri
  items         Json     // [{description: string, amount: number}]
  totalAmount   Decimal  @db.Decimal(15, 2)
  
  // Durum
  status        String   @default("PENDING") // PENDING, SENT, APPROVED, REJECTED, PAID
  
  // Gönderim
  sentAt        DateTime?
  sentVia       String?  // EMAIL, SMS
  notificationId String? // İlgili ClientNotification
  
  // Yanıt
  respondedAt   DateTime?
  responseNotes String?
  
  // Ödeme
  paidAt        DateTime?
  paidAmount    Decimal? @db.Decimal(15, 2)
  
  // Oluşturan
  createdById   String
  
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

// E-posta Şablonları
model EmailTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  
  // Şablon Bilgileri
  name        String   // Şablon adı
  code        String   // Benzersiz kod (MASRAF_TALEBI, BILGILENDIRME, vb.)
  category    String   // MASRAF, BILGILENDIRME, RAPOR, DIGER
  
  // İçerik
  subject     String   // E-posta konusu (değişkenler içerebilir)
  body        String   @db.Text // HTML içerik (değişkenler içerebilir)
  
  // Değişkenler: {{clientName}}, {{caseNo}}, {{amount}}, {{dueDate}}, vb.
  
  isActive    Boolean  @default(true)
  isDefault   Boolean  @default(false) // Varsayılan şablon
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([isActive])
}

// ==================== ÖZEL GÜNLER & TEBRİK SİSTEMİ ====================

// Özel Günler (Bayramlar, Anma Günleri, vb.)
model SpecialDay {
  id          String   @id @default(cuid())
  tenantId    String?  // null = sistem geneli, değer = büroya özel
  
  // Gün Bilgileri
  name        String   // Ramazan Bayramı, Kurban Bayramı, 10 Kasım, vb.
  type        String   // RELIGIOUS (Dini), NATIONAL (Milli), MEMORIAL (Anma), CUSTOM (Özel)
  
  // Tarih (yıl olmadan - her yıl tekrarlar)
  month       Int      // 1-12
  day         Int      // 1-31
  
  // Bazı bayramlar değişken tarihli (Hicri takvim)
  isVariable  Boolean  @default(false)  // Değişken tarihli mi
  year        Int?     // Değişken tarihli ise hangi yıl için geçerli
  
  // Mesaj Şablonu
  greetingMessage String?  // Varsayılan tebrik mesajı
  smsMessage      String?  // SMS için kısa mesaj (160 karakter)
  
  // Ayarlar
  isActive    Boolean  @default(true)
  sendGreeting Boolean @default(true)  // Otomatik tebrik gönder
  daysBeforeReminder Int @default(0)   // Kaç gün önce hatırlat
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([month, day])
  @@index([type])
  @@index([isActive])
}

// Tebrik Kuyruğu (Gönderilecek tebrikler)
model GreetingQueue {
  id          String   @id @default(cuid())
  tenantId    String
  
  // Alıcı
  clientId    String
  
  // Tebrik Türü
  type        String   // BIRTHDAY, FOUNDING_ANNIVERSARY, POA_ANNIVERSARY, HOLIDAY, MEMORIAL
  
  // Özel gün referansı (bayram/anma günü için)
  specialDayId String?
  
  // Gönderim
  channel     String   // EMAIL, SMS, BOTH
  scheduledAt DateTime // Gönderilecek tarih/saat
  
  // Mesaj
  subject     String?  // E-posta konusu
  message     String   // Mesaj içeriği
  
  // Durum
  status      String   @default("PENDING") // PENDING, SENT, FAILED, CANCELLED
  sentAt      DateTime?
  errorMessage String?
  
  // İlişkili bildirim
  notificationId String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type])
}

// ==================== TAKVİM & AJANDA ====================

// Takvim Etkinlikleri
model CalendarEvent {
  id            String   @id @default(cuid())
  tenantId      String
  
  // Etkinlik Bilgileri
  title         String
  description   String?
  date          DateTime
  time          String?  // "10:00" formatında
  
  // Tür
  type          String   // DURUSMA, HATIRLATICI, GOREV, DIGER
  
  // İlişkili Dosya (opsiyonel)
  caseId        String?
  
  // Konum
  location      String?
  
  // Durum
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  
  // Oluşturan
  createdById   String
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@index([caseId])
  @@index([type])
  @@index([isCompleted])
}

// ==================== DENETİM KAYITLARI (AUDIT LOG) ====================

// Audit Log - Tüm önemli işlemlerin kaydı
model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  
  // İşlem Bilgileri
  action        String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT, vb.
  entityType    String   // CASE, CLIENT, POA, USER, vb.
  entityId      String?  // İlgili kaydın ID'si
  
  // Kullanıcı
  userId        String?
  userName      String?
  userIp        String?
  userAgent     String?
  
  // Değişiklik Detayları
  oldValues     Json?    // Eski değerler
  newValues     Json?    // Yeni değerler
  
  // Ek Bilgiler
  description   String?
  metadata      Json?
  
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}
