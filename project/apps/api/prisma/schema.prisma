  resolvedAt DateTime?
  resolvedBy String?
  resolution String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([isResolved])
}

// ==================== DENETİM KAYITLARI (AUDIT LOG) ====================

// Audit Log - Tüm önemli işlemlerin kaydı
model AuditLog {
  id       String @id @default(cuid())
  tenantId String

  // İşlem Bilgileri
  action     String // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT, vb.
  entityType String // CASE, CLIENT, POA, USER, vb.
  entityId   String? // İlgili kaydın ID'si

  // Kullanıcı
  userId    String?
  userName  String?
  userIp    String?
  userAgent String?

  // Değişiklik Detayları
  oldValues Json? // Eski değerler
  newValues Json? // Yeni değerler

  // Ek Bilgiler
  description String?
  metadata    Json?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

// ==================== KAMU KURUMLARI (DETSİS) ====================

// Kamu Kurumu Türleri
enum PublicInstitutionCategory {
  BAKANLIK // Bakanlıklar
