  PTT
  SMS
  EMAIL
  PUSH
}

enum NotificationStatus {
  PENDING
  SCHEDULED
  SENT
  DELIVERED
  READ
  RESPONDED
  FAILED
  EXPIRED
}

// OCR Tespit Edilen Takip Türü
enum DetectedCaseType {
  ILAMLI // İlamlı takip
  ILAMSIZ // İlamsız takip
  KAMBIYO // Kambiyo senetlerine özgü
  KIRA // Kira alacağı
