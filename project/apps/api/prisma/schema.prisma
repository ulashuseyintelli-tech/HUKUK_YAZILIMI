model IcrabotFactAudit {
  id       String @id @default(cuid())
  caseId   String
  key      String
  oldValue Json?
  newValue Json?
  kind     String // "fact" or "flag"
  meta     Json? // runId, ruleId, source, eventId

  createdAt DateTime @default(now())

  @@index([caseId])
  @@index([key])
  @@index([kind])
  @@index([createdAt])
