// Portal Mesajları (Müvekkil-Büro arası mesajlaşma)
model PortalMessage {
  id            String   @id @default(cuid())
  clientId      String
  tenantId      String
  caseId        String?  // İlgili dosya (opsiyonel)
  
  // Mesaj İçeriği
  content       String
  
  // Gönderen
  senderType    String   // CLIENT veya OFFICE
  senderId      String   // ClientPortalUser ID veya User ID
  senderName    String
  
  // Okunma Durumu
  isRead        Boolean  @default(false)
  readAt        DateTime?
  
  createdAt     DateTime @default(now())

  @@index([clientId])
  @@index([tenantId])
  @@index([caseId])
  @@index([createdAt])
