  SATIS_ILANI // Satış İlanı
  REDDIYAT // Reddiyat Yazısı
  MTS_DONUS // MTS Geri Dönüş Yazısı
  ITIRAZ // İtiraz Dilekçesi
  DIGER // Diğer
}

// ==================== UYAP ENTEGRASYON LOGLARI ====================

model UyapRequestLog {
  id          String   @id @default(cuid())
  caseId      String?
  requestType String // sendPaymentOrder, checkTebligat vs.
  requestData Json? // Gönderilen veri
  requestAt   DateTime @default(now())

  // Yanıt
  responseData Json?
  responseAt   DateTime?

  // Durum
  status       UyapRequestStatus @default(PENDING)
  errorMessage String?
  retryCount   Int               @default(0)

  // Referanslar
  evkNo       String? // Evrak kayıt numarası
  uyapDosyaId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([requestType])
}

enum UyapRequestStatus {
  PENDING
  SENT
  SUCCESS
  FAILED
  RETRY
}

// ==================== FORM METADATA ====================

model FormType {
  id                String        @id @default(cuid())
  code              String        @unique
  name              String
  title             String
  description       String?
  category          FormCategory
  procedureType     ProcedureType
  uyapCode          String?
  iikMaddesi        String?
  usageScenario     String?
  exampleCase       String?
  hasJudgment       Boolean       @default(false)
  needsMortgage     Boolean       @default(false)
  isKambiyo         Boolean       @default(false)
  isRental          Boolean       @default(false)
  requiredDocuments Json?
  defaultWorkflow   String?
  sortOrder         Int           @default(0)
  isActive          Boolean       @default(true)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  subForms FormSubType[]
  cases    Case[]        @relation("CaseFormType")

  @@index([category])
  @@index([isActive])
}

model FormSubType {
  id            String   @id @default(cuid())
  formTypeId    String
  formType      FormType @relation(fields: [formTypeId], references: [id], onDelete: Cascade)
  code          String   @unique
  name          String
  title         String
  uyapCode      String?
  usageScenario String?
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([formTypeId])
}

