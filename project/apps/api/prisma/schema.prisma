// Engine Run - Kural çalıştırma kaydı
model IcrabotEngineRun {
  id             String  @id @default(cuid())
  caseId         String
  ruleId         String
  triggerEventId String?
  snapshotHash   String // SHA-256 hash of facts+flags+event

  status         String @default("started") // started, succeeded, failed
  computeSummary Json? // Compute outputs
  error          Json? // Error details if failed

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  // Relations
  timelineEntries IcrabotTimelineEntry[]
  outboxActions   IcrabotOutboxAction[]

  @@index([caseId])
  @@index([ruleId])
  @@index([status])
  @@index([startedAt])
}

// Timeline Entry - Olay kaydı
model IcrabotTimelineEntry {
  id     String  @id @default(cuid())
  caseId String
  /// Faz 1: nullable (backfill bekliyor). Faz 4'te NOT NULL — bkz legal-kernel/15-timeline-tenant-isolation-migration.md
  tenantId String?
  runId  String?

  type     String // UYAP_EVENT, FACT_WRITE, COMPUTE, DECISION, ACTION, OUTCOME, NOTE
  severity String @default("info") // info, warn, critical
  title    String
  body     Json?
  source   String @default("system") // uyap, engine, user, system

  /// HR-11: Per-case monotonic, gap-free ordering. DB trigger enforces gap-free on INSERT.
  aggregateVersion BigInt

  createdAt DateTime @default(now())

  run IcrabotEngineRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@unique([caseId, aggregateVersion])
  @@index([tenantId, caseId])
  @@index([caseId])
  @@index([runId])
  @@index([type])
  @@index([severity])
  @@index([createdAt])
}

// Outbox Action - Action queue
model IcrabotOutboxAction {
  id     String  @id @default(cuid())
  caseId String
  /// outbox-tenancy: write-time tenant capture. Adım A tip+runtime guard, Adım B DB NOT NULL.
  /// Üreticiler enqueue anında tenantId yazmak zorunda; tüketiciler satırdan thread eder.
  /// External callback path'i (processCallback) caseId→tenant boundary lookup yapar.
  tenantId String
  runId    String?

  actionType     String // open_lock, enqueue, send_email, send_sms, uyap_submit, etc.
  idempotencyKey String @unique
  payload        Json

  status       String    @default("pending") // pending, sent, done, failed, dead
  attemptCount Int       @default(0)
  lastError    Json?
  nextRetryAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  run IcrabotEngineRun? @relation(fields: [runId], references: [id], onDelete: SetNull)

  @@index([tenantId, caseId])
  @@index([caseId])
  @@index([runId])
  @@index([actionType])
  @@index([status])
  @@index([nextRetryAt])
  @@index([createdAt])
}

// Rule Pack - Kural paketi
model IcrabotRulePack {
