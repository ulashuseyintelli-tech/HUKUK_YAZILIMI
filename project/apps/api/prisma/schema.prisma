  @@index([courtName])
  @@index([decisionDate])
}

enum NafakaType {
  ISTIRAK         // İştirak nafakası (çocuk)
  YOKSULLUK       // Yoksulluk nafakası
  TEDBIR          // Tedbir nafakası
  YARDIM          // Yardım nafakası
}

// ==================== REHİN/İPOTEK ====================

// Rehin veya ipotek bilgileri - Rehinli takipler için
model CaseCollateral {
