// ==================== EVIDENCE BUNDLE STORAGE (Phase 9C) ====================

// Bundle State Machine
// CRITICAL INVARIANT: SEALED is TERMINAL - no transitions out of SEALED
enum BundleState {
  DRAFT     // Items being uploaded, manifest not yet written
  SEALED    // Manifest written, bundle is immutable (TERMINAL STATE)
  FAILED    // Seal failed after retries, needs investigation
  ORPHANED  // S3 objects exist but DB pointer missing (reconciliation detected)
}

// Evidence Bundle Pointer - links snapshot to S3 bundle
// Phase 9C - Object Storage Migration
// 
// INVARIANTS:
// 1. snapshotId is UNIQUE - one bundle per snapshot
// 2. SEALED state is TERMINAL - no transitions out
// 3. FAILED → DRAFT only via retry policy with sealAttemptCount++
// 4. manifestKey is write-once (same key = same content)
model EvidenceBundlePointer {
  id                  String      @id @default(cuid())
  
  // Foreign key to snapshot (1:1)
  snapshotId          String      @unique @map("snapshot_id")
  
  // Tenant isolation
  tenantId            String      @map("tenant_id")
  incidentId          String      @map("incident_id")
  
  // S3 location
  bucket              String
  manifestKey         String      @map("manifest_key")
  
  // Integrity - hash chain
  manifestSha256      String      @map("manifest_sha256")
  bundleContentHash   String      @map("bundle_content_hash") // SHA256(concat all item sha256s)
  
  // S3 metadata (write-once verification)
  etag                String?
  versionId           String?     @map("version_id")
  
  // Size tracking
  totalSizeBytes      BigInt      @map("total_size_bytes")
  itemCount           Int         @map("item_count")
  
  // State machine
  state               BundleState @default(DRAFT)
  
  // Forensic/debug fields (REQUIRED for production debugging)
  sealAttemptCount    Int         @default(0) @map("seal_attempt_count")
  lastSealAttemptAt   DateTime?   @map("last_seal_attempt_at") @db.Timestamptz(6)
  lastErrorCode       String?     @map("last_error_code")
  lastErrorDetail     String?     @map("last_error_detail")
  
  // Timestamps
  createdAt           DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  sealedAt            DateTime?   @map("sealed_at") @db.Timestamptz(6)
  
  // Indexes for common queries
  @@index([tenantId], map: "ix_bundle_ptr_tenant")
  @@index([manifestSha256], map: "ix_bundle_ptr_manifest_hash")
  @@index([state, createdAt], map: "ix_bundle_ptr_state_created") // Reconciliation query
  @@index([tenantId, incidentId], map: "ix_bundle_ptr_tenant_incident")
  @@map("evidence_bundle_pointers")
}


// ==================== EVIDENCE BUNDLE SYSTEM (Phase 9C Task 2) ====================
// Legal-grade evidence bundle for incident audit trail
// 
// ARCHITECTURE:
// - EvidenceBundle: Logical container for evidence objects (OPEN -> SEALED state machine)
// - EvidenceObject: Metadata for S3/MinIO objects (immutable once bundle is SEALED)
// - BundleSealEvent: Audit log for seal operations (idempotent by bundle_id + run_id)
//
// DB INVARIANTS (enforced by triggers in migration.sql):
// 1. SEALED bundle cannot accept new objects (write-once semantics)
// 2. Only one OPEN bundle per tenant+incident (partial unique index)
// 3. tenant_id in EvidenceObject must match bundle's tenant_id
// 4. BundleSealEvent can only be created for SEALED bundles
//
// ERROR CODES (for application layer mapping):
// - 45000: sealed_bundle_write_forbidden -> 409 WriteOnceViolation
// - 45001: tenant_mismatch -> 403 TenantMismatchError
// - 45002: seal_event_requires_sealed_bundle -> 409 InvalidStateTransition
// - 23503: bundle_not_found -> 404 BundleNotFoundError

// Bundle State (OPEN -> SEALED is one-way, no rollback)
enum EvidenceBundleState {
  OPEN    // Accepting new objects
  SEALED  // Immutable, no new objects allowed (TERMINAL)
}

// Evidence Bundle - Logical container for evidence objects
model EvidenceBundle {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @map("bundle_id") @db.Uuid
  tenantId    String              @map("tenant_id") @db.VarChar(64)
  incidentId  String              @map("incident_id") @db.VarChar(128)
  state       EvidenceBundleState @default(OPEN)
  sealedHash  String?             @map("sealed_hash") @db.VarChar(128)
  createdAt   DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  sealedAt    DateTime?           @map("sealed_at") @db.Timestamptz(6)

  // Relations
  objects    EvidenceObject[]
  sealEvents BundleSealEvent[]

  // Indexes defined in migration.sql:
  // - idx_evidence_bundles_one_open: UNIQUE(tenant_id, incident_id) WHERE state = 'OPEN'
  // - idx_evidence_bundles_tenant_incident: (tenant_id, incident_id)
  // - idx_evidence_bundles_state: (state)

  @@index([tenantId, incidentId], map: "idx_evidence_bundles_tenant_incident")
  @@index([state], map: "idx_evidence_bundles_state")
  @@map("evidence_bundles")
}

// Evidence Object - Metadata for S3/MinIO objects
model EvidenceObject {
  bundleId    String   @map("bundle_id") @db.Uuid
  objectKey   String   @map("object_key") @db.VarChar(512)
  tenantId    String   @map("tenant_id") @db.VarChar(64)
  etag        String   @db.VarChar(64)
  versionId   String?  @map("version_id") @db.VarChar(128)
  contentType String   @map("content_type") @db.VarChar(128)
  sizeBytes   BigInt   @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  bundle EvidenceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  // Composite PK
  @@id([bundleId, objectKey], map: "evidence_objects_pk")
  @@index([tenantId, createdAt], map: "idx_evidence_objects_tenant_created")
  @@index([bundleId], map: "idx_evidence_objects_bundle")
  @@map("evidence_objects")
}

// Bundle Seal Event - Audit log for seal operations
model BundleSealEvent {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bundleId       String   @map("bundle_id") @db.Uuid
  runId          String   @map("run_id") @db.VarChar(128)
  hash           String   @db.VarChar(128)
  objectCount    Int      @map("object_count")
  totalSizeBytes BigInt   @map("total_size_bytes")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  bundle EvidenceBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  // Idempotency constraint
  @@unique([bundleId, runId], map: "bundle_seal_events_idempotency_uniq")
  @@index([bundleId, createdAt], map: "idx_bundle_seal_events_bundle_created")
  @@map("bundle_seal_events")
}


// ==================== PHASE 10.2: MANIFEST ADMIN AUDIT LOG ====================
// Audit trail for manifest retry admin operations
// Retention: 90 days hot (PostgreSQL), then archive to S3
// PII Protection: IP addresses are hashed (SHA-256) for KVKK compliance

// Audit Event Type
enum ManifestAdminAuditEventType {
  DLQ_RESOLVE
  DLQ_REDRIVE
  DLQ_REDRIVE_BULK
  JOB_FORCE_RETRY
  CB_OVERRIDE
}

// Audit Resource Type
enum ManifestAdminAuditResourceType {
  dlq_entry
  retry_job
  circuit_breaker
}

// Manifest Admin Audit Log - Immutable audit trail for admin operations
model ManifestAdminAuditLog {
  id              String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  
  // Event identification
  eventType       ManifestAdminAuditEventType     @map("event_type")
  
  // Actor information
  actor           String                          @db.VarChar(256)
  requestId       String                          @unique @map("request_id") @db.VarChar(256) // Idempotency key
  ipHash          String                          @map("ip_hash") @db.VarChar(64) // SHA-256 hash of IP
  userAgent       String                          @map("user_agent") @db.Text
  
  // Resource information
  resourceType    ManifestAdminAuditResourceType  @map("resource_type")
  resourceId      String                          @map("resource_id") @db.VarChar(256)
  targetBundleId  String                          @map("target_bundle_id") @db.VarChar(256)
  
  // State tracking
  beforeState     Json?                           @map("before_state")
  afterState      Json?                           @map("after_state")
  
  // Reason/notes
  reason          String?                         @db.Text
  
  // Timestamp
  createdAt       DateTime                        @default(now()) @map("created_at") @db.Timestamptz(6)

  // Indexes for common queries
  @@index([createdAt(sort: Desc)], map: "idx_audit_log_created_at")
  @@index([actor, createdAt(sort: Desc)], map: "idx_audit_log_actor")
  @@index([targetBundleId, createdAt(sort: Desc)], map: "idx_audit_log_bundle")
  @@index([eventType, createdAt(sort: Desc)], map: "idx_audit_log_event_type")
  @@index([resourceType, resourceId], map: "idx_audit_log_resource")
  @@map("manifest_admin_audit_log")
}

// ==================== PHASE 10.2: MANIFEST WORKER STATE ====================
// Singleton table for worker safety controls
// Design: Single row with owner/lease for multi-instance safety
// Approved: 2026-02-03 by User

// Pause Reason Enum - Forward-compatible with UNKNOWN
enum ManifestWorkerPauseReason {
  CONSECUTIVE_ERRORS  // Auto-resume after cooloff (default 5 min)
  MANUAL_PAUSE        // Never auto-resume, requires manual resume
  UNKNOWN             // Forward-compatible placeholder
}

// Manifest Worker State - Singleton table (id='singleton')
model ManifestWorkerState {
  // Singleton constraint: only 'singleton' allowed
  id                  String                        @id @default("singleton")
  
  // Pause state
  isPaused            Boolean                       @default(false) @map("is_paused")
  pauseReason         ManifestWorkerPauseReason?    @map("pause_reason")
  pausedAt            DateTime?                     @map("paused_at") @db.Timestamptz(6)
  pausedBy            String?                       @map("paused_by")  // Actor for MANUAL_PAUSE
  
  // Error tracking
  consecutiveErrors   Int                           @default(0) @map("consecutive_errors")
  lastErrorCode       String?                       @map("last_error_code")
  lastErrorAt         DateTime?                     @map("last_error_at") @db.Timestamptz(6)
  
  // Leader election (multi-instance safety)
  ownerInstanceId     String?                       @map("owner_instance_id")
  leaseExpiresAt      DateTime?                     @map("lease_expires_at") @db.Timestamptz(6)
  
  // Timestamps
  createdAt           DateTime                      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime                      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Indexes
  @@index([ownerInstanceId, leaseExpiresAt], map: "idx_worker_state_lease")
  @@map("manifest_worker_state")
}


// ==================== SPRINT 3: PROMOTE & ESCALATION STATE ====================

// Promote Request Status
enum PromoteRequestStatus {
  IN_PROGRESS
  SUCCEEDED
  FAILED
}

// Promote Request - Idempotency store for promote pipeline
// UNIQUE(incident_id, run_id) — DB-level race condition prevention
// Pattern: INSERT → catch unique violation → SELECT (not TOCTOU)
model PromoteRequest {
  id              String                @id @default(cuid())
  incidentId      String                @map("incident_id")
  runId           String                @map("run_id")
  requestId       String                @map("request_id")
  status          PromoteRequestStatus  @default(IN_PROGRESS) @map("status")
  resultRef       String?               @map("result_ref")

  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([incidentId, runId], map: "promote_request_incident_run_unique")
  @@index([createdAt], map: "promote_request_created_at_idx")
  @@map("promote_request")
}

// Escalation Level
enum EscalationLevelEnum {
  NONE
  L1
  L2
  L3
}

// Escalation State - DB-backed hysteresis state machine
// CAS via version column: UPDATE ... SET version = version + 1 WHERE version = $current
// Max 2 retry on CAS conflict, then 409 ESCALATION_STATE_CONFLICT
model EscalationStateRecord {
  incidentId            String              @id @map("incident_id")
  currentLevel          EscalationLevelEnum @default(NONE) @map("current_level")
  lastTransitionAt      DateTime            @default(now()) @map("last_transition_at") @db.Timestamptz(6)
  holdDownUntil         DateTime?           @map("hold_down_until") @db.Timestamptz(6)
  stableWindowCounter   Int                 @default(0) @map("stable_window_counter")
  stableWindowStartedAt DateTime?           @map("stable_window_started_at") @db.Timestamptz(6)
  version               Int                 @default(1) @map("version")

  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("escalation_state")
}
