// ==================== INTEREST ENGINE MODULE ====================

// Faiz Türü Kodu (Interest Engine için)
enum InterestTypeCode {
  LEGAL_3095 // Yasal faiz - 3095 sayılı Kanun
  COMMERCIAL_AVANS_3095_2_2 // Ticari temerrüt/avans faizi
  TTK_1530 // Geç ödeme faizi - TTK 1530
  CONTRACTUAL // Sözleşmesel faiz
  MEVDUAT_TL_BANKALARCA // Bankalarca TL mevduat faizi
  MEVDUAT_USD_BANKALARCA // Bankalarca USD mevduat faizi
  MEVDUAT_EUR_BANKALARCA // Bankalarca EUR mevduat faizi
  MEVDUAT_TL_KAMU // Kamu bankası TL mevduat faizi
  MEVDUAT_USD_KAMU // Kamu bankası USD mevduat faizi
  MEVDUAT_EUR_KAMU // Kamu bankası EUR mevduat faizi
  COMMERCIAL_FIXED // Ticari sabit oran (E5: TS InterestTypeCode ile parity; SABIT→COMMERCIAL_FIXED)
}

// Oran Kaynağı
enum RateSource {
  TCMB // T.C. Merkez Bankası
  RESMI_GAZETE // Resmi Gazete
  CONTRACT // Sözleşme
}

// Faiz Oranı Çizelgesi
model RateSchedule {
  id           String    @id @default(cuid())
  tenantId     String
  interestType String // InterestTypeCode enum değeri
  validFrom    DateTime
  validTo      DateTime? // null = güncel oran
  annualRate   Decimal   @db.Decimal(10, 6) // örn: 0.397500 = %39.75
  source       String // RateSource enum değeri
  sourceRef    String? // "TCMB 20.12.2025", "Resmi Gazete 32123"
  versionHash  String // SHA256 hash (değişiklik tespiti için)
  createdAt    DateTime  @default(now())
  createdBy    String?

  tenant Office @relation(fields: [tenantId], references: [id])

  @@index([tenantId, interestType, validFrom])
  @@index([tenantId, interestType, validTo])
  @@map("rate_schedule")
}

// Faiz Hesaplama Logu
model InterestCalculationLog {
  id               String   @id @default(cuid())
  tenantId         String
  caseId           String
  calculatedAt     DateTime @default(now())
  asOfDate         DateTime
  requestJson      Json // Tam istek (audit için)
  resultJson       Json // Tam sonuç (audit için)
  totalInterest    Decimal  @db.Decimal(18, 2)
  totalDue         Decimal  @db.Decimal(18, 2)
  rateHashes       String[] // Kullanılan oranların version hash'leri
  flaggedForReview Boolean  @default(false)
  reviewReason     String?
  createdBy        String?

  tenant   Office               @relation(fields: [tenantId], references: [id])
  case     Case                 @relation(fields: [caseId], references: [id], onDelete: Cascade)
  segments InterestSegmentLog[]

  @@index([tenantId, caseId])
  @@index([tenantId, calculatedAt])
  @@index([tenantId, flaggedForReview])
  @@map("interest_calculation_log")
}

// Faiz Segment Logu
model InterestSegmentLog {
  id               String   @id @default(cuid())
  calculationLogId String
  principalItemId  String
  periodStart      DateTime
  periodEnd        DateTime
  days             Int
  rate             Decimal  @db.Decimal(10, 6)
  rateId           String
  principal        Decimal  @db.Decimal(18, 2)
  segmentInterest  Decimal  @db.Decimal(18, 2)

  calculationLog InterestCalculationLog @relation(fields: [calculationLogId], references: [id], onDelete: Cascade)

  @@index([calculationLogId])
  @@map("interest_segment_log")
}


// ==================== ADDRESS TASK SYSTEM ====================
// Borçlu adres yönetimi görev sistemi

// Adres Görevi Türü
enum AddressTaskType {
  DOC_EXTRACT_DEBTOR_ADDRESSES // Evraktan adres çıkarma
  CLIENT_CONTACT_VALIDATE // Müvekkil iletişim doğrulama
  CLIENT_REQUEST_DEBTOR_ADDRESSES // Müvekkile adres talebi
  CLIENT_REMIND_DEBTOR_ADDRESSES // Hatırlatma
  CLIENT_ANNUAL_ADDRESS_REFRESH // Yıllık tekrar
  ASSIGN_MANUAL_CALL_CLIENT // Manuel arama görevi
  MANUAL_CLIENT_FOLLOWUP // Manuel takip görevi
  UYAP_PULL_MERNIS // MERNİS sorgusu (sonraki faz)
  UYAP_PULL_SGK // SGK sorgusu (sonraki faz)
}

// Adres Görevi Sonuç Türü
enum AddressTaskResultType {
  POSITIVE // Olumlu cevap (adres geldi)
  NEGATIVE // Olumsuz cevap (adres yok)
  NO_RESPONSE // Cevap gelmedi
  PARTIAL // Kısmi cevap
}

// Adres Görevi İptal Nedeni
enum AddressTaskCancellationReason {
  CASE_CLOSED // Dosya kapandı
  MANUAL_CANCEL // Manuel iptal
  DUPLICATE_TASK // Tekrar görev
  SUPERSEDED // Başka görev tarafından geçersiz kılındı
}

// Adres Görevi Hata Nedeni
enum AddressTaskFailureReason {
  UYAP_UNAVAILABLE // UYAP erişilemez
  NO_CONTACT_INFO // İletişim bilgisi yok
  CLIENT_NO_RESPONSE // Müvekkil cevap vermedi
  EMAIL_BOUNCE // Email geri döndü
  WHATSAPP_UNDELIVERED // WhatsApp iletilemedi
  INVALID_ADDRESS // Geçersiz adres
  SYSTEM_ERROR // Sistem hatası
  SLA_EXCEEDED // SLA aşıldı
}

// Manuel Görev Kapatma Nedeni
enum ManualTaskResolution {
  CLIENT_RESPONDED // Müvekkil cevapladı
  CONTACT_UPDATED // İletişim bilgisi güncellendi
  ADDRESS_UPDATED // Adres manuel güncellendi
  NO_ADDRESS_AVAILABLE // Müvekkil adres bilmiyor
  CLIENT_UNREACHABLE // Müvekkile ulaşılamıyor
  OTHER // Diğer
}

// Adres Kategorisi (Genişletilmiş)
enum AddressCategory {
  DECLARED_DOCUMENT // Borç evrakından
  DECLARED_CLIENT // Müvekkilden
  MERNIS_RESIDENCE // MERNİS yerleşim yeri
  SGK_ADDRESS // SGK adresi
  TICARET_SICIL // Ticaret Sicili
  VERGI_DAIRESI // Vergi Dairesi
  GSM_OPERATOR // GSM operatörü
}

// Adres Kaynak Detayı
enum AddressSourceDetail {
  DOCUMENT_SCAN // OCR/AI tarama
  MANUAL_ENTRY // Manuel giriş
  CLIENT_REPLY_EMAIL // Müvekkil email cevabı
  CLIENT_REPLY_WHATSAPP // Müvekkil WhatsApp cevabı
  UYAP_MERNIS // UYAP MERNİS sorgusu
  UYAP_SGK // UYAP SGK sorgusu
  UYAP_TICARET // UYAP Ticaret Odası sorgusu
  INSTITUTION_LETTER // Kurum yazısı
}

// Güven Seviyesi
enum ConfidenceLevel {
  LOW // Düşük güven (40 puan)
  MEDIUM // Orta güven (60 puan)
  HIGH // Yüksek güven (80+ puan)
}

// Kanıt Türü
enum EvidenceType {
  DOCUMENT // Belge
  COMMUNICATION // İletişim (email/whatsapp)
  UYAP_QUERY // UYAP sorgusu
}

// Adres Görevi Modeli
model AddressTask {
  id       String @id @default(cuid())
  tenantId String
  caseId   String
  debtorId String

  // Task Type & Dedupe
  taskType AddressTaskType
  scopeKey String? // Scope identifier for dedupe (e.g., "annual_2024")
  dedupeKey String? // Computed: {taskType}:{caseId}:{debtorId}:{scopeKey}

  // Status & SLA
  status AddressTaskStatus @default(PENDING)
  dueAt DateTime?
  attemptCount Int @default(0)
  maxAttempts Int @default(3)

  // Assignment
  assignedToId String?

  // Communication
  channelUsed String? // EMAIL, WHATSAPP, BOTH
