// ==================== BANKA ENTEGRASYONU ====================

model BankAccount {
  id       String @id @default(cuid())
  tenantId String

  // Hesap Bilgileri
  bankCode    String // Banka kodu (0001, 0010, vb.)
  bankName    String // Banka adı
  branchCode  String? // Şube kodu
  branchName  String? // Şube adı
  accountNo   String? // Hesap numarası
  iban        String // IBAN
  currency    String  @default("TRY")
  accountType String  @default("VADESIZ") // VADESIZ, VADELI, YATIRIM

  // Sahip Bilgileri
  ownerType String // TENANT, CLIENT
  ownerId   String? // Client ID (müvekkil hesabıysa)
  ownerName String

  // Entegrasyon
  isIntegrated        Boolean   @default(false)
  integrationProvider String? // garanti, akbank, isbank, vb.
  lastSyncAt          DateTime?

  // Durum
  isActive  Boolean @default(true)
  isPrimary Boolean @default(false)

  // Meta
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  transactions BankTransaction[]

  @@unique([tenantId, iban])
  @@index([tenantId])
  @@index([ownerType, ownerId])
  @@index([isActive])
}

model BankTransaction {
  id            String @id @default(cuid())
  tenantId      String
  bankAccountId String

  // İşlem Bilgileri
  transactionDate DateTime
  valueDate       DateTime?
  amount          Decimal   @db.Decimal(18, 2)
  currency        String    @default("TRY")
  transactionType String // INCOMING, OUTGOING

  // Karşı Taraf
  counterpartyName String?
  counterpartyIban String?
  counterpartyBank String?

  // Açıklama
  description String?
  referenceNo String?

  // Eşleştirme
  isMatched           Boolean   @default(false)
  matchedCaseId       String?
  matchedCollectionId String?
  matchedAt           DateTime?
  matchedById         String?

  // Banka Verisi
  bankReferenceId String? // Bankanın verdiği referans
  rawData         Json? // Ham banka verisi

  // Meta
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isMatched])
  @@index([matchedCaseId])
}

model BankIntegrationLog {
  id            String  @id @default(cuid())
  tenantId      String
  bankAccountId String?

  // İşlem Bilgileri
  action   String // SYNC, TRANSFER, BALANCE_CHECK
  provider String // garanti, akbank, isbank, vb.

  // Sonuç
  status           String  @default("PENDING") // PENDING, SUCCESS, FAILED
  transactionCount Int?
  errorCode        String?
  errorMessage     String?

  // Veri
  requestData  Json?
  responseData Json?

  // Tarihler
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([status])
  @@index([startedAt])
}

// ==================== İHTİYATİ HACİZ MODÜLÜ ====================

// İhtiyati Haciz Kararı Durumu
enum PrecautionaryOrderStatus {
  DRAFT // Taslak (henüz karar alınmadı)
  DECIDED // Karar alındı
  APPLIED // Uygulandı
  LIFTED // Kaldırıldı
  EXPIRED // Süresi doldu
  REJECTED // Reddedildi
}

// Teminat Türü
enum SecurityDepositType {
  NAKIT // Nakit teminat
  TEMINAT_MEKTUBU // Banka teminat mektubu
  GAYRIMENKUL // Gayrimenkul ipoteği
  KEFALET // Kefalet
  DIGER // Diğer
}

// İhtiyati Haciz Kararı
model PrecautionaryOrder {
  id       String @id @default(cuid())
  tenantId String
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Karar Türü
  orderType String @default("IHTIYATI_HACIZ") // IHTIYATI_HACIZ, IHTIYATI_TEDBIR

  // Mahkeme Bilgileri
  courtName    String // Mahkeme adı
  courtCity    String? // Mahkeme ili
  decisionDate DateTime // Karar tarihi
  decisionNo   String? // Esas/Karar numarası

  // Kapsam
  scopeNote        String? // Hangi alacak/borçlular için
  coveredDebtorIds String[] // Kapsanan borçlu ID'leri

  // Teminatlı Tutar
  securedAmount Decimal @db.Decimal(15, 2)
  currency      String  @default("TRY")

  // Teminat Bilgileri
  requiresSecurityDeposit Boolean              @default(false)
  securityDepositAmount   Decimal?             @db.Decimal(15, 2)
  securityDepositType     SecurityDepositType?
  securityDepositNote     String? // Teminat açıklaması
  securityDepositPaidAt   DateTime? // Teminat yatırma tarihi

  // Durum
  status     PrecautionaryOrderStatus @default(DRAFT)
  appliedAt  DateTime? // Uygulanma tarihi
  liftedAt   DateTime? // Kaldırılma tarihi
  liftReason String? // Kaldırılma nedeni
  expiresAt  DateTime? // Son geçerlilik tarihi

  // Belgeler
  decisionDocumentId String? // Karar belgesi (CaseDocument referansı)

  // Meta
  notes       String?
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // İlişkiler
  costs PrecautionaryCost[]

