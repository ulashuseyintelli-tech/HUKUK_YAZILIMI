  @@index([city])
  @@index([uyapCode])
}

// ==================== BÜRO BİLGİLERİ ====================

model Office {
  id       String @id @default(cuid())
  tenantId String @unique // Her tenant'ın tek bir ofisi var
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Temel Bilgiler
  name String // Hukuk Bürosu adı

  // Adres
  address    String?
  city       String?
  district   String?
  postalCode String?

  // İletişim
  phone   String?
  fax     String?
  email   String?
  website String?

  // Baro Bilgisi
  barAssociation String? // Bağlı olduğu baro

  // Varsayılan İcra Dairesi
  defaultExecutionOfficeId String?

  // SMTP Ayarları (E-posta Gönderimi)
  smtpHost      String? // smtp.gmail.com, smtp.yandex.com, vb.
  smtpPort      Int? // 587, 465, vb.
  smtpUser      String? // E-posta adresi
  smtpPass      String? // Uygulama şifresi (şifrelenmiş)
  smtpSecure    Boolean @default(false) // TLS/SSL
  smtpFromName  String? // Gönderen adı
  smtpFromEmail String? // Gönderen e-posta

  // SMS Ayarları (Opsiyonel)
  smsProvider  String? // NETGSM, ILETI_MERKEZI, vb.
  smsApiKey    String?
  smsApiSecret String?
  smsSender    String? // Gönderen adı

  // Otomatik Tebrik Ayarları
  autoGreetingEnabled Boolean   @default(true) // Otomatik tebrik sistemi açık/kapalı
  autoGreetingTime    String?   @default("09:00") // Tebrik gönderim saati (HH:mm)
  lastGreetingRunAt   DateTime? // Otomatik tebrik scheduler'ının o tenant için en son BAŞARIYLA çalıştığı an (aynı-gün tekrar gönderim guard'ı)

  // İİK 78 Ayarları
  inactivityThresholdDays Int @default(365) // Pasifleşme süresi (gün) - İİK 78
  inactivityWarningDays   Int @default(60) // Uyarı süresi (gün) - kalan gün bu değerin altına düşünce uyarı

  // Görev & Eskalasyon Ayarları (büro-geneli politika) — PR-3a config; motor PR-3b okur.
  // manager/founder = Lawyer id DİZİSİ (düz alan; FK relation değil; motor id ile çözer, yoksa skip+log).
  // Birden fazla yönetici/kurucu olabilir → hepsine bildirim gider.
  escalationManagerLawyerIds String[] @default([]) // Yönetici avukat(lar) (3g aşımında bildirim)
  escalationFounderLawyerIds String[] @default([]) // Kurucu/ortak avukat(lar) (6g aşımında bildirim)
  opReminderDays Int     @default(3)  // İlk hatırlatma / yöneticiye eskalasyon (gün)
  opFounderDays  Int     @default(6)  // Kurucu/ortağa eskalasyon (gün)
  opRepeatMonths Int     @default(3)  // Periyodik tekrar (ay)
  opEmailEnabled Boolean @default(true) // E-posta bildirimi açık mı
  opSmsEnabled   Boolean @default(true) // SMS bildirimi açık mı (yalnız kurucu/6g kademesi)
  // Operasyonel görevin İLK SAHİBİ (L1): bu personel türleri görür/bildirim alır. Yeni StaffRole
  // enum'u YOK — mevcut StaffType kullanılır.
  opStaffTypes StaffType[] @default([MUHASEBE, ADLI_KATIP, SEKRETER])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // İlişkiler
  bankAccounts    OfficeBankAccount[]
  lawyers         Lawyer[]
  lawyerTemplates LawyerTemplate[]

  // Interest Engine
  rateSchedules           RateSchedule[]
  interestCalculationLogs InterestCalculationLog[]

  @@index([tenantId])
}

model OfficeBankAccount {
