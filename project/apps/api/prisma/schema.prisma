// Immutable Audit Log with Hash Chain (v38)
model IcrabotAuditLog {
  id       String  @id @default(cuid())
  tenantId String
  caseId   String?
  userId   String

  action  String // e.g., JOB_STARTED, APPROVAL_GRANTED, PII_ACCESSED
  payload Json // Full event payload

  // Hash chain for immutability
  prevHash  String // Previous event hash (genesis: 64 zeros)
  eventHash String // SHA-256(prevHash + payload + createdAt)

  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  case   Case?  @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([caseId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
