generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== LOOKUP TABLOLARI ====================

model LookupTakipTuru {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   // ILAMSIZ_GENEL, ILAMLI, NAFAKA, vb.
  name        String   // İlamsız Genel Haciz
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  
  // Varsayılan değerler (otomatik doldurma için)
  defaultMahiyetTipiId  String?  // Takip türüne göre varsayılan mahiyet tipi
  defaultBorcluTipiId   String?  // Takip türüne göre varsayılan borçlu tipi
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       Case[]   @relation("CaseTakipTuru")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

model LookupAsama {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   // DOSYA_ACILDI, TEBLIG, HACIZ_TALEP, vb.
  name        String   // Dosya Açıldı
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       Case[]   @relation("CaseAsama")
  stageHistory CaseStageHistory[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

model LookupRisk {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   // DUSUK, ORTA, YUKSEK
  name        String   // Düşük
  description String?
  color       String?  // #22c55e (yeşil), #eab308 (sarı), #ef4444 (kırmızı)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       Case[]   @relation("CaseRisk")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

model LookupBorcluTipi {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   // GERCEK_KISI, TUZEL_KISI, KAMU
  name        String   // Gerçek Kişi
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       Case[]   @relation("CaseBorcluTipi")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

model LookupDurumEtiketi {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   // MASRAF_BEKLIYOR, ADRES_ARASTIRMA, vb.
  name        String   // Masraf Bekliyor
  description String?
  color       String?  // Badge rengi
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       Case[]   @relation("CaseDurumEtiketi")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

// Mahiyet Tipi (Alacak Türü) - Büro içi sınıflandırma + UYAP uyumu
model LookupMahiyetTipi {
  id           String   @id @default(cuid())
  tenantId     String
  code         String   // PARA, KIRA, AIDAT, KREDI, NAFAKA, vb. (internal_code)
  name         String   // Genel Para Alacağı, Kira Alacağı, vb.
  uyapCode     String?  // UYAP iş/takip kodu eşleştirmesi (opsiyonel)
  description  String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cases        Case[]   @relation("CaseMahiyetTipi")

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([isActive])
}

// ==================== ESNEK GRUPLAMA SİSTEMİ ====================

model GroupDefinition {
  id          String   @id @default(cuid())
  tenantId    String
  name        String   // Aksu Grup Portföyü, Stratejik Dosyalar, vb.
  description String?
  isGlobal    Boolean  @default(true)  // true: tüm büro, false: müvekkile özel
  clientId    String?  // Müvekkile bağlı grup için
  color       String?  // UI renk kodu (#3b82f6)
  createdById String?  // Oluşturan kullanıcı
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  caseGroups  CaseGroup[]

  @@index([tenantId])
  @@index([clientId])
  @@index([isActive])
}

model CaseGroup {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  groupId     String
  group       GroupDefinition @relation(fields: [groupId], references: [id], onDelete: Cascade)
  assignedById String?  // Atayan kullanıcı
  assignedAt  DateTime @default(now())

  @@unique([caseId, groupId])
  @@index([caseId])
  @@index([groupId])
}

// Aşama Tarihçesi (PART 10 - SLA takibi için)
model CaseStageHistory {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation("CaseStageHistory", fields: [caseId], references: [id], onDelete: Cascade)
  asamaId     String
  asama       LookupAsama @relation(fields: [asamaId], references: [id])
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  changedById String?  // Değiştiren kullanıcı
  notes       String?

  @@index([caseId])
  @@index([asamaId])
  @@index([startedAt])
}

// ==================== TENANT & AUTH ====================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  settings  Json?
  
  // Hesap tipi (profesyonel vs vatandaş)
  accountType AccountType @default(PROFESSIONAL)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  cases              Case[]
  debtors            Debtor[]
  clients            Client[]
  tasks              Task[]
  courts             Court[]
  collections        Collection[]
  lawyers            Lawyer[]
  workflowTemplates  WorkflowTemplate[]
  executionOffices   ExecutionOffice[]
  office             Office?  // Her tenant'ın tek bir ofisi var
  
  // Address Discovery
  clientInfoRequests  ClientInfoRequest[]
  uyapQueries         UyapQuery[]
  institutionLetters  InstitutionLetter[]
  addressResearches   AddressResearch[]
  
  // Asset Queries (FAZ 4)
  assetQueries        AssetQuery[]

  @@index([slug])
  @@index([accountType])
}

enum AccountType {
  PROFESSIONAL  // Hukuk bürosu / Avukat
  CORPORATE     // Şirket hukuk departmanı
  PUBLIC        // Kamu avukatı
  CITIZEN       // Vatandaş (avukatsız)
}

model WorkflowTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code        String
  name        String
  description String?
  formTypeCode String?
  steps       Json
  triggers    Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String
  passwordHash String
  name         String
  surname      String
  role         UserRole @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignedTasks Task[] @relation("AssignedTasks")
  createdTasks  Task[] @relation("CreatedTasks")
  statusChanges CaseStatusHistory[] @relation("StatusChangedBy")
  sorumluCases  Case[] @relation("SorumluPersonel")
  
  // Address Discovery
  uyapQueriesRequested    UyapQuery[]         @relation("UyapQueryRequester")
  institutionLettersCreated InstitutionLetter[] @relation("InstitutionLetterCreator")
  
  // Asset Queries (FAZ 4)
  assetQueriesRequested   AssetQuery[]        @relation("AssetQueryRequester")

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ==================== İCRA DAİRESİ ====================

model ExecutionOffice {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String   // İstanbul 5. İcra Dairesi
  city        String   // İstanbul
  district    String?  // Kadıköy
  officeCode  String?  // Daire kodu
  uyapCode    String?  // UYAP kodu
  taxNumber   String?  // Vergi numarası
  bankName    String?  // Banka adı
  branchName  String?  // Şube adı
  iban        String?  // Emanet IBAN
  ibanHarc    String?  // Harç IBAN
  ibanCezaevi String?  // Cezaevi IBAN
  address     String?
  phone       String?
  fax         String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  cases       Case[]

  @@index([tenantId])
  @@index([city])
  @@index([uyapCode])
}

// ==================== CORE MODELS ====================

model Client {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type         ClientType
  
  // === ORTAK ALAN ===
  displayName  String?    // Görünen ad (otomatik: Ad Soyad veya Kurum Adı)
  
  // === ŞAHIS BİLGİLERİ ===
  firstName    String?
  lastName     String?
  tckn         String?    // TC Kimlik No (11 hane)
  isForeigner  Boolean    @default(false)  // Yabancı uyruklu
  nationality  String?    // Uyruk
  gender       String?    // E, K
  birthDate    DateTime?  // Doğum Tarihi (tebrik için)
  
  // === KURUM BİLGİLERİ ===
  companyName  String?    // Kurum/Şirket Adı
  companyType  String?    // Anonim, Limited, Kamu, vb.
  vkn          String?    // Vergi Kimlik No (10 hane)
  mersisNo     String?    // MERSİS No
  detsisNo     String?    // DETSİS No (Kamu için)
  taxOffice    String?    // Vergi Dairesi
  ticaretSicilNo String?  // Ticaret Sicil No
  foundingDate DateTime?  // Kuruluş Tarihi (yıldönümü tebriği için)
  
  // === VEKALET BİLGİLERİ ===
  poaStartDate DateTime?  // Vekalet Başlangıç Tarihi (işbirliği yıldönümü için)
  
  // === TEBRİK AYARLARI ===
  sendBirthdayGreeting    Boolean @default(true)  // Doğum günü tebriği gönder
  sendAnniversaryGreeting Boolean @default(true)  // Yıldönümü tebriği gönder
  sendHolidayGreeting     Boolean @default(true)  // Bayram tebriği gönder
  greetingChannel         String? // EMAIL, SMS, BOTH - varsayılan: EMAIL
  
  // === ADRES ===
  address      String?
  city         String?
  district     String?
  postalCode   String?
  region       String?    // İcra Bölgesi (İstanbul 1. Bölge vb.)
  useMernisAddress Boolean @default(false)
  useUyapAddress   Boolean @default(false)
  
  // === YETKİLER (Vekaletname Kapsamı) ===
  canCollect   Boolean    @default(true)   // Ahzu Kabza
  canWaive     Boolean    @default(false)  // Feragat
  canSettle    Boolean    @default(false)  // Sulh
  canRelease   Boolean    @default(false)  // İbra
  
  // === PORTAL ERİŞİMİ ===
  hasPortalAccess Boolean @default(false)
  portalUserId    String?
  
  // === DİĞER ===
  notes        String?
  isActive     Boolean    @default(true)
  sortOrder    Int        @default(0)
  
  // Eski alanlar (geriye uyumluluk)
  name         String?    // @deprecated - displayName kullan
  identityNo   String?    // @deprecated - tckn veya vkn kullan
  email        String?    // @deprecated - contacts kullan
  phone        String?    // @deprecated - contacts kullan
  
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // İLİŞKİLER
  cases            Case[]
  contacts         ClientContact[]
  bankAccounts     ClientBankAccount[]
  powerOfAttorneys ClientPowerOfAttorney[]
  caseClients      CaseClient[]
  notifications    ClientNotification[]
  expenseRequests  ExpenseRequest[]
  portalUser       ClientPortalUser?
  
  // Address Discovery
  clientInfoRequests ClientInfoRequest[]

  @@index([tenantId])
  @@index([tenantId, tckn])
  @@index([tenantId, vkn])
  @@index([type])
  @@index([isActive])
}

// ==================== MÜVEKKİL PORTALI ====================

// Portal Kullanıcısı (Müvekkil girişi için)
model ClientPortalUser {
  id            String   @id @default(cuid())
  clientId      String   @unique
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email         String
  passwordHash  String
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  loginCount    Int      @default(0)
  
  // Şifre sıfırlama
  resetToken    String?
  resetTokenExp DateTime?
  
  // İki faktörlü doğrulama (opsiyonel)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([email])
  @@index([clientId])
}

// Müvekkil İletişim Bilgileri (Çoklu telefon/email)
model ClientContact {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type        String   // HOME_PHONE, WORK_PHONE, MOBILE, FAX, EMAIL
  value       String
  label       String?  // "İş", "Ev", "Asistan"
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([clientId])
  @@index([type])
}

// Müvekkil Banka Hesabı
model ClientBankAccount {
  id              String   @id @default(cuid())
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  bankName        String
  branchName      String?
  iban            String
  accountHolder   String?  // Hesap sahibi adı
  showInDocuments Boolean  @default(false)  // Takip talebinde göster
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
}

// Vekalet Durumu
enum PoaStatus {
  ACTIVE    // Geçerli
  EXPIRED   // Süresi Dolmuş
  REVOKED   // İptal Edilmiş
  PENDING   // Onay Bekliyor (portal için)
}

// Vekalet Kapsamı
enum PoaScopeType {
  GENEL       // Tüm işlemler
  ICRA_TAKIP  // Sadece icra takipleri
  BU_DOSYA    // Belirli dosya için
  OZEL        // Özel kapsam (açıklama ile)
}

// Müvekkil Vekaletnamesi
model ClientPowerOfAttorney {
  id            String    @id @default(cuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Temel Bilgiler
  notaryName    String?   // Noter Adı
  notaryCity    String?   // Noter İli
  journalNo     String?   // Yevmiye No
  poaNumber     String?   // Vekalet No
  dateIssued    DateTime? // Düzenleme Tarihi (eski: poaDate)
  
  // SÜRELİ VEKALET
  isLimited     Boolean   @default(false)  // Süreli mi?
  validUntil    DateTime?                   // Geçerlilik Bitiş Tarihi
  status        PoaStatus @default(ACTIVE)  // Durum
  
  // KAPSAM
  scopeType     PoaScopeType @default(GENEL)
  scopeDescription String?   // Özel kapsam açıklaması (eski: scope)
  
  // YETKİLER
  canCollect    Boolean   @default(true)   // Ahzu Kabza
  canWaive      Boolean   @default(false)  // Feragat
  canSettle     Boolean   @default(false)  // Sulh
  canRelease    Boolean   @default(false)  // İbra
  
  // Dosya
  filePath      String?   // Dosya yolu (.pdf, .jpg)
  fileSize      Int?
  mimeType      String?   // Dosya türü
  
  // Meta
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Eski alanlar (geriye uyumluluk)
  poaDate       DateTime? // @deprecated - dateIssued kullan
  scope         String?   // @deprecated - scopeDescription kullan

  // İlişkiler
  lawyers       PoaLawyer[]

  @@index([clientId])
  @@index([isActive])
  @@index([status])
  @@index([validUntil])
}

// Vekalet-Avukat İlişkisi (Bir vekalette birden fazla avukat olabilir)
model PoaLawyer {
  id          String   @id @default(cuid())
  poaId       String
  poa         ClientPowerOfAttorney @relation(fields: [poaId], references: [id], onDelete: Cascade)
  lawyerId    String
  lawyer      Lawyer   @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  isPrimary   Boolean  @default(false)  // Ana vekil mi?
  createdAt   DateTime @default(now())

  @@unique([poaId, lawyerId])
  @@index([poaId])
  @@index([lawyerId])
}

// Dosya-Müvekkil İlişkisi (Takipte yer alan müvekkiller)
model CaseClient {
  id                  String   @id @default(cuid())
  caseId              String
  case                Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  clientId            String
  client              Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  role                String   @default("ALACAKLI")  // ALACAKLI, ORTAK_ALACAKLI
  
  // Bu takip için özel ayarlar
  showBankInDocuments Boolean  @default(false)
  
  // Atama bilgileri
  assignedAt          DateTime @default(now())
  assignedById        String?
  notes               String?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([caseId, clientId])
  @@index([caseId])
  @@index([clientId])
}

model Debtor {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Temel Bilgiler
  type                  DebtorType
  
  // Gerçek Kişi Alanları (INDIVIDUAL)
  firstName             String?
  lastName              String?
  tckn                  String?    @db.VarChar(11)
  gender                String?    // E, K
  birthDate             DateTime?
  fatherName            String?
  motherName            String?
  birthPlace            String?
  
  // Tüzel Kişi Alanları (COMPANY)
  companyName           String?
  vkn                   String?    @db.VarChar(10)
  taxOffice             String?
  mersisNo              String?
  tradeRegisterNo       String?
  
  // Kamu Kurumu Alanları (PUBLIC_INSTITUTION)
  institutionName       String?
  detsisNo              String?
  institutionType       PublicInstitutionType?
  parentInstitution     String?
  authorizedPerson      String?
  
  // Tereke Alanları (ESTATE) - Miras Ortaklığı
  deceasedName          String?    // Müteveffanın (murisin) adı soyadı
  deceasedTckn          String?    @db.VarChar(11) // Murisin TCKN'si
  deathDate             DateTime?  // Ölüm tarihi
  inheritanceDocPath    String?    // Veraset ilamı dosya yolu
  
  // Computed Display Name (Ad Soyad veya Ünvan)
  name                  String
  // Kimlik No (TCKN, VKN veya DETSİS)
  identityNo            String?
  
  // İletişim
  email                 String?
  phone                 String?
  kepAddress            String?
  
  // Risk ve Notlar
  riskLevel             DebtorRiskLevel?
  riskNotes             String?
  notes                 String?
  
  // Eski alan (geriye uyumluluk)
  addresses             Json?
  
  // Timestamps
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  debtorAddresses       DebtorAddress[]
  caseDebtors           CaseDebtor[]
  assets                Asset[]
  communications        DebtorCommunication[]
  estateHeirs           EstateHeir[]  // Tereke mirasçıları
  
  // Address Discovery
  clientInfoRequests    ClientInfoRequest[]

  @@index([tenantId])
  @@index([tenantId, identityNo])
  @@index([tenantId, tckn])
  @@index([tenantId, vkn])
  @@index([tenantId, detsisNo])
  @@index([tenantId, name])
}

// Tereke Mirasçısı - Miras ortaklığındaki mirasçı bilgileri
model EstateHeir {
  id            String   @id @default(cuid())
  debtorId      String
  debtor        Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  
  // Mirasçı Bilgileri
  name          String   // Ad Soyad
  tckn          String?  @db.VarChar(11)
  address       String   // Yerleşim yeri adresi (zorunlu)
  city          String?
  district      String?
  shareRatio    String?  // Pay oranı (örn: "1/4", "25%")
  
  // İletişim Bilgileri
  phone         String?  // Telefon
  email         String?  // E-posta
  
  // Sıralama
  sortOrder     Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([debtorId])
}

// Borçlu Adresi (Tebligat Kanunu'na Uygun - Genişletilmiş)
model DebtorAddress {
  id              String   @id @default(cuid())
  debtorId        String
  debtor          Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  
  // Temel Bilgiler (Yeni - TK Uyumlu)
  type            AddressType      @default(DECLARED)
  subType         AddressSubType?
  source          AddressSource    @default(USER_INPUT)
  
  // Adres Detayları
  street          String
  city            String
  district        String?
  postalCode      String?
  country         String   @default("Türkiye")
  fullText        String?  // Computed: tam adres metni
  
  // Hukuki Bilgiler
  legalPriority   LegalPriority @default(MEDIUM)
  canApply21_2    Boolean  @default(false)  // TK 21/2 uygulanabilir mi?
  
  // Doğrulama
  verified        Boolean  @default(false)
  verifiedAt      DateTime?
  verifiedSource  String?  // Sorgu referansı
  
  // Risk Durumu
  riskFlags       AddressRiskFlag[]
  riskNotes       String?
  
  // TK 21/2 Bilgileri (bila tebligat)
  tk21_2Applied       Boolean   @default(false)
  tk21_2MuhtarDate    DateTime?  // Muhtara teslim tarihi
  tk21_2DoorPostDate  DateTime?  // Kapıya yapıştırma tarihi
  tk21_2NoticeDate    DateTime?  // İhbarname tarihi
  
  // Meta
  isPrimary       Boolean  @default(false)
  notes           String?
  
  // Güven Skoru (Address Discovery)
  confidenceScore Int?     // 0-100 arası güven skoru
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Eski alanlar (geriye uyumluluk - migration sonrası kaldırılabilir)
  addressType     String?  // @deprecated - type kullan
  isMernis        Boolean  @default(false) // @deprecated - type=MERNIS kullan

  // İlişkiler
  caseDebtors     CaseDebtor[]
  serviceHistory  ServiceHistory[]

  @@index([debtorId])
  @@index([type])
  @@index([verified])
}


// ==================== CASE (TAKİP) - GENİŞLETİLMİŞ ====================

model Case {
  id                  String        @id @default(cuid())
  tenantId            String
  tenant              Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Temel Bilgiler
  fileNumber          String        // Büro dosya no
  executionFileNumber String?       // İcra dosya no (2024/12345)
  
  // Takip Tipi ve Form (A.1)
  type                CaseType      // Takip türü enum
  formTypeId          String?       // Form tipi referansı
  formType            FormType?     @relation("CaseFormType", fields: [formTypeId], references: [id])
  
  // Takip Yolu (A.2)
  executionPath       ExecutionPath @default(HACIZ) // HACIZ, IFLAS, REHIN
  
  // Alt Takip Türü (A.7)
  subType             String?       // GENEL, KAMBIYO, vs.
  
  // Alt Kategori - UYAP Uyumlu (Genel/Nafaka/Döviz)
  subCategory         CaseSubCategory @default(GENEL)
  
  // Para Birimi
  currency            Currency      @default(TRY)
  
  // MTS (Merkezi Takip Sistemi) Dosyası mı?
  isMtsCase           Boolean       @default(false)
  mtsReferenceNo      String?       // MTS referans numarası
  mtsReturnDate       DateTime?     // MTS'den icra takibine dönüş tarihi
  
  // Faiz Bilgileri
  interestType        InterestType  @default(YASAL)
  interestStartDate   DateTime?     // Faiz başlangıç tarihi
  interestDescription String?       // Faiz açıklaması (şablonlar için)
  
  // Döviz Alacağı Bilgileri
  exchangeDate        DateTime?     // Kur tarihi (döviz alacağı için)
  exchangeRateType    String?       // "TAKIP_TARIHI" veya "ODEME_TARIHI"
  
  // Nafaka Bilgileri
  nafakaStartDate     DateTime?     // Nafaka başlangıç tarihi
  monthlyNafakaAmount Decimal?      @db.Decimal(15, 2) // Aylık nafaka tutarı
  
  // Takip Tarihi (A.3) - Zorunlu
  caseDate            DateTime      @default(now()) // Takip başlangıç tarihi
  
  // İcra Dairesi (A.5)
  executionOfficeId   String?
  executionOffice     ExecutionOffice? @relation(fields: [executionOfficeId], references: [id])
  
  // UYAP Bilgileri (A.6)
  uyapDosyaId         String?       // UYAP dosya ID
  uyapBirimKodu       String?       // UYAP birim kodu
  hasUyapWarning      Boolean       @default(false) // UYAP kodu eksik uyarısı
  
  // Statü Sistemi (B.13-16)
  caseStatus          LegalCaseStatus @default(DERDEST)
  
  // 4. Madde Talep (A.8)
  hasArticle4Request  Boolean       @default(false) // Takip talebi var mı?
  article4RequestDate DateTime?     // Takip talebi tarihi
  
  // İhtiyati Haciz (Her takip türünde olabilir)
  hasPrecautionaryOrder Boolean     @default(false) // İhtiyati haciz kararı var mı?
  
  // Dosya Yönetim Flag'leri (A.9)
  isArchived          Boolean       @default(false) // Arşiv dosyası
  showToClient        Boolean       @default(true)  // Müvekkile göster
  allowUyapActions    Boolean       @default(true)  // UYAP'ta işlem yap
  
  // Otomasyon Ayarları (A.10-11)
  isAutomationEnabled Boolean       @default(true)  // Otomasyon açık/kapalı
  nextAutoAction      String?       // Sıradaki otomatik işlem
  automationConfig    Json?         // Otomasyon ayarları detayı
  
  // Gün Sayacı (A.4)
  daysLeft            Int?          // Kalan gün sayısı
  nextActionAt        DateTime?     // Sonraki işlem zamanı
  
  // Risk Skoru (A.12)
  riskScore           Int?          // 0-100 arası risk skoru
  
  // Workflow
  workflowStage       WorkflowStage @default(INITIAL)
  
  // ==================== YENİ LOOKUP ALANLARI ====================
  // Takip Türü (ZORUNLU)
  takipTuruId         String?
  takipTuru           LookupTakipTuru? @relation("CaseTakipTuru", fields: [takipTuruId], references: [id])
  
  // Aşama
  asamaId             String?
  asama               LookupAsama?  @relation("CaseAsama", fields: [asamaId], references: [id])
  
  // Risk Sınıfı
  riskId              String?
  risk                LookupRisk?   @relation("CaseRisk", fields: [riskId], references: [id])
  
  // Borçlu Tipi
  borcluTipiId        String?
  borcluTipi          LookupBorcluTipi? @relation("CaseBorcluTipi", fields: [borcluTipiId], references: [id])
  
  // Durum Etiketi
  durumEtiketiId      String?
  durumEtiketi        LookupDurumEtiketi? @relation("CaseDurumEtiketi", fields: [durumEtiketiId], references: [id])
  
  // Mahiyet Tipi (Alacak Türü)
  mahiyetTipiId       String?
  mahiyetTipi         LookupMahiyetTipi? @relation("CaseMahiyetTipi", fields: [mahiyetTipiId], references: [id])
  mahiyetKodu         String?       // UYAP kodu veya büro içi kısa kod (otomatik veya manuel)
  
  // Sorumlu Personel (ZORUNLU)
  sorumluPersonelId   String?
  sorumluPersonel     User?         @relation("SorumluPersonel", fields: [sorumluPersonelId], references: [id])
  
  // Ek Bilgi Alanları
  dahiliNot           String?       // Müvekkile gitmez
  muvekkilNotu        String?       // Raporlarda görünür
  sonDegerlendirmeTarihi DateTime?  // Son değerlendirme tarihi

  // ==================== ESKİ ALANLAR (geriye uyumluluk) ====================
  status              CaseStatus    @default(ACTIVE)
  clientId            String?
  client              Client?       @relation(fields: [clientId], references: [id])
  courtId             String?
  court               Court?        @relation(fields: [courtId], references: [id])
  principalAmount     Decimal?      @db.Decimal(15, 2)
  interestRate        Decimal?      @db.Decimal(5, 2)
  startDate           DateTime?
  notes               String?
  metadata            Json?
  
  // Otomasyon tracking
  isAutoMode          Boolean       @default(false)
  autoActionsCount    Int           @default(0)
  lastAutoActionAt    DateTime?
  
  // OCR / Belge Tarama Bilgileri
  preDetectedCaseType   String?       // AI/rule tahmini (ILAMLI, KAMBIYO, vs.)
  preDetectedSubCategory String?      // Alt kategori tahmini (GENEL, NAFAKA, DOVIZ)
  ocrText               String?       // OCR'dan çıkarılan metin (ilk 2000 karakter)
  isAutoDetected        Boolean       @default(false) // Otomatik tespit edildi mi
  confidenceScore       Int?          // Güven skoru (0-100)
  sourceDocumentId      String?       // Kaynak belge ID (CaseDocument referansı)
  detectionKeywords     Json?         // Tespit edilen anahtar kelimeler
  
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // İlişkiler
  debtors             CaseDebtor[]
  lawyers             CaseLawyer[]
  staff               CaseStaff[]
  tasks               Task[]
  collections         Collection[]
  dues                Due[]
  lifecycleEvents     CaseLifecycle[]
  enforcementActions  EnforcementAction[]
  decisionLogs        DecisionLog[]
  notifications       NotificationQueue[]
  riskReports         RiskReport[]
  statusHistory       CaseStatusHistory[]
  documents           CaseDocument[]
  groups              CaseGroup[]
  stageHistory        CaseStageHistory[] @relation("CaseStageHistory")
  caseClients         CaseClient[]
  tebligatlar         Tebligat[]
  claimItems          ClaimItem[]
  ledgerEntries       LedgerEntry[]      // Tahsilat/düzeltme kayıtları
  precautionaryOrders PrecautionaryOrder[] // İhtiyati haciz kararları
  expenseRequests     ExpenseRequest[]   // Masraf talepleri
  caseBalance         CaseBalance?       // Masraf bakiyesi (1:1)
  
  // Address Discovery
  clientInfoRequests  ClientInfoRequest[]

  @@unique([tenantId, fileNumber])
  @@index([tenantId, status])
  @@index([tenantId, caseStatus])
  @@index([tenantId, createdAt])
  @@index([formTypeId])
  @@index([workflowStage])
  @@index([nextActionAt])
  @@index([executionOfficeId])
  @@index([isAutomationEnabled])
  @@index([takipTuruId])
  @@index([asamaId])
  @@index([riskId])
  @@index([durumEtiketiId])
  @@index([mahiyetTipiId])
  @@index([sorumluPersonelId])
  @@index([clientId])
}

// Statü Değişim Geçmişi (B.18)
model CaseStatusHistory {
  id            String          @id @default(cuid())
  caseId        String
  case          Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  fromStatus    LegalCaseStatus?
  toStatus      LegalCaseStatus
  reason        String?         // Değişim nedeni
  changedById   String?
  changedBy     User?           @relation("StatusChangedBy", fields: [changedById], references: [id])
  automationWasEnabled Boolean? // Otomasyon durumu değişti mi
  createdAt     DateTime        @default(now())

  @@index([caseId])
  @@index([createdAt])
}

// Dosya Belgeleri
model CaseDocument {
  id            String   @id @default(cuid())
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  documentType  DocumentType
  title         String
  description   String?
  filePath      String?
  fileSize      Int?
  mimeType      String?
  isGenerated   Boolean  @default(false) // Sistem tarafından üretildi mi
  generatedAt   DateTime?
  metadata      Json?
  
  // OCR Bilgileri
  ocrText           String?   // OCR'dan çıkarılan tam metin
  ocrProcessedAt    DateTime? // OCR işlem tarihi
  ocrConfidence     Int?      // OCR güven skoru
  isSourceDocument  Boolean   @default(false) // Takip için kaynak belge mi
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([caseId])
  @@index([documentType])
  @@index([isSourceDocument])
}


// Dosya Borçlusu - Genişletilmiş Model
model CaseDebtor {
  id                    String           @id @default(cuid())
  caseId                String
  case                  Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  debtorId              String
  debtor                Debtor           @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  
  // Rol ve Sorumluluk
  role                  DebtorRole       @default(ASIL_BORCLU)
  liabilityAmount       Decimal?         @db.Decimal(15, 2)
  liabilityType         LiabilityType?
  
  // Tebligat Modu ve Adres
  notificationMode      DebtorNotificationMode @default(NORMAL)
  selectedAddressId     String?
  selectedAddress       DebtorAddress?   @relation(fields: [selectedAddressId], references: [id])
  prepareNotification   Boolean          @default(true)
  ilanenJustification   String?          // İlanen tebligat gerekçesi
  
  // ===== TEBLİGAT TAKİP BİLGİLERİ (Güncellenmiş) =====
  serviceStatus         ServiceStatus    @default(NOT_STARTED)
  serviceChannel        DebtorNotificationMode? // Kullanılan kanal (NORMAL/KEP/UETS)
  trackingNo            String?          // PTT barkod / UETS referans no
  sentAt                DateTime?        // Gönderim tarihi
  deliveredAt           DateTime?        // Tebliğ tarihi
  returnedAt            DateTime?        // İade tarihi
  returnReason          ServiceReturnReason? // İade sebebi
  muhtarDeliveredAt     DateTime?        // Muhtara teslim tarihi (TK 21/2)
  announcementDate      DateTime?        // İlan tarihi
  announcementExpiry    DateTime?        // İlan süresi bitişi
  
  // Eski alanlar (geriye uyumluluk - deprecated)
  notificationBarcode   String?          @map("notification_barcode_old") // @deprecated - trackingNo kullan
  notificationSentDate  DateTime?        @map("notification_sent_date_old") // @deprecated - sentAt kullan
  notificationDeliveredDate DateTime?    @map("notification_delivered_date_old") // @deprecated - deliveredAt kullan
  notificationStatus    String?          @map("notification_status_old") // @deprecated - serviceStatus kullan
  notificationNote      String?          // Tebligat notu (iade sebebi detayı vb.)
  
  // ===== MALVARLIĞI SORGU DURUMLARI =====
  assetVehicle          AssetQueryStatus @default(UNKNOWN)
  assetRealEstate       AssetQueryStatus @default(UNKNOWN)
  assetBank             AssetQueryStatus @default(UNKNOWN)
  assetSgkWage          AssetQueryStatus @default(UNKNOWN)
  assetLastQueryAt      DateTime?        // Son sorgu tarihi
  
  // ===== HIZLI NOT =====
  quickNote             String?          // Avukatın kısa notu (max 240 karakter)
  quickNoteUpdatedAt    DateTime?
  quickNoteUpdatedBy    String?
  
  // Borçlu Vekili
  debtorLawyerId        String?
  debtorLawyerName      String?
  debtorLawyerBarNo     String?
  
  // Dosyaya Özel
  caseNote              String?
  
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @default(now()) @updatedAt

  // Relations
  thirdParties          ThirdParty[]
  externalCases         ExternalCase[]
  serviceHistory        ServiceHistory[]
  
  // Address Discovery
  uyapQueries           UyapQuery[]
  institutionLetters    InstitutionLetter[]
  addressResearch       AddressResearch?
  
  // Asset Queries (FAZ 4)
  assetQueries          AssetQuery[]

  @@unique([caseId, debtorId, role])
  @@index([caseId])
  @@index([debtorId])
  @@index([serviceStatus])
}

// Tebligat Geçmişi - Audit Trail
model ServiceHistory {
  id              String              @id @default(cuid())
  caseDebtorId    String
  caseDebtor      CaseDebtor          @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  
  // Durum Değişikliği
  fromStatus      ServiceStatus?
  toStatus        ServiceStatus
  channel         DebtorNotificationMode?
  trackingNo      String?
  returnReason    ServiceReturnReason?
  
  // Adres Bağlantısı (Yeni - TK Uyumlu)
  addressId       String?
  address         DebtorAddress?      @relation(fields: [addressId], references: [id])
  addressType     AddressType?        // Snapshot - tebligat anındaki adres türü
  addressText     String?             // Snapshot - tebligat anındaki tam adres
  
  // Tarihler
  actionDate      DateTime            // İşlem tarihi (gönderim/tebliğ/iade)
  
  // Meta
  note            String?
  createdBy       String?             // User ID
  createdAt       DateTime            @default(now())

  @@index([caseDebtorId])
  @@index([toStatus])
  @@index([addressId])
}

model Due {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type        DueType
  description String?
  amount      Decimal  @db.Decimal(15, 2)
  dueDate     DateTime
  
  // Para Birimi
  currency    String   @default("TRY")  // TRY, USD, EUR, GBP, CHF
  
  // Faiz Detayları (type = INTEREST için)
  interestType      String?   // YASAL, TICARI, AVANS, TEMERRUT, OZEL
  interestRate      Decimal?  @db.Decimal(5, 2)  // Faiz oranı (%)
  interestStartDate DateTime? // Faiz başlangıç tarihi
  interestEndDate   DateTime? // Faiz bitiş tarihi
  interestDays      Int?      // Faiz gün sayısı
  
  // Kaynak Belge Referansı
  sourceDocumentId  String?   // CaseDocument referansı
  sourceDocumentNo  String?   // Belge numarası (fatura no, senet no vb.)
  
  // Vergi/Kesinti Bilgileri
  hasKdv            Boolean   @default(false)  // KDV dahil mi
  kdvRate           Decimal?  @db.Decimal(5, 2) // KDV oranı
  hasBsmv           Boolean   @default(false)  // BSMV dahil mi (bankacılık)
  hasKkdf           Boolean   @default(false)  // KKDF dahil mi (kredi)
  
  // Kesinleşme Durumu (ilamlı takipler için)
  requiresFinalization Boolean @default(false) // Kesinleşme gerekiyor mu
  isFinalized          Boolean @default(false) // Kesinleşti mi
  finalizationDate     DateTime?              // Kesinleşme tarihi
  finalizationNote     String?                // Kesinleşme notu
  
  // Sıralama ve Öncelik
  sortOrder   Int      @default(0)
  isPrimary   Boolean  @default(false)  // Ana alacak kalemi mi
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([caseId])
  @@index([type])
}

model Asset {
  id          String    @id @default(cuid())
  debtorId    String
  debtor      Debtor    @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  type        AssetType
  description String
  value       Decimal?  @db.Decimal(15, 2)
  details     Json?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([debtorId])
}

// ==================== ÜÇÜNCÜ ŞAHIS (89 İHBARNAME) ====================

model ThirdParty {
  id              String          @id @default(cuid())
  tenantId        String
  caseDebtorId    String
  caseDebtor      CaseDebtor      @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  
  // Temel Bilgiler
  type            ThirdPartyType
  name            String
  identityNo      String?         // TCKN veya VKN
  
  // İletişim
  address         String
  city            String?
  phone           String?
  email           String?
  kepAddress      String?
  
  // İlişki
  relationDesc    String?         // Borçlu ile ilişki açıklaması
  
  // 89 İhbarname Takibi
  ihbarname89_1_date      DateTime?
  ihbarname89_1_status    String?   // GONDERILDI, TEBLIG_EDILDI, CEVAP_ALINDI
  ihbarname89_2_date      DateTime?
  ihbarname89_2_status    String?
  ihbarname89_3_date      DateTime?
  ihbarname89_3_status    String?
  
  // Cevap
  responseDate    DateTime?
  responseContent String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([caseDebtorId])
  @@index([tenantId])
}

// ==================== DIŞ DOSYA (ALACAK HACZİ) ====================

// Borçlunun alacaklı olduğu icra dosyaları - alacak haczi için
model ExternalCase {
  id                String   @id @default(cuid())
  tenantId          String
  caseDebtorId      String
  caseDebtor        CaseDebtor @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  
  // Dış Dosya Bilgileri
  externalOffice    String          // İcra dairesi adı
  externalOfficeId  String?         // UYAP birim kodu (varsa)
  externalCaseNo    String          // Dosya numarası (2024/12345)
  
  // Karşı Taraf (Dış dosyadaki borçlu)
  counterpartyName  String          // Borçlumuzun alacaklı olduğu kişi/kurum
  counterpartyId    String?         // Sistemde kayıtlıysa debtor ID
  
  // Alacak Bilgileri
  claimAmount       Decimal         @db.Decimal(15, 2)
  claimCurrency     String          @default("TRY")
  
  // Haciz Durumu
  attachmentStatus  ExternalCaseStatus @default(HACIZ_TALEP)
  attachedAt        DateTime?       // Haciz konulma tarihi
  
  // Tahsilat Takibi
  receivedAmount    Decimal         @default(0) @db.Decimal(15, 2)
  lastReceivedAt    DateTime?
  
  // Notlar
  notes             String?
  priorityNote      String?         // Sıra, rüçhan notları
  
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([caseDebtorId])
  @@index([tenantId])
  @@index([externalCaseNo])
}

enum ExternalCaseStatus {
  HACIZ_TALEP       // Haciz talep edildi
  HACIZ_KONDU       // Haciz konuldu
  CEVAP_BEKLENIYOR  // Cevap bekleniyor
  TAHSIL_BASLADI    // Tahsilat başladı
  KAPANDI           // Kapandı
}

// ==================== BORÇLU İLETİŞİM ====================

model DebtorCommunication {
  id            String   @id @default(cuid())
  tenantId      String
  debtorId      String
  debtor        Debtor   @relation(fields: [debtorId], references: [id], onDelete: Cascade)
  caseId        String?
  
  channel       String   // SMS, EMAIL, PHONE_CALL
  templateId    String?
  templateName  String?
  content       String
  
  status        String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt        DateTime?
  deliveredAt   DateTime?
  failReason    String?
  
  // Telefon görüşmesi için
  callDuration  Int?
  callNotes     String?
  
  createdAt     DateTime @default(now())

  @@index([debtorId])
  @@index([caseId])
  @@index([tenantId])
}

model Task {
  id           String     @id @default(cuid())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caseId       String?
  case         Case?      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  status       TaskStatus @default(PENDING)
  priority     Priority   @default(MEDIUM)
  dueDate      DateTime?
  assigneeId   String?
  assignee     User?      @relation("AssignedTasks", fields: [assigneeId], references: [id])
  createdById  String?
  createdBy    User?      @relation("CreatedTasks", fields: [createdById], references: [id])
  completedAt  DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([assigneeId])
}

model Court {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  city      String
  district  String?
  type      String?
  courtType String?  // Mahkeme türü (Asliye Hukuk, Ağır Ceza, vb.)
  courtCode String?  // Birim ID
  uyapCode  String?  // UYAP organizasyon kodu
  address   String?
  phone     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases Case[]

  @@index([tenantId])
  @@index([city])
  @@index([uyapCode])
}

// ==================== BÜRO BİLGİLERİ ====================

model Office {
  id              String   @id @default(cuid())
  tenantId        String   @unique  // Her tenant'ın tek bir ofisi var
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Temel Bilgiler
  name            String   // Hukuk Bürosu adı
  
  // Adres
  address         String?
  city            String?
  district        String?
  postalCode      String?
  
  // İletişim
  phone           String?
  fax             String?
  email           String?
  website         String?
  
  // Baro Bilgisi
  barAssociation  String?  // Bağlı olduğu baro
  
  // Varsayılan İcra Dairesi
  defaultExecutionOfficeId String?
  
  // SMTP Ayarları (E-posta Gönderimi)
  smtpHost        String?  // smtp.gmail.com, smtp.yandex.com, vb.
  smtpPort        Int?     // 587, 465, vb.
  smtpUser        String?  // E-posta adresi
  smtpPass        String?  // Uygulama şifresi (şifrelenmiş)
  smtpSecure      Boolean  @default(false) // TLS/SSL
  smtpFromName    String?  // Gönderen adı
  smtpFromEmail   String?  // Gönderen e-posta
  
  // SMS Ayarları (Opsiyonel)
  smsProvider     String?  // NETGSM, ILETI_MERKEZI, vb.
  smsApiKey       String?
  smsApiSecret    String?
  smsSender       String?  // Gönderen adı
  
  // Otomatik Tebrik Ayarları
  autoGreetingEnabled     Boolean @default(true)  // Otomatik tebrik sistemi açık/kapalı
  autoGreetingTime        String? @default("09:00") // Tebrik gönderim saati (HH:mm)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // İlişkiler
  bankAccounts    OfficeBankAccount[]
  lawyers         Lawyer[]
  lawyerTemplates LawyerTemplate[]

  @@index([tenantId])
}

model OfficeBankAccount {
  id          String   @id @default(cuid())
  officeId    String
  office      Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  
  bankName    String
  branchName  String?
  iban        String
  accountName String?  // Hesap sahibi adı
  isDefault   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([officeId])
}

// ==================== AVUKAT ====================

model Lawyer {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  officeId     String?
  office       Office?  @relation(fields: [officeId], references: [id])
  
  // Kişisel Bilgiler
  name         String
  surname      String
  tckn         String?  // TC Kimlik No (zorunlu)
  gender       String?  // E, K, D
  
  // Unvan/Sıfat - İsmin önünde görünecek (Av., Stj. Av., Huk. Müş., İcra Kat., vb.)
  title        String?  // Varsayılan: role'e göre otomatik belirlenir
  
  // Mesleki Bilgiler
  barNumber    String?  // Baro Sicil No
  barCity      String?  // Kayıtlı olduğu baro (İstanbul, Ankara...)
  tbbNo        String?  // TBB No
  lawyerType   String?  // BARO, KURUM, SOZLESMELI
  
  // Vergi Bilgileri
  vergiDairesi String?  // Vergi Dairesi
  vergiNo      String?  // Vergi No (zorunlu)
  
  // İletişim
  email        String?
  phone        String?
  fax          String?  // Faks numarası
  address      String?
  city         String?
  district     String?
  
  // Banka Bilgileri
  bankName     String?
  branchName   String?  // Şube adı
  iban         String?
  
  // Statü
  isInHouseCounsel Boolean @default(false)  // Kurum Avukatı
  isEmployee       Boolean @default(false)  // Sigortalı (SSK'lı)
  
  // ==================== AVUKAT TİPİ VE YETKİ SİSTEMİ ====================
  // Avukat Tipi (Hiyerarşi)
  lawyerRank       LawyerRank @default(LAWYER)  // PARTNER, MANAGER, AUTHORIZED, LAWYER
  
  // Varsayılan Yetkiler (Büro genelinde - yeni dosyalara otomatik uygulanır)
  defaultPermissions Json?  // { canEditCase, canGenerateDocs, canSyncUYAP, ... }
  
  // Yetki Kilidi (Ortak avukat tarafından belirlenir)
  permissionsLocked Boolean @default(false)  // true ise yönetici bile değiştiremez
  permissionsLockedBy String?  // Kilitleyen ortak avukat ID
  permissionsLockedAt DateTime?
  
  // Yetki Değiştirme Yetkisi
  canModifyOtherPermissions Boolean @default(false)  // Başka avukatların yetkilerini değiştirebilir mi
  
  // Rol (eski alan - geriye uyumluluk)
  role         LawyerRole @default(EMPLOYEE)
  
  // Genel Yetkiler (büro genelinde)
  canSign              Boolean @default(false)  // Genel imza yetkisi
  canAppearInUyap      Boolean @default(false)  // UYAP'ta görünebilir
  canBeResponsible     Boolean @default(true)   // Dosya sorumlusu olabilir
  isDefaultForNewCases Boolean @default(false)  // Yeni dosyalarda otomatik seç
  
  // UYAP Bilgileri (ileride kullanılacak)
  uyapUsername    String?
  uyapToken       String?  // Şifrelenmiş
  eSignatureSerial String? // E-imza seri no
  
  // Durum
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  
  // Eski alanlar (geriye uyumluluk)
  barName      String?  // @deprecated - barCity kullan
  identityNo   String?  // @deprecated - tckn kullan
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  caseLawyers  CaseLawyer[]
  poaLawyers   PoaLawyer[]  // Avukatın dahil olduğu vekaletler
  powerOfAttorneys PowerOfAttorney[]  // Eski vekalet modeli ilişkisi

  @@index([tenantId])
  @@index([officeId])
  @@index([isActive])
  @@index([lawyerRank])
}

// Avukat Tipi/Rütbesi (Hiyerarşi)
enum LawyerRank {
  PARTNER     // Ortak Avukat - Tüm yetkiler, yetki yönetimi
  MANAGER     // Yönetici Avukat - Geniş yetkiler, ortak tarafından atanır
  AUTHORIZED  // Yetkili Avukat - Büro ayarlarındaki varsayılan yetkiler
  LAWYER      // Avukat - Büro ayarlarındaki varsayılan yetkiler
  INTERN      // Stajyer Avukat - Kısıtlı yetkiler
}

enum LawyerRole {
  OWNER      // Büro sahibi
  PARTNER    // Ortak
  EMPLOYEE   // Çalışan avukat
  INTERN     // Stajyer
}

model CaseLawyer {
  id          String   @id @default(cuid())
  caseId      String
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  lawyerId    String
  lawyer      Lawyer   @relation(fields: [lawyerId], references: [id], onDelete: Cascade)
  
  // Bu dosyadaki rol
  role        CaseLawyerRole @default(ASSIGNED)
  
  // Bu dosyadaki yetkiler
  hasSignatureAuthority Boolean @default(false)  // Bu dosyada imza yetkisi
  isResponsible         Boolean @default(false)  // Dosya sorumlusu mu
  
  // ==================== DOSYA ÖZEL YETKİLER ====================
  // Bu yetkiler avukatın varsayılan yetkilerini override eder
  casePermissions Json?  // { canEditCase, canGenerateDocs, canSyncUYAP, canViewFinance, canEditFinance, canChangeStatus, canEditParties }
  
  // Yetki kaynağı
  permissionSource String @default("DEFAULT")  // DEFAULT (avukat varsayılanı), CUSTOM (dosya özel), LOCKED (kilitli)
  
  // Müvekkil portalı
  visibleToClient       Boolean @default(true)
  
  // Bildirimler
  receiveNotifications  Boolean @default(true)
  
  // Vekalet bilgisi
  powerOfAttorneyId     String?
  powerOfAttorney       PowerOfAttorney? @relation(fields: [powerOfAttorneyId], references: [id])
  
  // Atama bilgileri
  assignedAt    DateTime @default(now())
  assignedById  String?  // Kim atadı
  notes         String?  // Özel notlar
  
  // Eski alan (geriye uyumluluk)
  canSign       Boolean  @default(false)  // @deprecated - hasSignatureAuthority kullan
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  @@unique([caseId, lawyerId])
  @@index([caseId])
  @@index([lawyerId])
  @@index([isResponsible])
}

enum CaseLawyerRole {
  RESPONSIBLE  // Sorumlu avukat
  ASSIGNED     // Atanmış avukat
  ASSISTANT    // Yardımcı
  INTERN       // Stajyer
}

// ==================== AVUKAT ŞABLONU ====================

model LawyerTemplate {
  id          String   @id @default(cuid())
  officeId    String
  office      Office   @relation(fields: [officeId], references: [id], onDelete: Cascade)
  
  name        String   // "Standart İcra Takibi", "Önemli Dosya"
  description String?
  isDefault   Boolean  @default(false)  // Varsayılan şablon mu
  
  // Şablondaki avukatlar (JSON)
  // [{lawyerId: "xxx", role: "RESPONSIBLE", hasSignatureAuthority: true}]
  lawyers     Json
  
  // Hangi takip türleri için geçerli
  applicableFor String?  // "ICRA", "DAVA", "ALL"
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([officeId])
  @@index([isDefault])
}

// ==================== VEKALETNAME ====================

model PowerOfAttorney {
  id              String   @id @default(cuid())
  tenantId        String
  
  // Vekalet veren (müvekkil)
  clientId        String?
  clientName      String?  // Müvekkil adı (client yoksa)
  
  // Vekil (avukat)
  lawyerId        String
  lawyer          Lawyer   @relation(fields: [lawyerId], references: [id])
  
  // Vekalet bilgileri
  type            PowerOfAttorneyType @default(GENEL)
  scope           String?  // Vekalet kapsamı açıklaması
  
  // Tarihler
  issueDate       DateTime  // Düzenleme tarihi
  expiryDate      DateTime? // Bitiş tarihi (varsa)
  
  // Noter bilgileri
  notaryName      String?   // Noter adı
  notaryCity      String?   // Noter ili
  registerNo      String?   // Yevmiye no
  
  // Belge
  documentPath    String?   // Vekalet belgesi dosya yolu
  
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  caseLawyers     CaseLawyer[]

  @@index([tenantId])
  @@index([lawyerId])
  @@index([clientId])
  @@index([isActive])
}

enum PowerOfAttorneyType {
  GENEL           // Genel vekaletname
  OZEL            // Özel vekaletname
  ICRA            // İcra vekaletnamesi
  DAVA            // Dava vekaletnamesi
}

model Collection {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  caseId          String
  case            Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseDebtorId    String?         // Hangi borçludan tahsil edildi
  
  // Tutar Bilgileri
  amount          Decimal         @db.Decimal(15, 2)
  currency        String          @default("TRY")
  
  // Tahsilat Türü ve Kanalı
  type            CollectionType
  channel         CollectionChannel @default(BANKA)
  
  // Tarih
  date            DateTime
  valueDate       DateTime?       // Valör tarihi
  
  // Kaynak Bilgisi
  sourceType      CollectionSource? // Nereden geldi
  sourceId        String?          // Kaynak ID (ExternalCase, ThirdParty vs.)
  
  // Mahsup Bilgileri
  allocations     CollectionAllocation[]
  
  // Açıklama ve Notlar
  description     String?
  receiptNo       String?         // Makbuz no
  bankName        String?         // Banka adı
  accountNo       String?         // Hesap no
  notes           String?
  
  // Durum
  status          CollectionStatus @default(CONFIRMED)
  cancelledAt     DateTime?
  cancelReason    String?
  
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdById     String?

  @@index([tenantId])
  @@index([caseId])
  @@index([caseDebtorId])
  @@index([date])
  @@index([status])
  @@index([type])
}

// Tahsilat Mahsup Kaydı (Hangi alacak kalemine ne kadar mahsup edildi)
model CollectionAllocation {
  id              String     @id @default(cuid())
  collectionId    String
  collection      Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  
  // Mahsup Edilen Kalem
  allocationType  AllocationType  // PRINCIPAL, INTEREST, EXPENSE, FEE, OTHER
  amount          Decimal    @db.Decimal(15, 2)
  description     String?
  
  createdAt       DateTime   @default(now())

  @@index([collectionId])
}

// Tahsilat Kanalı
enum CollectionChannel {
  NAKIT           // Nakit
  BANKA           // Banka havalesi/EFT
  CEK             // Çek
  SENET           // Senet
  KREDI_KARTI     // Kredi kartı
  ICRA_DAIRESI    // İcra dairesinden
  HACIZ           // Haciz yoluyla
  DIGER           // Diğer
}

// Tahsilat Kaynağı
enum CollectionSource {
  MANUAL          // Manuel giriş
  EXTERNAL_CASE   // Dış dosyadan (alacak haczi)
  THIRD_PARTY     // Üçüncü şahıstan (89 ihbarname)
  BANK_SEIZURE    // Banka haczi
  SALARY_SEIZURE  // Maaş haczi
  AUCTION         // Satış/ihale
  SETTLEMENT      // Sulh/anlaşma
}

// Tahsilat Durumu
enum CollectionStatus {
  PENDING         // Beklemede
  CONFIRMED       // Onaylandı
  CANCELLED       // İptal edildi
  REFUNDED        // İade edildi
}

// Masraf Talebi Durumu
enum ExpenseRequestStatus {
  PENDING         // Oluşturuldu, henüz gönderilmedi
  SENT            // Müvekkile gönderildi
  REMINDED        // Hatırlatma gönderildi
  RECEIVED        // Dekont/ödeme alındı
  LAWYER_PAID     // Avukat karşıladı - müvekkilden tahsil edilecek
  OVERDUE         // Süresi geçti
  CANCELLED       // İptal edildi
}

// Mahsup Türü
enum AllocationType {
  PRINCIPAL       // Ana para
  INTEREST        // Faiz
  EXPENSE         // Masraf
  FEE             // Harç
  ATTORNEY_FEE    // Vekalet ücreti
  PENALTY         // Ceza/tazminat
  OTHER           // Diğer
}

// ==================== AUTOMATION MODELS ====================

model CaseLifecycle {
  id          String         @id @default(cuid())
  caseId      String
  case        Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  stage       WorkflowStage
  action      String
  description String?
  triggeredBy TriggerType    @default(MANUAL)
  metadata    Json?
  createdAt   DateTime       @default(now())

  @@index([caseId])
  @@index([stage])
  @@index([createdAt])
}

model EnforcementAction {
  id              String              @id @default(cuid())
  caseId          String
  case            Case                @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type            EnforcementType
  status          EnforcementStatus   @default(PENDING)
  targetType      String?
  targetDetails   Json?
  requestDate     DateTime?
  responseDate    DateTime?
  responseDetails Json?
  amount          Decimal?            @db.Decimal(15, 2)
  notes           String?
  documentPath    String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([caseId])
  @@index([type])
  @@index([status])
}

model RiskReport {
  id              String   @id @default(cuid())
  caseId          String
  case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  overallScore    Int
  collectionProb  Int?
  recommendedAction String?
  factors         Json?
  assetAnalysis   Json?
  debtorAnalysis  Json?
  aiSuggestions   Json?
  createdAt       DateTime @default(now())

  @@index([caseId])
  @@index([overallScore])
}

model DecisionLog {
  id            String       @id @default(cuid())
  caseId        String
  case          Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  decisionType  DecisionType
  decision      String
  reasoning     String?
  confidence    Int?
  inputData     Json?
  outcome       String?
  isAutomatic   Boolean      @default(false)
  executedAt    DateTime?
  createdAt     DateTime     @default(now())

  @@index([caseId])
  @@index([decisionType])
  @@index([isAutomatic])
}

model NotificationQueue {
  id              String             @id @default(cuid())
  tenantId        String?            // Tenant bazlı bildirimler için (vekalet uyarıları vb.)
  caseId          String?            // Dosya bazlı bildirimler için (opsiyonel)
  case            Case?              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type            NotificationType
  channel         NotificationChannel
  recipient       String
  recipientName   String?
  subject         String?
  content         String?
  templateCode    String?
  status          NotificationStatus @default(PENDING)
  scheduledAt     DateTime?
  sentAt          DateTime?
  deliveredAt     DateTime?
  responseAt      DateTime?
  expiresAt       DateTime?
  errorMessage    String?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([status])
  @@index([scheduledAt])
  @@index([expiresAt])
}


// ==================== TEBLİGAT SİSTEMİ ====================

// Tebligat Kaydı - İcra tebligatları için özel model
model Tebligat {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  case            Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  caseDebtorId    String?          // Hangi borçluya
  
  // Tebligat Türü
  tebligatType    TebligatType     // ODEME_EMRI, ICRA_EMRI, HACIZ_IHBARNAMESI, vs.
  
  // Adres Bilgileri
  addressType     TebligatAddressType  // BILINEN, MERNIS, TICARET_SICIL, KEP
  addressId       String?          // DebtorAddress referansı
  addressText     String           // Tam adres metni
  city            String?
  district        String?
  
  // Muhatap Bilgileri
  recipientName   String           // Borçlu adı
  recipientTcVkn  String?          // TC/VKN
  
  // Tebligat Kanalı
  channel         TebligatChannel  // PTT, KEP, UETS, ILANEN
  
  // Durum Takibi
  status          TebligatStatus   @default(HAZIRLANDI)
  
  // Tarihler
  preparedAt      DateTime         @default(now())  // Hazırlandı
  sentAt          DateTime?        // Gönderildi
  deliveredAt     DateTime?        // Teslim edildi
  returnedAt      DateTime?        // İade geldi
  
  // PTT/Tebligat Sonucu
  pttResult       TebligatPttResult?  // PTT şerhi
  pttResultDate   DateTime?
  pttResultNote   String?          // PTT açıklama
  
  // 21/1 - 21/2 Bilgileri
  tk21Type        Tk21Type?        // TK_21_1, TK_21_2
  muhtarlikDate   DateTime?        // Muhtarlığa bırakılma tarihi
  ilanDate        DateTime?        // İhbar yapıştırma tarihi
  tebligSayilmaDate DateTime?      // Tebliğ edilmiş sayılma tarihi (21/2 için +15 gün)
  
  // Sonraki Adım
  nextAction      TebligatNextAction?
  nextActionDate  DateTime?
  
  // Belge
  documentId      String?          // Oluşturulan belge
  barcodeNo       String?          // PTT barkod no
  
  // Notlar
  notes           String?
  metadata        Json?
  
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([caseDebtorId])
  @@index([status])
  @@index([tebligatType])
}

// Tebligat Türü
enum TebligatType {
  ODEME_EMRI           // Ödeme Emri
  ICRA_EMRI            // İcra Emri
  TAHLIYE_EMRI         // Tahliye Emri
  HACIZ_IHBARNAMESI_89_1  // 89/1 Haciz İhbarnamesi
  HACIZ_IHBARNAMESI_89_2  // 89/2 Haciz İhbarnamesi
  HACIZ_IHBARNAMESI_89_3  // 89/3 Haciz İhbarnamesi
  SATIS_ILANI          // Satış İlanı
  KIYMET_TAKDIRI       // Kıymet Takdiri
  DIGER                // Diğer
}

// Tebligat Adres Türü
enum TebligatAddressType {
  BILINEN              // Bilinen en son adres (TK m.10)
  MERNIS               // MERNİS adresi (TK m.10/2)
  TICARET_SICIL        // Ticaret sicil adresi (tüzel kişiler)
  KEP                  // KEP adresi
  VERGI_DAIRESI        // Vergi dairesi adresi
}

// Tebligat Kanalı
enum TebligatChannel {
  PTT                  // PTT ile fiziki tebligat
  KEP                  // Kayıtlı Elektronik Posta
  UETS                 // Ulusal Elektronik Tebligat Sistemi
  ILANEN               // İlanen tebligat
  ELDEN                // Elden tebligat
}

// Tebligat Durumu
enum TebligatStatus {
  HAZIRLANDI           // Hazırlandı, gönderilmedi
  GONDERILDI           // Gönderildi, sonuç bekleniyor
  TESLIM_EDILDI        // Muhataba teslim edildi
  IADE_GELDI           // İade geldi (çeşitli nedenlerle)
  MUHTARLIGA_BIRAKILDI // Muhtarlığa bırakıldı (21/1 veya 21/2)
  TEBLIG_EDILMIS_SAYILDI // Tebliğ edilmiş sayıldı (21/2 +15 gün)
  IPTAL                // İptal edildi
}

// PTT Sonucu (Şerh)
enum TebligatPttResult {
  TESLIM_EDILDI        // Muhataba teslim edildi
  AYNI_KONUTTA_TESLIM  // Aynı konutta birlikte oturana teslim
  ISYERINDE_TESLIM     // İşyerinde çalışana teslim
  ADRESTE_BULUNAMADI   // Muhatap adreste bulunamadı
  TASINMIS             // Taşınmış
  ADRES_YETERSIZ       // Adres yetersiz
  BINA_YIKILMIS        // Bina yıkılmış
  ADRES_KAPALI         // Adres kapalı
  IMTINA               // Tebligatı almaktan imtina
  MUHTARLIGA_BIRAKILDI // Muhtarlığa bırakıldı
  VEFAT                // Muhatap vefat etmiş
  TANIMIYOR            // Adreste tanınmıyor
  DIGER                // Diğer
}

// TK 21 Türü
enum Tk21Type {
  TK_21_1              // Bilinen adreste imtina (aynı gün tebliğ)
  TK_21_2              // MERNİS adresi (ihbar + 15 gün)
}

// Sonraki Adım
enum TebligatNextAction {
  MERNIS_TEBLIGAT      // MERNİS adresine tebligat çıkar
  ILANEN_TEBLIGAT      // İlanen tebligat başlat
  TEBLIG_TAMAMLANDI    // Tebligat tamamlandı
  YENI_ADRES_ARA       // Yeni adres araştır
  BEKLE                // Bekle (süre dolmadı)
}


// ==================== BELGE ŞABLONLARI ====================

model DocumentTemplate {
  id              String   @id @default(cuid())
  code            String   @unique  // TAKIP_TALEBI_GENEL, ODEME_EMRI_NAFAKA vs.
  name            String            // Takip Talebi - Genel
  title           String            // Başlık
  description     String?
  category        DocumentCategory
  subCategory     CaseSubCategory?  // Hangi alt kategori için
  currency        Currency?         // Hangi para birimi için
  
  // Şablon İçeriği
  templateContent String            // Şablon metni (değişkenlerle)
  headerContent   String?           // Üst bilgi
  footerContent   String?           // Alt bilgi
  
  // Değişkenler
  variables       Json?             // Kullanılan değişkenler listesi
  
  // UYAP Bilgileri
  uyapCode        String?           // UYAP belge kodu
  iikMaddesi      String?           // İİK maddesi
  
  // Ayarlar
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([category])
  @@index([subCategory])
  @@index([isActive])
}

// Belge Kategorisi
enum DocumentCategory {
  TAKIP_TALEBI      // 4. Madde Takip Talebi
  ODEME_EMRI        // Ödeme Emri
  HACIZ_MUZEKKERESI // Haciz Müzekkeresi
  SATIS_ILANI       // Satış İlanı
  REDDIYAT          // Reddiyat Yazısı
  MTS_DONUS         // MTS Geri Dönüş Yazısı
  ITIRAZ            // İtiraz Dilekçesi
  DIGER             // Diğer
}

// ==================== UYAP ENTEGRASYON LOGLARI ====================

model UyapRequestLog {
  id              String   @id @default(cuid())
  caseId          String?
  requestType     String            // sendPaymentOrder, checkTebligat vs.
  requestData     Json?             // Gönderilen veri
  requestAt       DateTime @default(now())
  
  // Yanıt
  responseData    Json?
  responseAt      DateTime?
  
  // Durum
  status          UyapRequestStatus @default(PENDING)
  errorMessage    String?
  retryCount      Int      @default(0)
  
  // Referanslar
  evkNo           String?           // Evrak kayıt numarası
  uyapDosyaId     String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([caseId])
  @@index([status])
  @@index([requestType])
}

enum UyapRequestStatus {
  PENDING
  SENT
  SUCCESS
  FAILED
  RETRY
}

// ==================== FORM METADATA ====================

model FormType {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  title             String
  description       String?
  category          FormCategory
  procedureType     ProcedureType
  uyapCode          String?
  iikMaddesi        String?
  usageScenario     String?
  exampleCase       String?
  hasJudgment       Boolean         @default(false)
  needsMortgage     Boolean         @default(false)
  isKambiyo         Boolean         @default(false)
  isRental          Boolean         @default(false)
  requiredDocuments Json?
