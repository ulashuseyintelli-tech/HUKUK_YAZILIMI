// ==================== BANKA ENTEGRASYONU ====================

model BankAccount {
  id              String   @id @default(cuid())
  tenantId        String
  
  // Hesap Bilgileri
  bankCode        String   // Banka kodu (0001, 0010, vb.)
  bankName        String   // Banka adı
  branchCode      String?  // Şube kodu
  branchName      String?  // Şube adı
  accountNo       String?  // Hesap numarası
  iban            String   // IBAN
  currency        String   @default("TRY")
  accountType     String   @default("VADESIZ") // VADESIZ, VADELI, YATIRIM
  
  // Sahip Bilgileri
  ownerType       String   // TENANT, CLIENT
  ownerId         String?  // Client ID (müvekkil hesabıysa)
  ownerName       String
  
  // Entegrasyon
  isIntegrated    Boolean  @default(false)
  integrationProvider String? // garanti, akbank, isbank, vb.
  lastSyncAt      DateTime?
  
  // Durum
  isActive        Boolean  @default(true)
  isPrimary       Boolean  @default(false)
  
  // Meta
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // İlişkiler
  transactions    BankTransaction[]

  @@unique([tenantId, iban])
  @@index([tenantId])
  @@index([ownerType, ownerId])
  @@index([isActive])
}

model BankTransaction {
  id              String   @id @default(cuid())
  tenantId        String
  bankAccountId   String
  
  // İşlem Bilgileri
  transactionDate DateTime
  valueDate       DateTime?
  amount          Decimal  @db.Decimal(18, 2)
  currency        String   @default("TRY")
  transactionType String   // INCOMING, OUTGOING
  
  // Karşı Taraf
  counterpartyName String?
  counterpartyIban String?
  counterpartyBank String?
  
  // Açıklama
  description     String?
  referenceNo     String?
  
  // Eşleştirme
  isMatched       Boolean  @default(false)
  matchedCaseId   String?
  matchedCollectionId String?
  matchedAt       DateTime?
  matchedById     String?
  
  // Banka Verisi
  bankReferenceId String?  // Bankanın verdiği referans
  rawData         Json?    // Ham banka verisi
  
  // Meta
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // İlişkiler
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id])

  @@index([tenantId])
  @@index([bankAccountId])
  @@index([transactionDate])
  @@index([isMatched])
  @@index([matchedCaseId])
}

model BankIntegrationLog {
  id              String   @id @default(cuid())
  tenantId        String
  bankAccountId   String?
  
  // İşlem Bilgileri
  action          String   // SYNC, TRANSFER, BALANCE_CHECK
  provider        String   // garanti, akbank, isbank, vb.
  
  // Sonuç
  status          String   @default("PENDING") // PENDING, SUCCESS, FAILED
  transactionCount Int?
  errorCode       String?
  errorMessage    String?
  
  // Veri
  requestData     Json?
  responseData    Json?
  
  // Tarihler
  startedAt       DateTime @default(now())
  completedAt     DateTime?
  
  @@index([tenantId])
  @@index([bankAccountId])
  @@index([status])
  @@index([startedAt])
}


// ==================== İHTİYATİ HACİZ MODÜLÜ ====================

// İhtiyati Haciz Kararı Durumu
enum PrecautionaryOrderStatus {
  DRAFT           // Taslak (henüz karar alınmadı)
  DECIDED         // Karar alındı
  APPLIED         // Uygulandı
  LIFTED          // Kaldırıldı
  EXPIRED         // Süresi doldu
  REJECTED        // Reddedildi
}

// Teminat Türü
enum SecurityDepositType {
  NAKIT           // Nakit teminat
  TEMINAT_MEKTUBU // Banka teminat mektubu
  GAYRIMENKUL     // Gayrimenkul ipoteği
  KEFALET         // Kefalet
  DIGER           // Diğer
}

// İhtiyati Haciz Kararı
model PrecautionaryOrder {
  id                    String                    @id @default(cuid())
  tenantId              String
  caseId                String
  case                  Case                      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // Karar Türü
  orderType             String                    @default("IHTIYATI_HACIZ") // IHTIYATI_HACIZ, IHTIYATI_TEDBIR
  
  // Mahkeme Bilgileri
  courtName             String                    // Mahkeme adı
  courtCity             String?                   // Mahkeme ili
  decisionDate          DateTime                  // Karar tarihi
  decisionNo            String?                   // Esas/Karar numarası
  
  // Kapsam
  scopeNote             String?                   // Hangi alacak/borçlular için
  coveredDebtorIds      String[]                  // Kapsanan borçlu ID'leri
  
  // Teminatlı Tutar
  securedAmount         Decimal                   @db.Decimal(15, 2)
  currency              String                    @default("TRY")
  
  // Teminat Bilgileri
  requiresSecurityDeposit Boolean                 @default(false)
  securityDepositAmount Decimal?                  @db.Decimal(15, 2)
  securityDepositType   SecurityDepositType?
  securityDepositNote   String?                   // Teminat açıklaması
  securityDepositPaidAt DateTime?                 // Teminat yatırma tarihi
  
  // Durum
  status                PrecautionaryOrderStatus  @default(DRAFT)
  appliedAt             DateTime?                 // Uygulanma tarihi
  liftedAt              DateTime?                 // Kaldırılma tarihi
  liftReason            String?                   // Kaldırılma nedeni
  expiresAt             DateTime?                 // Son geçerlilik tarihi
  
  // Belgeler
  decisionDocumentId    String?                   // Karar belgesi (CaseDocument referansı)
  
  // Meta
  notes                 String?
  metadata              Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt
  createdById           String?

  // İlişkiler
  costs                 PrecautionaryCost[]

  @@index([tenantId])
  @@index([caseId])
  @@index([status])
  @@index([decisionDate])
}

// İhtiyati Haciz Masraf Kalemi
model PrecautionaryCost {
  id                    String                    @id @default(cuid())
  tenantId              String
  precautionaryOrderId  String
  precautionaryOrder    PrecautionaryOrder        @relation(fields: [precautionaryOrderId], references: [id], onDelete: Cascade)
  
  // Kalem Türü
  costType              PrecautionaryCostType     // HARC, POSTA, VEKALET, TEMINAT, YEDIEMIN, DIGER
  
  // Tutar
  amount                Decimal                   @db.Decimal(15, 2)
  currency              String                    @default("TRY")
  
  // Açıklama
  description           String?
  label                 String?                   // Özet panelde görünecek etiket
  
  // Takipte Talep
  isClaimedInEnforcement Boolean                  @default(true)  // Ana takipte talep ediliyor mu
  claimItemId           String?                   // Bağlı ClaimItem ID'si (talep ediliyorsa)
  
  // Durum
  isPaid                Boolean                   @default(false)
  paidAt                DateTime?
  paidAmount            Decimal?                  @db.Decimal(15, 2)
  
  // Sıralama
  sortOrder             Int                       @default(0)
  
  // Meta
  metadata              Json?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  @@index([tenantId])
  @@index([precautionaryOrderId])
  @@index([costType])
}

// İhtiyati Haciz Masraf Türü
enum PrecautionaryCostType {
  HARC              // İhtiyati Haciz Harcı
  POSTA             // Tebligat/Posta Gideri
  VEKALET           // Vekalet Ücreti
  TEMINAT           // Teminat Masrafı
  YEDIEMIN          // Yediemin Ücreti
  BILIRKISI         // Bilirkişi Ücreti
  MUHAFAZA          // Muhafaza Gideri
  DIGER             // Diğer Masraflar
}

// ==================== ZAMANAŞIMI RİSK LOG ====================

// Zamanaşımı Risk Logu - Uyarı gösterildiğinde ve kullanıcı kararı kaydedilir
model LimitationRiskLog {
  id                String              @id @default(cuid())
  tenantId          String
  userId            String              // Uyarıyı gören kullanıcı
  caseId            String?             // İlişkili dosya (varsa)
  
  // Risk Bilgileri
  riskType          String              @default("LIMITATION") // LIMITATION
  level             LimitationLevel     // GREEN, YELLOW, RED, UNKNOWN
  
  // Alacak Bilgileri
  claimTypeCode     String              // TBK_10, KAMB_BONO_ASIL, vb.
  role              String?             // Borçlu rolü (ASIL_BORCLU, CIRANTA, vb.)
  
  // Tarih Hesaplamaları
  startDateInput    DateTime?           // Kullanıcının girdiği başlangıç tarihi
  baseStartUsed     DateTime?           // Hesaplamada kullanılan tarih
  expiryDate        DateTime?           // Hesaplanan bitiş tarihi
  daysLeft          Int?                // Kalan gün sayısı
  
  // Kullanıcı Kararı
  ackAction         LimitationAckAction? // PROCEED, BACK
  ackAt             DateTime?           // Karar zamanı
  
  // Meta
  metadata          Json?               // Ek bilgiler
  createdAt         DateTime            @default(now())

  @@index([tenantId])
  @@index([caseId])
  @@index([userId])
  @@index([level])
  @@index([createdAt])
}

// Zamanaşımı Seviyesi
enum LimitationLevel {
  GREEN     // Süre yeterli
  YELLOW    // Süre yaklaşıyor
  RED       // Süre dolmuş
  UNKNOWN   // Hesaplanamadı
}

// Kullanıcı Karar Aksiyonu
enum LimitationAckAction {
  PROCEED   // Devam Et
  BACK      // Geri Dön
}

// ============================================
// MASRAF OTOMASYON SİSTEMİ
// ============================================

// Masraf Paketi Tanımları (UYAP_PRE, RE_TEBLIGAT, HACIZ vb.)
model CostPackage {
  id          String   @id @default(cuid())
  tenantId    String?  // null = sistem paketi (tüm tenant'lar için)
  
  code        String   // UYAP_PRE, RE_TEBLIGAT, HACIZ, SATIS, KIYMET_TAKDIRI
  name        String   // "UYAP Öncesi / Takip Açılış Masrafları"
  description String?
  
  // Hangi takip türleri için geçerli (null = tümü)
  caseTypes   Json?    // ["GENERAL_EXECUTION", "CHECK", "BOND"] veya null
  
  // Sıralama ve durum
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false) // Sistem paketi (silinemez)
  
  // İlişkili mesaj şablonu
  messageTemplateCode String? // TPL_UYAP_PRE, TPL_RE_TEBLIGAT
  
  items       CostPackageItem[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([code])
  @@index([isActive])
}

// Masraf Paketi Kalemleri
model CostPackageItem {
  id          String   @id @default(cuid())
  packageId   String
  package     CostPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  
  // Kalem Bilgileri
  itemCode    String   // BASVURMA_HARCI, PESIN_HARC, TEBLIGAT_GIDERI
  label       String   // "Başvurma Harcı", "Peşin Harç"
  description String?
  
  // Tutar
  defaultAmount Decimal @db.Decimal(15, 2) // Varsayılan tutar
  currency    String   @default("TRY")
  
  // Hesaplama Kuralı (opsiyonel)
  // Örn: {"type":"per_unit", "unitAmount":15.00, "multiplier":"debtorCount"}
  // Örn: {"type":"percentage", "rate":0.005, "base":"principalAmount"}
  calcRule    Json?
  
  // Düzenlenebilirlik
  isEditable  Boolean  @default(true) // Avukat değiştirebilir mi
  isRequired  Boolean  @default(true) // Zorunlu kalem mi
  
  // Sıralama
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([packageId])
  @@index([itemCode])
}

// Dosya Masraf Bakiyesi (1:1 Case ile)
model CaseBalance {
  id          String   @id @default(cuid())
  tenantId    String
  caseId      String   @unique
  case        Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // Bakiye
  balance     Decimal  @db.Decimal(15, 2) @default(0)
  currency    String   @default("TRY")
  
  // Eşik değeri (düşük bakiye uyarısı için)
  lowThreshold Decimal? @db.Decimal(15, 2)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  ledger      BalanceLedger[]

  @@index([tenantId])
  @@index([caseId])
}

// Bakiye Hareketleri (Kredi/Debit)
model BalanceLedger {
  id          String   @id @default(cuid())
  tenantId    String
  caseBalanceId String
  caseBalance CaseBalance @relation(fields: [caseBalanceId], references: [id], onDelete: Cascade)
  
  // Hareket Tipi
  type        BalanceLedgerType
  
  // Tutar (pozitif = kredi, negatif = debit)
  amount      Decimal  @db.Decimal(15, 2)
  currency    String   @default("TRY")
  
  // Kaynak
  source      String   // "expense_request:xxx", "operation:haciz", "manual_adjust"
  sourceId    String?  // İlgili kayıt ID
  
  // Açıklama
  description String?
  
  // Oluşturan
  createdById String?
  
  createdAt   DateTime @default(now())

  @@index([tenantId])
  @@index([caseBalanceId])
  @@index([type])
  @@index([createdAt])
}

enum BalanceLedgerType {
  CREDIT      // Avans/ödeme geldi
  DEBIT       // Masraf yapıldı
  ADJUST      // Manuel düzeltme
  REFUND      // İade
}

// Aşama Tetikleyici Kuralları
model StageEventRule {
  id          String   @id @default(cuid())
  tenantId    String?  // null = sistem kuralı
  
  // Event Kodu
  eventCode   String   // EVT_UYAP_SEND_CLICKED, EVT_TEBLIGAT_RETURNED, EVT_HACIZ_INIT
  
  // Tetiklenecek Paket
  packageCode String?  // UYAP_PRE, RE_TEBLIGAT, HACIZ (null = operasyon)
  
  // Aksiyon Tipi
  actionType  StageActionType
  
  // Kilit Kuralı
  hardBlock   Boolean  @default(false) // true = işlemi tamamen engeller
  
  // Minimum bakiye gereksinimi (DEBIT_FROM_BALANCE için)
  minBalanceRequired Decimal? @db.Decimal(15, 2)
  
  // İlişkili mesaj şablonu
  messageTemplateCode String?
  
  // Öncelik (düşük = önce çalışır)
  priority    Int      @default(50)
  
  // Durum
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([eventCode])
  @@index([isActive])
}

enum StageActionType {
  CREATE_EXPENSE_REQUEST  // Masraf talebi oluştur
  DEBIT_FROM_BALANCE      // Bakiyeden düş
  SUGGEST_ONLY            // Sadece öneri göster
  BLOCK_UNTIL_PAID        // Ödeme gelene kadar engelle
}

// Stage Event Kodları (referans için enum)
enum StageEventCode {
  EVT_UYAP_SEND_CLICKED     // UYAP'a Gönder tıklandı
  EVT_TEBLIGAT_REQUESTED    // Tebligat talebi
  EVT_TEBLIGAT_RETURNED     // Tebligat iade
  EVT_NEW_ADDRESS_ADDED     // Yeni adres eklendi
  EVT_HACIZ_INIT            // Haciz başlat
  EVT_HACIZ_EXECUTED        // Haciz yapıldı
  EVT_SALE_INIT             // Satış başlat
  EVT_VALUATION_INIT        // Kıymet takdiri başlat
  EVT_BALANCE_LOW           // Bakiye düşük
}


// ==================== ADDRESS DISCOVERY MODULE ====================

// Müvekkil Bilgi Talebi Durumu
enum ClientInfoRequestStatus {
  SENT          // Email gönderildi
  RESPONDED     // Yanıt alındı
  NO_RESPONSE   // Yanıt yok (timeout)
}

// Müvekkil Bilgi Talebi
model ClientInfoRequest {
  id            String   @id @default(cuid())
  tenantId      String
  caseId        String
  clientId      String
  debtorId      String?  // Belirli borçlu için (opsiyonel)
  
  emailTo       String
  emailSubject  String
  emailBody     String   @db.Text
  
  status        ClientInfoRequestStatus @default(SENT)
  sentAt        DateTime @default(now())
  respondedAt   DateTime?
  responseNotes String?  @db.Text
  
  // Hatırlatma
  reminderSentAt DateTime?
  reminderCount  Int      @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  client        Client   @relation(fields: [clientId], references: [id])
  debtor        Debtor?  @relation(fields: [debtorId], references: [id])
  
  @@index([tenantId])
  @@index([caseId])
  @@index([clientId])
  @@index([status])
  @@index([sentAt])
}

// UYAP Sorgu Türü
enum UyapQueryType {
  NUFUS_ADRES      // AA - Nüfus + Aile + Adres
  SGK              // AB - SGK işyeri
  TICARET_ODASI    // AF - Ticaret Odası
  VERGI_DAIRESI    // AJ - Vergi Dairesi
  GSM              // AR - GSM Operatörleri
  GUMRUK           // AL - Gümrük
  ORTAKLAR         // AH - Şirket ortakları
  AILE             // AN - Aile üyeleri
  ORTAK_DETAY      // AP - Ortak detayları
}

// UYAP Sorgu Durumu
enum UyapQueryStatus {
  PENDING       // Sorgu gönderildi, yanıt bekleniyor
  COMPLETED     // Yanıt alındı
  FAILED        // Sorgu başarısız
  NO_RESULT     // Sonuç bulunamadı
}

// UYAP Sorguları
model UyapQuery {
  id            String   @id @default(cuid())
  tenantId      String
  caseDebtorId  String
  
  queryType     UyapQueryType
  queryCode     String   // AA, AB, AF, AJ, AR, AL, AH, AN, AP
  
  status        UyapQueryStatus @default(PENDING)
  requestedAt   DateTime @default(now())
  requestedBy   String   // userId
  respondedAt   DateTime?
  
  // Tetikleme türü
  triggeredBy   String   @default("MANUAL") // MANUAL, AUTO
  
  // Sorgu sonucu (JSON)
  response      Json?
  errorMessage  String?
  
  // Bulunan adresler
  addressesFound Int     @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  caseDebtor    CaseDebtor  @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  requestedByUser User      @relation("UyapQueryRequester", fields: [requestedBy], references: [id])
  
  @@index([tenantId])
  @@index([caseDebtorId])
  @@index([queryType])
  @@index([status])
  @@index([requestedAt])
}

// Kurum Türü
enum InstitutionType {
  SGK             // Sosyal Güvenlik Kurumu
  VERGI_DAIRESI   // Vergi Dairesi
  TICARET_SICILI  // Ticaret Sicili Müdürlüğü
  BELEDIYE        // Belediye
  TAPU            // Tapu Müdürlüğü
  NUFUS           // Nüfus Müdürlüğü
}

// Kurum Yazısı Durumu
enum InstitutionLetterStatus {
  DRAFT         // Taslak
  SENT          // Gönderildi
  RESPONDED     // Yanıt alındı
  NO_RESPONSE   // Yanıt yok
}

// Kurum Yazıları
model InstitutionLetter {
  id            String   @id @default(cuid())
  tenantId      String
  caseDebtorId  String
  
  institution   InstitutionType
  letterType    String   // Yazı türü (adres sorgu, haciz ihbarnamesi, vs.)
  
  // Yazı içeriği
  subject       String
  body          String   @db.Text
  documentUrl   String?  // Oluşturulan Word dosyası
  
  status        InstitutionLetterStatus @default(DRAFT)
  sentAt        DateTime?
  sentMethod    String?  // Posta, KEP, Elden
  respondedAt   DateTime?
  responseNotes String?  @db.Text
  
  // Bulunan bilgiler
  addressesFound Int     @default(0)
  
  createdById   String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  caseDebtor    CaseDebtor  @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  createdByUser User?       @relation("InstitutionLetterCreator", fields: [createdById], references: [id])
  
  @@index([tenantId])
  @@index([caseDebtorId])
  @@index([institution])
  @@index([status])
  @@index([sentAt])
}

// Araştırma Durumu
enum AddressResearchStatus {
  NOT_STARTED   // Başlamadı
  IN_PROGRESS   // Devam ediyor
  COMPLETED     // Tamamlandı
  EXHAUSTED     // Tüm kaynaklar tükendi
}

// Adres Araştırma Durumu
model AddressResearch {
  id            String   @id @default(cuid())
  tenantId      String
  caseDebtorId  String   @unique
  
  status        AddressResearchStatus @default(NOT_STARTED)
  
  // Araştırma adımları
  clientInfoRequested   Boolean @default(false)
  uyapQueriesCompleted  Boolean @default(false)
  crossFileChecked      Boolean @default(false)
  institutionLettersSent Boolean @default(false)
  
  // İstatistikler
  totalAddressesFound   Int     @default(0)
  failedNotifications   Int     @default(0)
  
  // Tarihler
  startedAt     DateTime?
  completedAt   DateTime?
  
  // Son öneri
  lastSuggestion String?
  lastSuggestionAt DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  caseDebtor    CaseDebtor  @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  
  @@index([tenantId])
  @@index([status])
  @@index([startedAt])
}


// ==================== ASSET QUERY MODULE ====================

// Malvarlığı Sorgu Kaydı
model AssetQuery {
  id            String   @id @default(cuid())
  tenantId      String
  caseDebtorId  String
  
  // Sorgu Türü
  queryType     AssetQueryType
  
  // Durum
  status        AssetQueryJobStatus @default(QUEUED)
  
  // Talep Bilgileri
  requestedAt   DateTime @default(now())
  requestedBy   String   // userId
  reason        String?  // Sorgu sebebi
  
  // İşlem Bilgileri
  startedAt     DateTime?
  completedAt   DateTime?
  
  // Sonuç
  result        AssetQueryStatus?  // YES, NO, UNKNOWN, ERROR
  resultData    Json?              // Detaylı sonuç verisi
  errorMessage  String?
  
  // Idempotency
  idempotencyKey String?  @unique
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  caseDebtor    CaseDebtor  @relation(fields: [caseDebtorId], references: [id], onDelete: Cascade)
  requestedByUser User      @relation("AssetQueryRequester", fields: [requestedBy], references: [id])
  
  @@index([tenantId])
  @@index([caseDebtorId])
  @@index([queryType])
  @@index([status])
  @@index([requestedAt])
}

// Sorgu Job Durumu
enum AssetQueryJobStatus {
  QUEUED        // Kuyruğa alındı
  PROCESSING    // İşleniyor
  COMPLETED     // Tamamlandı
  FAILED        // Başarısız
  CANCELLED     // İptal edildi
}
