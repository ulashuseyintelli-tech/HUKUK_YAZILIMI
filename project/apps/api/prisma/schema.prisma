}

// ==================== VALİDASYON GATE SİSTEMİ ====================

// Validasyon sonuçları - Her gate geçişinde kaydedilir
model ValidationResult {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  
  // Gate Bilgisi
  gateId          ValidationGate   // GATE_1, GATE_2, GATE_3, GATE_4
  gateName        String           // "Takip Oluşturma", "Örnek 1 Üretimi", vb.
  
  // Sonuç
  isValid         Boolean          // Geçti mi
  validatedAt     DateTime         @default(now())
  
  // Hatalar ve Uyarılar (JSON array)
  // [{id: "no_principal", severity: "ERROR", message: "..."}]
  errors          Json?
  warnings        Json?
  
  // Validasyon Detayları
  checkedFields   Json?            // Kontrol edilen alanlar
  missingFields   Json?            // Eksik alanlar
  
  // Kullanıcı
  validatedById   String?
  
  // Meta
  metadata        Json?
  createdAt       DateTime         @default(now())

  @@index([tenantId])
  @@index([caseId])
  @@index([gateId])
  @@index([isValid])
  @@index([validatedAt])
}

enum ValidationGate {
  GATE_1_CASE_CREATION      // Takip oluşturma
  GATE_2_ORNEK1_GENERATION  // Örnek 1 üretimi
  GATE_3_SERVICE_OF_PROCESS // Tebligat
  GATE_4_UYAP_INTEGRATION   // UYAP gönderimi
}

// Adres eksikliği task'ı - Gate 3'te adres yoksa oluşturulur
model AddressMissingTask {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  debtorId        String
  
  // Durum
  status          AddressTaskStatus @default(PENDING)
  
  // Önerilen Yöntemler
  suggestedMethods Json?           // ["MERNIS", "TICARET_SICIL", "SGK", "MANUEL"]
  
  // Çözüm
  resolvedAt      DateTime?
  resolvedById    String?
  resolutionMethod String?         // Hangi yöntemle çözüldü
  foundAddressId  String?          // Bulunan adres ID
  
  // Meta
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([debtorId])
  @@index([status])
}

enum AddressTaskStatus {
  PENDING         // Bekliyor
  IN_PROGRESS     // Araştırılıyor
  RESOLVED        // Çözüldü
  CANCELLED       // İptal
}


// ==================== E-IMZA LOGLARI ====================

model EsignLog {
