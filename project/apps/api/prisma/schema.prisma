// MASRAF OTOMASYON SİSTEMİ
// ============================================

// Masraf Paketi Tanımları (UYAP_PRE, RE_TEBLIGAT, HACIZ vb.)
model CostPackage {
  id       String  @id @default(cuid())
  tenantId String? // null = sistem paketi (tüm tenant'lar için)

  code        String // UYAP_PRE, RE_TEBLIGAT, HACIZ, SATIS, KIYMET_TAKDIRI
  name        String // "UYAP Öncesi / Takip Açılış Masrafları"
  description String?

  // Hangi takip türleri için geçerli (null = tümü)
  caseTypes Json? // ["GENERAL_EXECUTION", "CHECK", "BOND"] veya null

  // Sıralama ve durum
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
  isSystem  Boolean @default(false) // Sistem paketi (silinemez)

  // İlişkili mesaj şablonu
  messageTemplateCode String? // TPL_UYAP_PRE, TPL_RE_TEBLIGAT

  items CostPackageItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([code])
  @@index([isActive])
}

// Masraf Paketi Kalemleri
model CostPackageItem {
  id        String      @id @default(cuid())
  packageId String
  package   CostPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)

  // Kalem Bilgileri
  itemCode    String // BASVURMA_HARCI, PESIN_HARC, TEBLIGAT_GIDERI
  label       String // "Başvurma Harcı", "Peşin Harç"
  description String?

  // Tutar
  defaultAmount Decimal @db.Decimal(15, 2) // Varsayılan tutar
  currency      String  @default("TRY")

  // Hesaplama Kuralı (opsiyonel)
  // Örn: {"type":"per_unit", "unitAmount":15.00, "multiplier":"debtorCount"}
  // Örn: {"type":"percentage", "rate":0.005, "base":"principalAmount"}
  calcRule Json?

  // Düzenlenebilirlik
  isEditable Boolean @default(true) // Avukat değiştirebilir mi
  isRequired Boolean @default(true) // Zorunlu kalem mi

  // Sıralama
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([packageId])
  @@index([itemCode])
}

// Dosya Masraf Bakiyesi (1:1 Case ile)
model CaseBalance {
  id       String @id @default(cuid())
  tenantId String
  caseId   String @unique
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Bakiye
  balance  Decimal @default(0) @db.Decimal(15, 2)
  currency String  @default("TRY")

  // Eşik değeri (düşük bakiye uyarısı için)
  lowThreshold Decimal? @db.Decimal(15, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ledger BalanceLedger[]

  @@index([tenantId])
  @@index([caseId])
}

// Bakiye Hareketleri (Kredi/Debit)
model BalanceLedger {
  id            String      @id @default(cuid())
  tenantId      String
  caseBalanceId String
  caseBalance   CaseBalance @relation(fields: [caseBalanceId], references: [id], onDelete: Cascade)

  // Hareket Tipi
  type BalanceLedgerType

  // Tutar (pozitif = kredi, negatif = debit)
  amount   Decimal @db.Decimal(15, 2)
  currency String  @default("TRY")

  // Kaynak
  source   String // "expense_request:xxx", "operation:haciz", "manual_adjust"
  sourceId String? // İlgili kayıt ID

  // Açıklama
  description String?

  // Oluşturan
  createdById String?

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([caseBalanceId])
  @@index([type])
  @@index([createdAt])
}

enum BalanceLedgerType {
  CREDIT // Avans/ödeme geldi
  DEBIT // Masraf yapıldı
  ADJUST // Manuel düzeltme
  REFUND // İade
}

// Aşama Tetikleyici Kuralları
model StageEventRule {
  id       String  @id @default(cuid())
  tenantId String? // null = sistem kuralı

  // Event Kodu
  eventCode String // EVT_UYAP_SEND_CLICKED, EVT_TEBLIGAT_RETURNED, EVT_HACIZ_INIT

  // Tetiklenecek Paket
  packageCode String? // UYAP_PRE, RE_TEBLIGAT, HACIZ (null = operasyon)

  // Aksiyon Tipi
  actionType StageActionType

  // Kilit Kuralı
  hardBlock Boolean @default(false) // true = işlemi tamamen engeller

  // Minimum bakiye gereksinimi (DEBIT_FROM_BALANCE için)
  minBalanceRequired Decimal? @db.Decimal(15, 2)

  // İlişkili mesaj şablonu
  messageTemplateCode String?

  // Öncelik (düşük = önce çalışır)
  priority Int @default(50)

  // Durum
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([eventCode])
  @@index([isActive])
}

enum StageActionType {
  CREATE_EXPENSE_REQUEST // Masraf talebi oluştur
  DEBIT_FROM_BALANCE // Bakiyeden düş
  SUGGEST_ONLY // Sadece öneri göster
  BLOCK_UNTIL_PAID // Ödeme gelene kadar engelle
}

// Stage Event Kodları (referans için enum)
enum StageEventCode {
  EVT_UYAP_SEND_CLICKED // UYAP'a Gönder tıklandı
  EVT_TEBLIGAT_REQUESTED // Tebligat talebi
  EVT_TEBLIGAT_RETURNED // Tebligat iade
  EVT_NEW_ADDRESS_ADDED // Yeni adres eklendi
  EVT_HACIZ_INIT // Haciz başlat
  EVT_HACIZ_EXECUTED // Haciz yapıldı
  EVT_SALE_INIT // Satış başlat
  EVT_VALUATION_INIT // Kıymet takdiri başlat
  EVT_BALANCE_LOW // Bakiye düşük
}

