// ==================== ALACAK KALEMLERİ SİSTEMİ ====================

// Alacak Kalemi - Dosyadaki her bir alacak bileşeni
model ClaimItem {
  id       String @id @default(cuid())
  tenantId String
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Kalem Türü
  itemType ClaimItemType // PRINCIPAL, INTEREST, EXPENSE, FEE, ATTORNEY_FEE, PENALTY, TAX, OTHER

  // ⭐ KAYNAK SÜREÇ - Ana takip mi, ihtiyati haciz mi?
  sourceProcess   ClaimSourceProcess @default(MAIN_ENFORCEMENT) // MAIN_ENFORCEMENT, PRECAUTIONARY
  sourceProcessId String? // İhtiyati haciz kararı ID'si (sourceProcess=PRECAUTIONARY ise)

  // ⭐ TAKİP MUHASEBESİ - Üç Tutar Sistemi
  originalAmount  Decimal @db.Decimal(15, 2) // Evraktan gelen orijinal tutar (örn: çek bedeli 10.000)
  demandedAmount  Decimal @db.Decimal(15, 2) // Bu takipte talep edilen tutar (örn: 8.000)
  collectedAmount Decimal @default(0) @db.Decimal(15, 2) // Tahsil edilen tutar (TBK 100 ile dağıtılır)

  // Eski alan (geriye uyumluluk için korunuyor, yeni kayıtlarda demandedAmount kullanılacak)
  amount   Decimal @db.Decimal(15, 2)
  currency String  @default("TRY")

  // Kaynak Belge
  sourceDocumentId   String? // CaseDocument referansı
  sourceDocumentType DocumentSourceType? // FATURA, CEK, SENET, KIRA, SOZLESME, ILAM, DIGER

  // Faiz Bilgileri (itemType = INTEREST için)
  interestType      InterestType? // YASAL, TICARI, AVANS, OZEL
  interestRate      Decimal?      @db.Decimal(5, 2)
  interestStartDate DateTime?
  interestEndDate   DateTime?

  // Vade/Tarih Bilgileri
  dueDate   DateTime? // Vade tarihi
  issueDate DateTime? // Düzenleme tarihi

  // Açıklama
  description String?
  referenceNo String? // Fatura no, çek no, senet no vb.
  label       String? // Özet panelde görünecek etiket

  // Hesaplama
  isCalculated Boolean   @default(false) // Otomatik hesaplandı mı
  calculatedAt DateTime?
  isVirtual    Boolean   @default(false) // Sanal kalem mi (sadece özette gösterilir)

  // Borçlu Sorumluluğu
  isAllDebtorsLiable Boolean  @default(true) // Tüm borçlular sorumlu mu
  liableDebtorIds    String[] // Sorumlu borçlu ID'leri (isAllDebtorsLiable=false ise)

  // Durum
  status ClaimItemStatus @default(ACTIVE)

  // Sıralama
  sortOrder Int     @default(0)
  bucket    String? // Özet panelde hangi gruba ait (principal_bucket, fees_bucket vb.)

  // Meta
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  // İlişkiler
  ledgerAllocations LedgerAllocation[]

  @@index([tenantId])
  @@index([caseId])
  @@index([itemType])
  @@index([status])
  @@index([bucket])
}

// ⭐ TAKİP DEFTERİ - Tahsilat ve Düzeltme Kayıtları (TBK 100 / BK 84)
model LedgerEntry {
  id       String @id @default(cuid())
  tenantId String
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

  // Kayıt Türü
  entryType LedgerEntryType // PAYMENT, ADJUSTMENT, WAIVER, REFUND

  // Tutar
  amount   Decimal @db.Decimal(15, 2)
  currency String  @default("TRY")

  // Tarih
  entryDate     DateTime  @default(now())
  effectiveDate DateTime? // İşlemin geçerli olduğu tarih

  // Açıklama
  description String?
  referenceNo String? // Makbuz no, dekont no vb.

  // Kaynak
  sourceType String? // BANKA, KASA, UYAP, MANUEL
  sourceId   String? // Banka işlem ID'si vb.

  // Dağıtım (TBK 100 sırasına göre)
  allocations LedgerAllocation[]

  // Durum
  status LedgerEntryStatus @default(CONFIRMED)

  // Meta
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?

  @@index([tenantId])
  @@index([caseId])
  @@index([entryType])
  @@index([entryDate])
}

// Tahsilat Dağıtımı - Hangi kaleme ne kadar düşüldü
model LedgerAllocation {
  id            String      @id @default(cuid())
  ledgerEntryId String
  ledgerEntry   LedgerEntry @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
  claimItemId   String
  claimItem     ClaimItem   @relation(fields: [claimItemId], references: [id], onDelete: Cascade)

  // Dağıtılan Tutar
  amount Decimal @db.Decimal(15, 2)

  // Sıra (TBK 100 mahsup sırası)
  allocationOrder Int

  // Meta
  createdAt DateTime @default(now())

  @@index([ledgerEntryId])
  @@index([claimItemId])
}

// Defter Kayıt Türü
enum LedgerEntryType {
  PAYMENT // Tahsilat
  ADJUSTMENT // Düzeltme
  WAIVER // Feragat
  REFUND // İade
  TRANSFER // Virman
}

// Defter Kayıt Durumu
enum LedgerEntryStatus {
  PENDING // Beklemede
  CONFIRMED // Onaylandı
  CANCELLED // İptal Edildi
}

// Alacak Kalemi Türü
enum ClaimItemType {
  PRINCIPAL // Asıl Alacak (Ana Para)
  INTEREST // Faiz
  PRE_INTEREST // Takip Öncesi Faiz
  POST_INTEREST // Takip Sonrası Faiz
  EXPENSE // Masraf
  FEE // Harç
  ATTORNEY_FEE // Vekalet Ücreti
  PENALTY // Ceza/Tazminat
  CHECK_PENALTY // Karşılıksız Çek Tazminatı
  CONTRACTUAL_PENALTY // Cezai Şart
  TAX_KDV // KDV
  TAX_BSMV // BSMV
  TAX_KKDF // KKDF
  OTHER // Diğer
}

// Alacak Kalemi Kaynak Süreci
enum ClaimSourceProcess {
  MAIN_ENFORCEMENT // Ana icra takibi
  PRECAUTIONARY // İhtiyati haciz
}

// Kaynak Belge Türü
enum DocumentSourceType {
  FATURA // Fatura
  CEK // Çek
  SENET // Senet/Bono
  KIRA // Kira Sözleşmesi
  SOZLESME // Sözleşme
  ILAM // Mahkeme İlamı
  KARAR // Mahkeme Kararı
  BORC_SENEDI // Borç Senedi
  KREDI // Kredi Sözleşmesi
  DIGER // Diğer
}

// Alacak Kalemi Durumu
enum ClaimItemStatus {
