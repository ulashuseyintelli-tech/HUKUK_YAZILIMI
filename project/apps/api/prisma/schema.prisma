  OFIS_KATIBI       // Ofis Katibi
  ADLI_KATIP        // Adli Katip (adliye koordinasyonu)
  SEKRETER          // Sekreter
  MUHASEBE          // Muhasebe
  ARSIV             // Arşiv Sorumlusu
  DIGER             // Diğer
}

// Ofis Personeli (Avukat hariç tüm çalışanlar)
model StaffMember {
  id          String     @id @default(cuid())
  tenantId    String
  officeId    String?
  
  // Kişisel Bilgiler
  firstName   String
  lastName    String
  tckn        String?    // TC Kimlik No
  email       String?
  phone       String?
  
  // Personel Türü
  staffType   StaffType
  
  // Genel Yetkiler (büro genelinde varsayılan)
  canCreateCase        Boolean @default(false)  // Dosya oluşturabilir
  canEditCase          Boolean @default(false)  // Dosya düzenleyebilir
  canGenerateDocuments Boolean @default(false)  // Belge taslağı hazırlayabilir
  canApproveDocuments  Boolean @default(false)  // Belge onaylayabilir
  canSeeFinance        Boolean @default(false)  // Muhasebe modülünü görebilir
  canApproveFinance    Boolean @default(false)  // Muhasebe işlemi onaylayabilir
  canSendNotifications Boolean @default(false)  // Tebligat gönderebilir
  isDefaultForNewCases Boolean @default(false)  // Yeni dosyalarda otomatik seç
  
  isActive    Boolean    @default(true)
  sortOrder   Int        @default(0)
  
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  caseAssignments CaseStaff[]

  @@index([tenantId])
  @@index([officeId])
  @@index([staffType])
  @@index([isActive])
}

// Dosya Bazlı Personel Ataması
model CaseStaff {
  id            String      @id @default(cuid())
  caseId        String
  case          Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  
  // Bu dosyadaki rol
  roleOnCase    String      // STAJYER, KONTROL, YAZI_ISLERI, MUHASEBE, TEBLIGAT, ARSIV
  
  // Bu dosyadaki yetkiler (personelin genel yetkilerini override edebilir)
  canEdit       Boolean     @default(false)  // Dosya içeriğini düzenleyebilir
  canApprove    Boolean     @default(false)  // İşlem onaylayabilir
  canView       Boolean     @default(true)   // Sadece görüntüleyebilir
  
  // Bildirimler
  receiveNotifications Boolean @default(true)
  
  // Atama bilgileri
  assignedAt    DateTime    @default(now())
  assignedById  String?     // Kim atadı
  notes         String?     // Özel notlar
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([caseId, staffMemberId])
  @@index([caseId])
  @@index([staffMemberId])
  @@index([roleOnCase])
}

// ==================== MÜVEKKİL İLETİŞİM SİSTEMİ ====================

// Müvekkil Bildirimleri (E-posta, SMS, WhatsApp logu)
model ClientNotification {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseId        String?  // İlgili dosya (opsiyonel)
  
  // İletişim Kanalı
  channel       String   // EMAIL, SMS, WHATSAPP
  
  // Bildirim Türü
  type          String   // MASRAF_ISTEK, GENEL_BILGILENDIRME, RAPOR, HATIRLATMA, DIGER
  
  // İçerik
  subject       String?  // E-posta konusu
  body          String   @db.Text // Mesaj içeriği
  
  // Durum
  status        String   @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt        DateTime?
  deliveredAt   DateTime?
  errorMessage  String?
  
  // Gönderen
  sentById      String
  
  // Meta
  metadata      Json?    // Ek bilgiler (template id, vs.)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([caseId])
  @@index([channel])
  @@index([type])
  @@index([status])
}

// Portal Bildirimleri (Müvekkil portalında gösterilecek bildirimler)
model PortalNotification {
  id            String   @id @default(cuid())
  clientId      String
  caseId        String?  // İlgili dosya (opsiyonel)
  
  // Bildirim Türü
  type          String   // TAHSILAT, ISLEM, BELGE, DURUM_DEGISIKLIGI, GENEL
  
  // İçerik
  title         String
  message       String
  
  // Durum
  isRead        Boolean  @default(false)
  readAt        DateTime?
  
  // Link (opsiyonel - tıklandığında yönlendirilecek sayfa)
  linkUrl       String?
  
  createdAt     DateTime @default(now())

  @@index([clientId])
  @@index([caseId])
  @@index([isRead])
  @@index([createdAt])
}

// Portal Belgeleri (Müvekkilin portaldan yüklediği belgeler)
model PortalDocument {
  id            String   @id @default(cuid())
  clientId      String
  caseId        String?  // İlgili dosya (opsiyonel)
  tenantId      String
  
  // Belge Bilgileri
  type          String   // VEKALET, KIMLIK, SOZLESME, DIGER
  title         String
  description   String?
  
  // Dosya Bilgileri
  fileName      String
  filePath      String
  fileSize      Int
  mimeType      String
  
  // Durum
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt    DateTime?
  reviewedBy    String?  // User ID
  reviewNote    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([clientId])
  @@index([caseId])
  @@index([tenantId])
  @@index([status])
