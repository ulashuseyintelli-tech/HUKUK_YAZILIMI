// Masraf Talepleri
model ExpenseRequest {
  id            String   @id @default(cuid())
  tenantId      String
  caseId        String
  case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  
  // Paket Bilgisi (otomatik oluşturma için)
  packageCode   String?  // UYAP_PRE, RE_TEBLIGAT, HACIZ (null = manuel)
  
  // Masraf Kalemleri (eski format - geriye uyumluluk)
  items         Json?    // [{type: string, description: string, amount: number}]
  
  // Yeni format - ayrı tablo
  requestItems  ExpenseRequestItem[]
  
  // Tutarlar
  totalSuggested Decimal? @db.Decimal(15, 2) // Sistem önerisi
  totalAmount   Decimal  @db.Decimal(15, 2)  // Final tutar (override sonrası)
  currency      String   @default("TRY")
  
  // Son Ödeme Tarihi
  dueDate       DateTime?
  
  // Durum Makinesi
  status        ExpenseRequestStatus @default(PENDING)
  
  // Gönderim Bilgileri
  sentAt        DateTime?
  sentVia       String?  // EMAIL, SMS, WHATSAPP
  messageTemplateId String? // Kullanılan şablon
  notificationId String? // İlgili ClientNotification
  
  // Gönderim Tercihleri
  sendEmail     Boolean  @default(false)
  sendSms       Boolean  @default(false)
  sendWhatsapp  Boolean  @default(false)
  
  // Render edilmiş mesaj (audit için)
  renderedSubject String?
  renderedBody  String?  @db.Text
  
  // Hatırlatma
  reminderCount Int      @default(0)
  lastReminderAt DateTime?
  
  // Yanıt
  respondedAt   DateTime?
  responseNotes String?
  
  // Ödeme/Dekont
  paidAt        DateTime?
  paidAmount    Decimal? @db.Decimal(15, 2)
  receiptDocId  String?  // Dekont belgesi ID
  paymentMethod String?  // MANUAL, BANK_MATCH, VIRTUAL_POS
  paymentReference String? // Ödeme referans kodu (TB-xxx)
  
  // Oluşturan
  createdById   String
  
  notes         String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([clientId])
  @@index([status])
  @@index([packageCode])
  @@index([createdAt])
  @@index([dueDate])
}

// Masraf Talebi Kalemleri
model ExpenseRequestItem {
  id              String   @id @default(cuid())
  expenseRequestId String
  expenseRequest  ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)
  
  // Kalem Bilgileri
  itemCode        String   // BASVURMA_HARCI, PESIN_HARC, TEBLIGAT_GIDERI
  label           String   // "Başvurma Harcı"
  description     String?
  
  // Tutarlar
  suggestedAmount Decimal  @db.Decimal(15, 2) // Sistem önerisi
  finalAmount     Decimal  @db.Decimal(15, 2) // Avukat girişi (override)
  currency        String   @default("TRY")
  
  // Override Bilgisi
  isEditable      Boolean  @default(true)
  wasOverridden   Boolean  @default(false)
  overrideReason  String?
  overriddenById  String?
  overriddenAt    DateTime?
  
  // Hesaplama Parametreleri (audit için)
  calcParams      Json?    // {"debtorCount": 2, "unitAmount": 15.00}
  
  // Sıralama
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expenseRequestId])
  @@index([itemCode])
}

// Mesaj Şablonları (E-posta, SMS, WhatsApp)
model MessageTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  
  // Şablon Bilgileri
  code        String   // Benzersiz kod: MASRAF_TALEBI, MASRAF_HATIRLATMA, DOSYA_ACILDI, TAHSILAT_BILGI
  name        String   // Görünen ad: "Masraf Talebi", "Hatırlatma"
  description String?  // Açıklama
  
  // Kategori
  category    MessageTemplateCategory
  
  // Kanal
  channel     MessageTemplateChannel @default(EMAIL)
  
  // İçerik
  subject     String?  // E-posta konusu (SMS/WhatsApp için null)
  body        String   @db.Text // Mesaj içeriği
  
  // Kullanılabilir Token'lar (bilgi amaçlı)
  // {{clientName}}, {{caseFileNumber}}, {{executionFileNumber}}, {{executionOfficeName}}
  // {{totalAmount}}, {{dueDate}}, {{items}}, {{lawyerName}}, {{officePhone}}
  availableTokens Json? // ["clientName", "caseFileNumber", ...]
  
  // Ayarlar
  isActive    Boolean  @default(true)
  isSystem    Boolean  @default(false) // Sistem şablonu (silinemez)
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([channel])
  @@index([isActive])
}

// Mesaj Şablonu Kategorisi
enum MessageTemplateCategory {
  CLIENT_INFO       // Müvekkil bilgilendirme (dosya açıldı, durum güncelleme)
  EXPENSE_REQUEST   // Masraf talebi
  EXPENSE_REMINDER  // Masraf hatırlatma
  COLLECTION_INFO   // Tahsilat bildirimi
  DEBTOR_NOTICE     // Borçluya bildirim
  GREETING          // Tebrik mesajları
  OTHER             // Diğer
}

// Mesaj Şablonu Kanalı
enum MessageTemplateChannel {
  EMAIL             // E-posta
  SMS               // SMS
  WHATSAPP          // WhatsApp
}

// ==================== ÖZEL GÜNLER & TEBRİK SİSTEMİ ====================

// Özel Günler (Bayramlar, Anma Günleri, vb.)
model SpecialDay {
  id          String   @id @default(cuid())
  tenantId    String?  // null = sistem geneli, değer = büroya özel
  
  // Gün Bilgileri
  name        String   // Ramazan Bayramı, Kurban Bayramı, 10 Kasım, vb.
  type        String   // RELIGIOUS (Dini), NATIONAL (Milli), MEMORIAL (Anma), CUSTOM (Özel)
  
  // Tarih (yıl olmadan - her yıl tekrarlar)
  month       Int      // 1-12
  day         Int      // 1-31
  
  // Bazı bayramlar değişken tarihli (Hicri takvim)
  isVariable  Boolean  @default(false)  // Değişken tarihli mi
  year        Int?     // Değişken tarihli ise hangi yıl için geçerli
  
  // Mesaj Şablonu
  greetingMessage String?  // Varsayılan tebrik mesajı
  smsMessage      String?  // SMS için kısa mesaj (160 karakter)
  
  // Ayarlar
  isActive    Boolean  @default(true)
  sendGreeting Boolean @default(true)  // Otomatik tebrik gönder
  daysBeforeReminder Int @default(0)   // Kaç gün önce hatırlat
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([month, day])
  @@index([type])
  @@index([isActive])
}

// Tebrik Kuyruğu (Gönderilecek tebrikler)
model GreetingQueue {
  id          String   @id @default(cuid())
  tenantId    String
  
  // Alıcı
  clientId    String
  
  // Tebrik Türü
  type        String   // BIRTHDAY, FOUNDING_ANNIVERSARY, POA_ANNIVERSARY, HOLIDAY, MEMORIAL
  
  // Özel gün referansı (bayram/anma günü için)
  specialDayId String?
  
  // Gönderim
  channel     String   // EMAIL, SMS, BOTH
  scheduledAt DateTime // Gönderilecek tarih/saat
  
  // Mesaj
  subject     String?  // E-posta konusu
  message     String   // Mesaj içeriği
  
  // Durum
  status      String   @default("PENDING") // PENDING, SENT, FAILED, CANCELLED
  sentAt      DateTime?
  errorMessage String?
  
  // İlişkili bildirim
  notificationId String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type])
}

// ==================== TAKVİM & AJANDA ====================

// Takvim Etkinlikleri
model CalendarEvent {
  id            String   @id @default(cuid())
  tenantId      String
  
  // Etkinlik Bilgileri
  title         String
  description   String?
  date          DateTime
  time          String?  // "10:00" formatında
  
  // Tür
  type          String   // DURUSMA, HATIRLATICI, GOREV, DIGER
  
  // İlişkili Dosya (opsiyonel)
  caseId        String?
  
  // Konum
  location      String?
  
  // Durum
  isCompleted   Boolean  @default(false)
  completedAt   DateTime?
  
  // Oluşturan
  createdById   String
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@index([caseId])
  @@index([type])
  @@index([isCompleted])
}

// ==================== HATA KAYITLARI (ERROR LOG) ====================

model ErrorLog {
  id            String   @id @default(cuid())
  tenantId      String?
  
  // Hata Bilgileri
  level         String   // ERROR, WARN, INFO, DEBUG
  source        String   // API, FRONTEND, CRON, UYAP, vb.
  message       String
  stack         String?  // Stack trace
  
  // Bağlam
  endpoint      String?  // API endpoint
  method        String?  // GET, POST, PUT, DELETE
  statusCode    Int?
  
  // Kullanıcı
  userId        String?
  userIp        String?
  userAgent     String?
  
  // Ek Bilgiler
  metadata      Json?    // Request body, params, vb.
  
  // Çözüm Durumu
  isResolved    Boolean  @default(false)
  resolvedAt    DateTime?
  resolvedBy    String?
  resolution    String?
  
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([level])
  @@index([source])
  @@index([createdAt])
  @@index([isResolved])
}

// ==================== DENETİM KAYITLARI (AUDIT LOG) ====================

// Audit Log - Tüm önemli işlemlerin kaydı
model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  
  // İşlem Bilgileri
  action        String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, EXPORT, vb.
  entityType    String   // CASE, CLIENT, POA, USER, vb.
  entityId      String?  // İlgili kaydın ID'si
  
  // Kullanıcı
  userId        String?
  userName      String?
  userIp        String?
  userAgent     String?
  
  // Değişiklik Detayları
  oldValues     Json?    // Eski değerler
  newValues     Json?    // Yeni değerler
  
  // Ek Bilgiler
  description   String?
  metadata      Json?
  
  createdAt     DateTime @default(now())

  @@index([tenantId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([userId])
  @@index([createdAt])
}

// ==================== KAMU KURUMLARI (DETSİS) ====================

// Kamu Kurumu Türleri
enum PublicInstitutionCategory {
  BAKANLIK           // Bakanlıklar
  GENEL_MUDURLUK     // Genel Müdürlükler
  BASKANLIK          // Başkanlıklar
  KURUL              // Kurullar
  KURUM              // Kurumlar
  UNIVERSITE         // Üniversiteler
  BELEDIYE           // Belediyeler
  IL_OZEL_IDARESI    // İl Özel İdareleri
  VALILIK            // Valilikler
  KAYMAKAMLIK        // Kaymakamlıklar
  MAHKEME            // Mahkemeler
  SAVCILIK           // Savcılıklar
  ICRA_DAIRESI       // İcra Daireleri
  CEZAEVI            // Ceza İnfaz Kurumları
  HASTANE            // Kamu Hastaneleri ve Üniversite Hastaneleri
  DIGER              // Diğer
}

// Kamu Kurumu Rehberi (DETSİS verileri)
model PublicInstitution {
  id              String   @id @default(cuid())
  
  // DETSİS Bilgileri
  detsisNo        String   @unique  // DETSİS numarası
  name            String             // Kurum adı
  shortName       String?            // Kısa ad
  
  // Kategori ve Hiyerarşi
  category        PublicInstitutionCategory
  parentId        String?            // Üst kurum ID
  parent          PublicInstitution? @relation("InstitutionHierarchy", fields: [parentId], references: [id])
  children        PublicInstitution[] @relation("InstitutionHierarchy")
  
  // Adres Bilgileri
  city            String?
  district        String?
  address         String?
  postalCode      String?
  
  // İletişim
  phone           String?
  fax             String?
  email           String?
  website         String?
  kepAddress      String?            // KEP adresi
  
  // Ek Bilgiler
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([category])
  @@index([city])
  @@index([parentId])
  @@index([isActive])
}

// UYAP Birim Kodları (Mahkemeler, İcra Daireleri, Savcılıklar vb.)
model UyapUnit {
  id              String   @id @default(cuid())
  
  // UYAP Bilgileri
  birimId         String   @unique  // UYAP birim ID
  name            String             // Birim adı
  uyapCode        String?            // Organizasyon kodu (1.04.045.000.6005 gibi)
  
  // Kategori
  unitType        UyapUnitType
  
  // Konum
  city            String?
  district        String?
  
  // Ek Bilgiler
  isActive        Boolean  @default(true)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([name])
  @@index([unitType])
  @@index([city])
  @@index([isActive])
}

enum UyapUnitType {
  ICRA_DAIRESI        // İcra Daireleri
  ICRA_MAHKEMESI      // İcra Mahkemeleri
  ASLIYE_HUKUK        // Asliye Hukuk Mahkemeleri
  ASLIYE_CEZA         // Asliye Ceza Mahkemeleri
  AGIR_CEZA           // Ağır Ceza Mahkemeleri
  SULH_HUKUK          // Sulh Hukuk Mahkemeleri
  SULH_CEZA           // Sulh Ceza Mahkemeleri
  AILE_MAHKEMESI      // Aile Mahkemeleri
  IS_MAHKEMESI        // İş Mahkemeleri
  TUKETICI_MAHKEMESI  // Tüketici Mahkemeleri
  KADASTRO_MAHKEMESI  // Kadastro Mahkemeleri
  TICARET_MAHKEMESI   // Ticaret Mahkemeleri
  IDARE_MAHKEMESI     // İdare Mahkemeleri
  VERGI_MAHKEMESI     // Vergi Mahkemeleri
  SAVCILIK            // Savcılıklar
  CEZA_INFAZ          // Ceza İnfaz Kurumları
  DIGER               // Diğer
}

// ==================== ALACAK KALEMLERİ SİSTEMİ ====================

// Alacak Kalemi - Dosyadaki her bir alacak bileşeni
model ClaimItem {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  case            Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // Kalem Türü
  itemType        ClaimItemType    // PRINCIPAL, INTEREST, EXPENSE, FEE, ATTORNEY_FEE, PENALTY, TAX, OTHER
  
  // ⭐ KAYNAK SÜREÇ - Ana takip mi, ihtiyati haciz mi?
  sourceProcess   ClaimSourceProcess @default(MAIN_ENFORCEMENT)  // MAIN_ENFORCEMENT, PRECAUTIONARY
  sourceProcessId String?          // İhtiyati haciz kararı ID'si (sourceProcess=PRECAUTIONARY ise)
  
  // ⭐ TAKİP MUHASEBESİ - Üç Tutar Sistemi
  originalAmount  Decimal          @db.Decimal(15, 2)  // Evraktan gelen orijinal tutar (örn: çek bedeli 10.000)
  demandedAmount  Decimal          @db.Decimal(15, 2)  // Bu takipte talep edilen tutar (örn: 8.000)
  collectedAmount Decimal          @db.Decimal(15, 2) @default(0)  // Tahsil edilen tutar (TBK 100 ile dağıtılır)
  
  // Eski alan (geriye uyumluluk için korunuyor, yeni kayıtlarda demandedAmount kullanılacak)
  amount          Decimal          @db.Decimal(15, 2)
  currency        String           @default("TRY")
  
  // Kaynak Belge
  sourceDocumentId String?         // CaseDocument referansı
  sourceDocumentType DocumentSourceType? // FATURA, CEK, SENET, KIRA, SOZLESME, ILAM, DIGER
  
  // Faiz Bilgileri (itemType = INTEREST için)
  interestType    InterestType?    // YASAL, TICARI, AVANS, OZEL
  interestRate    Decimal?         @db.Decimal(5, 2)
  interestStartDate DateTime?
  interestEndDate DateTime?
  
  // Vade/Tarih Bilgileri
  dueDate         DateTime?        // Vade tarihi
  issueDate       DateTime?        // Düzenleme tarihi
  
  // Açıklama
  description     String?
  referenceNo     String?          // Fatura no, çek no, senet no vb.
  label           String?          // Özet panelde görünecek etiket
  
  // Hesaplama
  isCalculated    Boolean          @default(false)  // Otomatik hesaplandı mı
  calculatedAt    DateTime?
  isVirtual       Boolean          @default(false)  // Sanal kalem mi (sadece özette gösterilir)
  
  // Borçlu Sorumluluğu
  isAllDebtorsLiable Boolean       @default(true)   // Tüm borçlular sorumlu mu
  liableDebtorIds String[]         // Sorumlu borçlu ID'leri (isAllDebtorsLiable=false ise)
  
  // Durum
  status          ClaimItemStatus  @default(ACTIVE)
  
  // Sıralama
  sortOrder       Int              @default(0)
  bucket          String?          // Özet panelde hangi gruba ait (principal_bucket, fees_bucket vb.)
  
  // Meta
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?
  
  // İlişkiler
  ledgerAllocations LedgerAllocation[]

  @@index([tenantId])
  @@index([caseId])
  @@index([itemType])
  @@index([status])
  @@index([bucket])
}

// ⭐ TAKİP DEFTERİ - Tahsilat ve Düzeltme Kayıtları (TBK 100 / BK 84)
model LedgerEntry {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  case            Case             @relation(fields: [caseId], references: [id], onDelete: Cascade)
  
  // Kayıt Türü
  entryType       LedgerEntryType  // PAYMENT, ADJUSTMENT, WAIVER, REFUND
  
  // Tutar
  amount          Decimal          @db.Decimal(15, 2)
  currency        String           @default("TRY")
  
  // Tarih
  entryDate       DateTime         @default(now())
  effectiveDate   DateTime?        // İşlemin geçerli olduğu tarih
  
  // Açıklama
  description     String?
  referenceNo     String?          // Makbuz no, dekont no vb.
  
  // Kaynak
  sourceType      String?          // BANKA, KASA, UYAP, MANUEL
  sourceId        String?          // Banka işlem ID'si vb.
  
  // Dağıtım (TBK 100 sırasına göre)
  allocations     LedgerAllocation[]
  
  // Durum
  status          LedgerEntryStatus @default(CONFIRMED)
  
  // Meta
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?

  @@index([tenantId])
  @@index([caseId])
  @@index([entryType])
  @@index([entryDate])
}

// Tahsilat Dağıtımı - Hangi kaleme ne kadar düşüldü
model LedgerAllocation {
  id              String           @id @default(cuid())
  ledgerEntryId   String
  ledgerEntry     LedgerEntry      @relation(fields: [ledgerEntryId], references: [id], onDelete: Cascade)
  claimItemId     String
  claimItem       ClaimItem        @relation(fields: [claimItemId], references: [id], onDelete: Cascade)
  
  // Dağıtılan Tutar
  amount          Decimal          @db.Decimal(15, 2)
  
  // Sıra (TBK 100 mahsup sırası)
  allocationOrder Int
  
  // Meta
  createdAt       DateTime         @default(now())

  @@index([ledgerEntryId])
  @@index([claimItemId])
}

// Defter Kayıt Türü
enum LedgerEntryType {
  PAYMENT         // Tahsilat
  ADJUSTMENT      // Düzeltme
  WAIVER          // Feragat
  REFUND          // İade
  TRANSFER        // Virman
}

// Defter Kayıt Durumu
enum LedgerEntryStatus {
  PENDING         // Beklemede
  CONFIRMED       // Onaylandı
  CANCELLED       // İptal Edildi
}

// Alacak Kalemi Türü
enum ClaimItemType {
  PRINCIPAL       // Asıl Alacak (Ana Para)
  INTEREST        // Faiz
  PRE_INTEREST    // Takip Öncesi Faiz
  POST_INTEREST   // Takip Sonrası Faiz
  EXPENSE         // Masraf
  FEE             // Harç
  ATTORNEY_FEE    // Vekalet Ücreti
  PENALTY         // Ceza/Tazminat
  CHECK_PENALTY   // Karşılıksız Çek Tazminatı
  CONTRACTUAL_PENALTY // Cezai Şart
  TAX_KDV         // KDV
  TAX_BSMV        // BSMV
  TAX_KKDF        // KKDF
  OTHER           // Diğer
}

// Alacak Kalemi Kaynak Süreci
enum ClaimSourceProcess {
  MAIN_ENFORCEMENT  // Ana icra takibi
  PRECAUTIONARY     // İhtiyati haciz
}

// Kaynak Belge Türü
enum DocumentSourceType {
  FATURA          // Fatura
  CEK             // Çek
  SENET           // Senet/Bono
  KIRA            // Kira Sözleşmesi
  SOZLESME        // Sözleşme
  ILAM            // Mahkeme İlamı
  KARAR           // Mahkeme Kararı
  BORC_SENEDI     // Borç Senedi
  KREDI           // Kredi Sözleşmesi
  DIGER           // Diğer
}

// Alacak Kalemi Durumu
enum ClaimItemStatus {
  ACTIVE          // Aktif
  COLLECTED       // Tahsil Edildi
  WAIVED          // Feragat Edildi
  CANCELLED       // İptal Edildi
}

// Faiz Oranları Tablosu (Merkez Bankası oranları)
model InterestRate {
  id              String           @id @default(cuid())
  
  // Faiz Türü
  interestType    InterestType
  currency        String           @default("TRY")
  
  // Oran ve Dönem
  rate            Decimal          @db.Decimal(5, 2)  // Yıllık oran
  startDate       DateTime         // Geçerlilik başlangıcı
  endDate         DateTime?        // Geçerlilik bitişi (null = hala geçerli)
  
  // Kaynak
  source          String?          // TCMB, Resmi Gazete vb.
  sourceDate      DateTime?
  
  // Meta
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([interestType])
  @@index([currency])
  @@index([startDate])
  @@index([isActive])
}


// ==================== ZORUNLU UNSURLAR MİMARİSİ ====================
// Yapılacaklar.txt'deki "Master Zorunlu Unsurlar" dokümanına göre

// ==================== ENSTRÜMAN (ÇEK/SENET) ====================

// Çek veya Senet bilgileri - Kambiyo takipleri için
model CaseInstrument {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  
  // Enstrüman Türü
  instrumentType  InstrumentType   // CEK, SENET, BONO, POLICE
  
  // Temel Bilgiler
  serialNo        String           // Seri/Numara
  amount          Decimal          @db.Decimal(15, 2)
  currency        String           @default("TRY")
  
  // Tarihler
  issueDate       DateTime         // Keşide tarihi
  maturityDate    DateTime?        // Vade tarihi (senet için)
  presentmentDate DateTime?        // İbraz tarihi (çek için)
  
  // Çek Bilgileri
  bankName        String?          // Banka adı
  bankBranch      String?          // Şube adı
  bankCode        String?          // Banka kodu
  accountNo       String?          // Hesap numarası
  
  // Taraflar
  drawerName      String?          // Keşideci adı
  drawerIdentity  String?          // Keşideci TCKN/VKN
  payeeName       String?          // Lehdar adı
  payeeIdentity   String?          // Lehdar TCKN/VKN
  
  // Ciranta/Aval Bilgileri (JSON array)
  endorsers       Json?            // [{name, identity, date}]
  avals           Json?            // [{name, identity, amount}]
  
  // Çek Durumu
  isProtested     Boolean          @default(false)  // Protesto edildi mi
  protestDate     DateTime?        // Protesto tarihi
  protestNo       String?          // Protesto numarası
  isBounced       Boolean          @default(false)  // Karşılıksız mı (çek)
  bounceDate      DateTime?        // Karşılıksız çıkma tarihi
  bounceReason    String?          // Karşılıksız nedeni
  
  // Belge
  documentId      String?          // Taranmış belge referansı
  
  // Meta
  notes           String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([instrumentType])
  @@index([serialNo])
}

enum InstrumentType {
  CEK             // Çek
  SENET           // Senet/Bono
  BONO            // Bono
  POLICE          // Poliçe
}

// ==================== KİRA SÖZLEŞMESİ ====================

// Kira sözleşmesi bilgileri - Kira alacağı ve tahliye takipleri için
model CaseLease {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  
  // Sözleşme Bilgileri
  contractDate    DateTime?        // Sözleşme tarihi
  startDate       DateTime         // Kira başlangıç tarihi
  endDate         DateTime?        // Kira bitiş tarihi
  
  // Kira Bedeli
  monthlyRent     Decimal          @db.Decimal(15, 2)
  currency        String           @default("TRY")
  paymentDay      Int?             // Ödeme günü (1-31)
  
  // Taşınmaz Bilgileri
  propertyType    PropertyType     @default(KONUT)
  propertyAddress String           // Taşınmaz adresi
  propertyCity    String?
  propertyDistrict String?
  
  // Taraflar
  landlordName    String?          // Kiralayan adı
  landlordIdentity String?         // Kiralayan TCKN/VKN
  tenantName      String?          // Kiracı adı (borçlu)
  tenantIdentity  String?          // Kiracı TCKN/VKN
  
  // Tahliye Bilgileri (tahliye takibi için)
  evictionReason  EvictionReason?  // Tahliye sebebi
  evictionCommitmentDate DateTime? // Tahliye taahhüdü tarihi
  evictionNoticeDate DateTime?     // İhtar tarihi
  
  // Dönemsel Alacaklar (JSON array)
  // [{year: 2024, month: 1, amount: 5000, isPaid: false, dueDate: "2024-01-05"}]
  rentPeriods     Json?
  
  // Belge
  documentId      String?          // Taranmış sözleşme referansı
  
  // Meta
  notes           String?
  metadata        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([tenantId])
  @@index([caseId])
}

enum PropertyType {
  KONUT           // Konut
  ISYERI          // İşyeri
  ARSA            // Arsa
  TARLA           // Tarla
  DIGER           // Diğer
}

enum EvictionReason {
  TAAHHUT         // Tahliye taahhüdü
  TEMERRUT        // Kira ödenmemesi (temerrüt)
  SOZLESME_SONU   // Sözleşme süresi sonu
  IHTIYAC         // Malik ihtiyacı
  YENIDEN_INSAAT  // Yeniden inşa/imar
  DIGER           // Diğer
}

// ==================== İLAM BİLGİSİ ====================

// Mahkeme ilamı bilgileri - İlamlı takipler için
model CaseJudgment {
  id              String           @id @default(cuid())
  tenantId        String
  caseId          String
  
  // Mahkeme Bilgileri
