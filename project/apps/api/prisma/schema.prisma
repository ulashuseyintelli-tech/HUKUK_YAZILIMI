// ==================== OFİS PERSONELİ (AVUKAT HARİÇ) ====================

// Personel Türleri
enum StaffType {
  STAJYER_AVUKAT // Stajyer Avukat
  OFIS_KATIBI // Ofis Katibi
  ADLI_KATIP // Adli Katip (adliye koordinasyonu)
  SEKRETER // Sekreter
  MUHASEBE // Muhasebe
  ARSIV // Arşiv Sorumlusu
  DIGER // Diğer
}

// Ofis Personeli (Avukat hariç tüm çalışanlar)
model StaffMember {
  id       String  @id @default(cuid())
  tenantId String
  officeId String?

  // Kişisel Bilgiler
  firstName String
  lastName  String
  tckn      String? // TC Kimlik No
  email     String?
  phone     String? // Ofis telefonu (UI: "Ofis Telefonu")
  mobilePhone   String? // Cep telefonu — SMS eskalasyonu bu alana gider (PR-3b)
  whatsappPhone String? // WhatsApp numarası — gönderim ileride (entegrasyon yok)

  // Personel Türü
  staffType StaffType

  // Genel Yetkiler (büro genelinde varsayılan)
  canCreateCase        Boolean @default(false) // Dosya oluşturabilir
  canEditCase          Boolean @default(false) // Dosya düzenleyebilir
  canGenerateDocuments Boolean @default(false) // Belge taslağı hazırlayabilir
  canApproveDocuments  Boolean @default(false) // Belge onaylayabilir
  canSeeFinance        Boolean @default(false) // Muhasebe modülünü görebilir
  canApproveFinance    Boolean @default(false) // Muhasebe işlemi onaylayabilir
  canSendNotifications Boolean @default(false) // Tebligat gönderebilir
  isDefaultForNewCases Boolean @default(false) // Yeni dosyalarda otomatik seç

  isActive  Boolean @default(true)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  caseAssignments CaseStaff[]

  @@index([tenantId])
  @@index([officeId])
  @@index([staffType])
  @@index([isActive])
}

// Dosya Bazlı Personel Ataması
model CaseStaff {
  id            String      @id @default(cuid())
  caseId        String
  case          Case        @relation(fields: [caseId], references: [id], onDelete: Cascade)
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  // Bu dosyadaki rol
  roleOnCase String // STAJYER, KONTROL, YAZI_ISLERI, MUHASEBE, TEBLIGAT, ARSIV

  // Bu dosyadaki yetkiler (personelin genel yetkilerini override edebilir)
  canEdit    Boolean @default(false) // Dosya içeriğini düzenleyebilir
  canApprove Boolean @default(false) // İşlem onaylayabilir
  canView    Boolean @default(true) // Sadece görüntüleyebilir

  // Bildirimler
  receiveNotifications Boolean @default(true)

  // Atama bilgileri
  assignedAt   DateTime @default(now())
  assignedById String? // Kim atadı
  notes        String? // Özel notlar

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([caseId, staffMemberId])
  @@index([caseId])
  @@index([staffMemberId])
  @@index([roleOnCase])
}

// ==================== MÜVEKKİL İLETİŞİM SİSTEMİ ====================

// Müvekkil Bildirimleri (E-posta, SMS, WhatsApp logu)
model ClientNotification {
  id       String  @id @default(cuid())
  tenantId String
  clientId String
  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  caseId   String? // İlgili dosya (opsiyonel)

  // İletişim Kanalı
  channel String // EMAIL, SMS, WHATSAPP

  // Bildirim Türü
  type String // MASRAF_ISTEK, GENEL_BILGILENDIRME, RAPOR, HATIRLATMA, DIGER

  // İçerik
  subject String? // E-posta konusu
  body    String  @db.Text // Mesaj içeriği

  // Durum
  status       String    @default("PENDING") // PENDING, SENT, DELIVERED, FAILED
  sentAt       DateTime?
  deliveredAt  DateTime?
  errorMessage String?

  // Gönderen
  sentById String

  // Meta
  metadata Json? // Ek bilgiler (template id, vs.)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([caseId])
  @@index([channel])
  @@index([type])
  @@index([status])
}

// Portal Bildirimleri (Müvekkil portalında gösterilecek bildirimler)
model PortalNotification {
  id       String  @id @default(cuid())
  clientId String
  caseId   String? // İlgili dosya (opsiyonel)

  // Bildirim Türü
  type String // TAHSILAT, ISLEM, BELGE, DURUM_DEGISIKLIGI, GENEL

  // İçerik
  title   String
  message String

  // Durum
  isRead Boolean   @default(false)
  readAt DateTime?

  // Link (opsiyonel - tıklandığında yönlendirilecek sayfa)
  linkUrl String?

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([caseId])
  @@index([isRead])
  @@index([createdAt])
}

// Portal Belgeleri (Müvekkilin portaldan yüklediği belgeler)
model PortalDocument {
  id       String  @id @default(cuid())
  clientId String
  caseId   String? // İlgili dosya (opsiyonel)
  tenantId String

  // Belge Bilgileri
  type        String // VEKALET, KIMLIK, SOZLESME, DIGER
  title       String
  description String?

  // Dosya Bilgileri
  fileName String
  filePath String
  fileSize Int
  mimeType String

  // Durum
  status     String    @default("PENDING") // PENDING, APPROVED, REJECTED
  reviewedAt DateTime?
  reviewedBy String? // User ID
  reviewNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([caseId])
  @@index([tenantId])
  @@index([status])
}

// Portal Mesajları (Müvekkil-Büro arası mesajlaşma)
model PortalMessage {
  id       String  @id @default(cuid())
  clientId String
  tenantId String
  caseId   String? // İlgili dosya (opsiyonel)

  // Mesaj İçeriği
  content String

  // Gönderen
  senderType String // CLIENT veya OFFICE
  senderId   String // ClientPortalUser ID veya User ID
  senderName String

  // Okunma Durumu
  isRead Boolean   @default(false)
  readAt DateTime?

  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([tenantId])
  @@index([caseId])
  @@index([createdAt])
}

// Masraf Talepleri
model ExpenseRequest {
  id       String @id @default(cuid())
  tenantId String
  caseId   String
  case     Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Paket Bilgisi (otomatik oluşturma için)
  packageCode String? // UYAP_PRE, RE_TEBLIGAT, HACIZ (null = manuel)

  // YENİ: Gate tipi - UYAP kilidi için
  gateType ExpenseGateType @default(BLOCKING)

  // YENİ: Aşama kodu (hangi aşamada oluşturuldu)
  stageCode String? // OPENING, RE_NOTIFICATION, SEIZURE, SALE

  // YENİ: Kısmi ödeme takibi
  paidTotal Decimal @default(0) @db.Decimal(15, 2)

  // YENİ: İlişkili görev ID
  taskId String?

  // Masraf Kalemleri (eski format - geriye uyumluluk)
  items Json? // [{type: string, description: string, amount: number}]

  // Yeni format - ayrı tablo
  requestItems ExpenseRequestItem[]

  // YENİ: Ödeme kayıtları
  payments ExpensePayment[]

  // YENİ: Audit log
  auditLogs ExpenseAuditLog[]

  // Tutarlar
  totalSuggested Decimal? @db.Decimal(15, 2) // Sistem önerisi
  totalAmount    Decimal  @db.Decimal(15, 2) // Final tutar (override sonrası)
  currency       String   @default("TRY")

  // Son Ödeme Tarihi
  dueDate DateTime?

  // Durum Makinesi
  status ExpenseRequestStatus @default(PENDING)

  // Gönderim Bilgileri
  sentAt            DateTime?
  sentVia           String? // EMAIL, SMS, WHATSAPP
  messageTemplateId String? // Kullanılan şablon
  notificationId    String? // İlgili ClientNotification

  // Gönderim Tercihleri
  sendEmail    Boolean @default(false)
  sendSms      Boolean @default(false)
  sendWhatsapp Boolean @default(false)

  // Render edilmiş mesaj (audit için)
  renderedSubject String?
  renderedBody    String? @db.Text

  // Hatırlatma
  reminderCount  Int       @default(0)
  lastReminderAt DateTime?

  // Yanıt
  respondedAt   DateTime?
  responseNotes String?

  // Ödeme/Dekont
  paidAt           DateTime?
  paidAmount       Decimal?  @db.Decimal(15, 2)
  receiptDocId     String? // Dekont belgesi ID
  paymentMethod    String? // MANUAL, BANK_MATCH, VIRTUAL_POS
  paymentReference String? // Ödeme referans kodu (TB-xxx)

  // Oluşturan
  createdById String

  notes String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([caseId])
  @@index([clientId])
  @@index([status])
  @@index([packageCode])
  @@index([createdAt])
  @@index([dueDate])
}

// Masraf Talebi Kalemleri
model ExpenseRequestItem {
  id               String         @id @default(cuid())
  expenseRequestId String
  expenseRequest   ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)

  // Kalem Bilgileri
  itemCode    String // BASVURMA_HARCI, PESIN_HARC, TEBLIGAT_GIDERI
  label       String // "Başvurma Harcı"
  description String?

  // Tutarlar
  suggestedAmount Decimal @db.Decimal(15, 2) // Sistem önerisi
  finalAmount     Decimal @db.Decimal(15, 2) // Avukat girişi (override)
  currency        String  @default("TRY")

  // Override Bilgisi
  isEditable     Boolean   @default(true)
  wasOverridden  Boolean   @default(false)
  overrideReason String?
  overriddenById String?
  overriddenAt   DateTime?

  // Hesaplama Parametreleri (audit için)
  calcParams Json? // {"debtorCount": 2, "unitAmount": 15.00}

  // Sıralama
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expenseRequestId])
  @@index([itemCode])
}

// Masraf Ödeme Kayıtları
model ExpensePayment {
  id               String         @id @default(cuid())
  expenseRequestId String
  expenseRequest   ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)

  // Ödeme Bilgileri
  amount      Decimal  @db.Decimal(15, 2)
  paymentDate DateTime
  method      String // BANK_TRANSFER, CASH, VIRTUAL_POS
  reference   String? // Dekont no, referans kodu
  notes       String?

  // Eşleştirme Bilgisi
  matchedBy   String? // AUTO, MANUAL
  matchedById String? // Eşleştiren kullanıcı ID

  createdAt DateTime @default(now())

  @@index([expenseRequestId])
  @@index([paymentDate])
}

// Masraf Audit Log
model ExpenseAuditLog {
  id               String         @id @default(cuid())
  expenseRequestId String
  expenseRequest   ExpenseRequest @relation(fields: [expenseRequestId], references: [id], onDelete: Cascade)

  // Log Bilgileri
  action  String // CREATED, ITEM_ADDED, ITEM_UPDATED, SENT, PAYMENT_RECORDED, STATUS_CHANGED, OVERRIDE
  details Json? // Detay bilgisi (eski değer, yeni değer vb.)
  userId  String? // İşlemi yapan kullanıcı

  createdAt DateTime @default(now())

  @@index([expenseRequestId])
  @@index([action])
  @@index([createdAt])
}

// Mesaj Şablonları (E-posta, SMS, WhatsApp)
model MessageTemplate {
  id       String @id @default(cuid())
  tenantId String

  // Şablon Bilgileri
  code        String // Benzersiz kod: MASRAF_TALEBI, MASRAF_HATIRLATMA, DOSYA_ACILDI, TAHSILAT_BILGI
  name        String // Görünen ad: "Masraf Talebi", "Hatırlatma"
  description String? // Açıklama

  // Kategori
  category MessageTemplateCategory

  // Kanal
  channel MessageTemplateChannel @default(EMAIL)

  // İçerik
  subject String? // E-posta konusu (SMS/WhatsApp için null)
  body    String  @db.Text // Mesaj içeriği

  // Kullanılabilir Token'lar (bilgi amaçlı)
  // {{clientName}}, {{caseFileNumber}}, {{executionFileNumber}}, {{executionOfficeName}}
  // {{totalAmount}}, {{dueDate}}, {{items}}, {{lawyerName}}, {{officePhone}}
  availableTokens Json? // ["clientName", "caseFileNumber", ...]

  // Ayarlar
  isActive  Boolean @default(true)
  isSystem  Boolean @default(false) // Sistem şablonu (silinemez)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([category])
  @@index([channel])
  @@index([isActive])
}

// Mesaj Şablonu Kategorisi
enum MessageTemplateCategory {
  CLIENT_INFO // Müvekkil bilgilendirme (dosya açıldı, durum güncelleme)
  EXPENSE_REQUEST // Masraf talebi
  EXPENSE_REMINDER // Masraf hatırlatma
  COLLECTION_INFO // Tahsilat bildirimi
  DEBTOR_NOTICE // Borçluya bildirim
  GREETING // Tebrik mesajları
  OTHER // Diğer
}

// Mesaj Şablonu Kanalı
enum MessageTemplateChannel {
  EMAIL // E-posta
  SMS // SMS
  WHATSAPP // WhatsApp
}

// ==================== ÖZEL GÜNLER & TEBRİK SİSTEMİ ====================

// Özel Günler (Bayramlar, Anma Günleri, vb.)
model SpecialDay {
  id       String  @id @default(cuid())
  tenantId String? // null = sistem geneli, değer = büroya özel

  // Gün Bilgileri
  name String // Ramazan Bayramı, Kurban Bayramı, 10 Kasım, vb.
  type String // RELIGIOUS (Dini), NATIONAL (Milli), MEMORIAL (Anma), CUSTOM (Özel)

  // Tarih (yıl olmadan - her yıl tekrarlar)
  month Int // 1-12
  day   Int // 1-31

  // Bazı bayramlar değişken tarihli (Hicri takvim)
  isVariable Boolean @default(false) // Değişken tarihli mi
  year       Int? // Değişken tarihli ise hangi yıl için geçerli

  // Mesaj Şablonu
  greetingMessage String? // Varsayılan tebrik mesajı
  smsMessage      String? // SMS için kısa mesaj (160 karakter)

  // Ayarlar
  isActive           Boolean @default(true)
  sendGreeting       Boolean @default(true) // Otomatik tebrik gönder
  daysBeforeReminder Int     @default(0) // Kaç gün önce hatırlat

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([month, day])
  @@index([type])
  @@index([isActive])
}

// Tebrik Kuyruğu (Gönderilecek tebrikler)
model GreetingQueue {
  id       String @id @default(cuid())
  tenantId String

  // Alıcı
  clientId String

  // Tebrik Türü
  type String // BIRTHDAY, FOUNDING_ANNIVERSARY, POA_ANNIVERSARY, HOLIDAY, MEMORIAL

  // Özel gün referansı (bayram/anma günü için)
  specialDayId String?

  // Gönderim
  channel     String // EMAIL, SMS, BOTH
  scheduledAt DateTime // Gönderilecek tarih/saat

  // Mesaj
  subject String? // E-posta konusu
  message String // Mesaj içeriği

  // Durum
  status       String    @default("PENDING") // PENDING, SENT, FAILED, CANCELLED
  sentAt       DateTime?
  errorMessage String?

  // İlişkili bildirim
  notificationId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([clientId])
  @@index([scheduledAt])
  @@index([status])
  @@index([type])
}

// ==================== TAKVİM & AJANDA ====================

// Takvim Etkinlikleri
model CalendarEvent {
  id       String @id @default(cuid())
  tenantId String

  // Etkinlik Bilgileri
  title       String
  description String?
  date        DateTime
  time        String? // "10:00" formatında

  // Tür
  type String // DURUSMA, HATIRLATICI, GOREV, DIGER

  // İlişkili Dosya (opsiyonel)
  caseId String?

  // Konum
  location String?

  // Durum
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  // Oluşturan
  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([date])
  @@index([caseId])
  @@index([type])
  @@index([isCompleted])
}

// ==================== HATA KAYITLARI (ERROR LOG) ====================

model ErrorLog {
  id       String  @id @default(cuid())
  tenantId String?

  // Hata Bilgileri
  level   String // ERROR, WARN, INFO, DEBUG
  source  String // API, FRONTEND, CRON, UYAP, vb.
  message String
  stack   String? // Stack trace

  // Bağlam
  endpoint   String? // API endpoint
  method     String? // GET, POST, PUT, DELETE
  statusCode Int?

  // Kullanıcı
  userId    String?
  userIp    String?
  userAgent String?

  // Ek Bilgiler
  metadata Json? // Request body, params, vb.

  // Çözüm Durumu
