  COMPLETED // Tamamlandı
  FAILED // Başarısız
  CANCELLED // İptal edildi
}

// ==================== ICRABOT MODULE ====================

// Bot Görev Durumu
enum BotTaskStatus {
  PENDING // Bekliyor
  QUEUED // Kuyruğa alındı
  RUNNING // Çalışıyor
  COMPLETED // Tamamlandı
  FAILED // Başarısız
  RETRY // Yeniden deneniyor
  CANCELLED // İptal edildi
  NEEDS_APPROVAL // Onay bekliyor
}

// Bot Görev Önceliği
enum BotTaskPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

// Bot Görevi
model BotTask {
  id       String @id @default(cuid())
  tenantId String
  caseId   String

  // Recipe bilgisi
  recipeId String // Recipe tanımlayıcı

  // Durum
  status   BotTaskStatus   @default(PENDING)
  priority BotTaskPriority @default(MEDIUM)

  // Zamanlama
  scheduledAt DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?

  // Retry
  attemptCount Int     @default(0)
  maxAttempts  Int     @default(3)
  lastError    String?

  // Girdi/Çıktı
  inputData  Json?
  outputData Json?

  // Onay
  requiresApproval Boolean   @default(false)
  approvedBy       String?
  approvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id])
  case           Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  approvedByUser User?  @relation("BotTaskApprover", fields: [approvedBy], references: [id])

  // Kanıtlar
  evidence BotEvidence[]

  @@index([tenantId])
  @@index([caseId])
  @@index([recipeId])
  @@index([status])
  @@index([priority])
  @@index([scheduledAt])
}

// Bot Kanıt Kaydı
model BotEvidence {
  id       String  @id @default(cuid())
  tenantId String?
  caseId   String
  taskId   String?

  // Recipe ve aksiyon
  recipeId String
  action   String // TEBLIGAT_SENT, ASSET_QUERY_SGK, FINALIZATION_DETECTED, etc.

  // Tetikleyen
  triggeredBy String @default("AUTO") // AUTO, MANUAL, RULE

  // Veri snapshot
  dataSnapshot Json
  dataHash     String // SHA-256 hash (bütünlük için)

  // Ekran görüntüsü (opsiyonel)
  screenshotUrl String?

  // Zaman damgası
  timestamp DateTime @default(now())

  case Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  task BotTask? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([caseId])
  @@index([taskId])
  @@index([recipeId])
  @@index([action])
  @@index([timestamp])
}

// ==================== ICRABOT v14-v16 MODELS ====================

// Bundle Durumu
enum IcrabotBundleStatus {
  DRAFT // Taslak
  APPROVED // Onaylandı
  ACTIVE // Aktif
  ARCHIVED // Arşivlendi
}

// Bundle Türü
enum IcrabotBundleType {
  RECIPE // Recipe tanımları
  PARAMS // Parametre değerleri
  UIMAP // UI haritası
  DECISION_RULES // Decision rules (v24)
  RISK // Risk scoring parametreleri (v28)
  RECOVERY // Recovery simulation parametreleri (v28)
  PLAN // Stage-based planning (v29)
  QUEUE_POLICY // Queue policy (v31) - concurrency limits, quotas
  SLA_POLICY // SLA policy (v32) - age-based priority boost
}

// Recipe/Params/UiMap Bundle (v14)
model IcrabotBundle {
  id       String @id @default(cuid())
  tenantId String

  // Bundle bilgileri
  type    IcrabotBundleType
  name    String
  version Int                 @default(1)
  status  IcrabotBundleStatus @default(DRAFT)

  // İçerik
  content     Json // YAML/JSON içerik
  contentHash String // SHA-256 hash

  // Notlar
  notes String?

  // Onay bilgileri
  approvedAt DateTime?
  approvedBy String?

  // Aktivasyon bilgileri
  activatedAt DateTime?
  activatedBy String?

  // Oluşturan
  createdBy String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([status])
  @@index([name, version])
}

// Job Çalıştırma Durumu
enum IcrabotJobStatus {
  QUEUED // Kuyruğa alındı
  RUNNING // Çalışıyor
  DONE // Tamamlandı
  FAILED // Başarısız
  QUARANTINED // Karantinaya alındı
}

// Job Risk Seviyesi
enum IcrabotRiskLevel {
  READ_ONLY // Sadece okuma
  LOW // Düşük risk
  MEDIUM // Orta risk
  HIGH // Yüksek risk
  CRITICAL // Kritik
}

// Job Çalıştırma Kaydı (v15-v16)
model IcrabotJobRun {
  id       String  @id @default(cuid())
  tenantId String
  caseId   String
  debtorId String? // v30: Debtor-scoped jobs

  // Job tanımlayıcı
  jobId         String @unique
  recipeId      String
  recipeVersion Int    @default(1)

  // Durum
  status    IcrabotJobStatus @default(QUEUED)
  riskLevel IcrabotRiskLevel @default(READ_ONLY)
  priority  Int              @default(100) // v31: Lower = higher priority

  // Deneme bilgileri
  attempt     Int @default(0)
  maxAttempts Int @default(4)

  // Hata bilgileri
  lastErrorCode    String?
  lastErrorMessage String?

  // Zamanlar
  startedAt  DateTime?
  finishedAt DateTime?

  // v38: Job leasing for multi-worker
  leasedUntil DateTime?
  leasedBy    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  case   Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
  debtor Debtor? @relation(fields: [debtorId], references: [id])

  // İlişkiler
  steps IcrabotJobStep[]

  @@index([tenantId])
  @@index([caseId])
  @@index([debtorId])
  @@index([jobId])
  @@index([recipeId])
  @@index([status])
  @@index([priority])
  @@index([createdAt])
}

// Job Adımı (v16)
model IcrabotJobStep {
  id    String @id @default(cuid())
  jobId String

  // Adım bilgileri
  stepNo      Int
  actionType  String // open, click, read, fill, query, recipe_meta
  uyapNavPath String? // UYAP navigasyon yolu

  // Durum
  status String @default("ok") // ok, error, skipped

  // Kanıt referansı
  snapshotHash String?
  proofRef     String? // IcrabotEvidence.snapshotId

  createdAt DateTime @default(now())

  job IcrabotJobRun @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([stepNo])
  @@index([actionType])
}

// Kanıt/Snapshot Kaydı (v14-v16)
model IcrabotEvidence {
  id       String @id @default(cuid())
  tenantId String
  caseId   String

  // Snapshot tanımlayıcı
  snapshotId   String @unique
  snapshotHash String // SHA-256 hash

  // Veri
  payload Json

  // Ekran görüntüsü (opsiyonel)
  screenshotUrl String?

  createdAt DateTime @default(now())

